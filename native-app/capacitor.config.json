    "SocialLogin": {
      "google": {
        "iOSClientId": "944339730636-2enclt34i6lq8g203bk0afhorbll1dt3.apps.googleusercontent.com",
        "iOSURLScheme": "com.googleusercontent.apps.944339730636-2enclt34i6lq8g203bk0afhorbll1dt3"
      }
    }
