<style>
.hide-scrollbar::-webkit-scrollbar { display: none; }
.hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<div style="min-height:100dvh; background:white; padding:0 0 80px 0; display:flex; flex-direction:column;">

  <!-- 헤더 -->
  <div style="background:white; padding:18px 20px 14px 20px; border-bottom:1px solid #f0f0f0; position:sticky; top:0; z-index:30;">
    <div style="display:flex; justify-content:space-between; align-items:center;">
      <div style="font-size:24px; color:#111827; font-weight:900; cursor:pointer;" onclick="openDrawer()">☰</div>
      <div style="font-size:18px; font-weight:900; color:#111827;">📝 일정 메모</div>
      <%= link_to daily_memo_path(memo_date: Date.today), style: "padding:6px 12px; background:#2563eb; color:white; border-radius:8px; text-decoration:none; font-size:13px; font-weight:800;" do %>
        오늘 기록
      <% end %>
    </div>
  </div>

  <!-- 캘린더 컨테이너 -->
  <div style="background:white; padding:20px 10px 0 10px; margin-bottom:0; flex:1; display:flex; flex-direction:column;">
    
    <!-- 스와이프를 위한 숨김 링크 -->
    <%= link_to "", daily_memos_list_path(year: @prev_month.year, month: @prev_month.month), id: "prevMonthLink", style: "display:none;" %>
    <%= link_to "", daily_memos_list_path(year: @next_month.year, month: @next_month.month), id: "nextMonthLink", style: "display:none;" %>

    <!-- 네이티브 월 선택기 (중앙) -->
    <div style="display:flex; justify-content:center; align-items:center; margin-bottom:24px; position:relative;">
      <div style="position:relative; display:inline-flex; align-items:center; cursor:pointer;">
        <div style="font-size:22px; font-weight:900; color:#111827; letter-spacing:-0.5px;">
          <%= @calendar_year %>. <%= format('%02d', @calendar_month) %> <span style="font-size:16px; margin-left:4px; vertical-align:middle; color:#6b7280;">⌃</span>
        </div>
        <input type="month" 
               value="<%= format('%04d-%02d', @calendar_year, @calendar_month) %>"
               onchange="window.location.href='<%= daily_memos_list_path %>?year=' + this.value.split('-')[0] + '&month=' + parseInt(this.value.split('-')[1])"
               style="position:absolute; top:0; left:0; width:100%; height:100%; opacity:0; cursor:pointer;" />
      </div>
    </div>

    <!-- 요일 헤더 -->
    <div style="display:grid; grid-template-columns:repeat(7, 1fr); text-align:center; margin-bottom:14px;">
      <% ['일', '월', '화', '수', '목', '금', '토'].each_with_index do |day_name, index| %>
        <div style="font-size:13px; font-weight:800; color:<%= index == 0 ? '#ef4444' : index == 6 ? '#3b82f6' : '#9ca3af' %>;">
          <%= day_name %>
        </div>
      <% end %>
    </div>

    <!-- 달력 그리드 -->
    <div id="calendarGrid" style="display:grid; grid-template-columns:repeat(7, 1fr); gap:4px; flex:1;">
      <% @calendar_days.each do |date| %>
        <%
          is_current_month = date.month == @calendar_month
          is_today = date == Date.today
          memo = @memos_by_date[date]
          
          # 텍스트 컬러 지정
          text_color = if date.wday == 0; '#ef4444' # 일
                       elsif date.wday == 6; '#3b82f6' # 토
                       elsif is_current_month; '#111827'
                       else; '#d1d5db' end
          
          bg_color = is_today ? "#eff6ff" : "transparent"
          border = is_today ? "1px solid #bfdbfe" : "none"
        %>
        
        <%= link_to daily_memo_path(memo_date: date), style: "text-decoration:none; color:inherit; display:flex; flex-direction:column; background:#{bg_color}; border:#{border}; border-radius:12px; padding:6px 4px; min-height:86px; position:relative; overflow:hidden;" do %>
          
          <!-- 날짜 번호 -->
          <div style="font-size:14px; font-weight:900; text-align:center; margin-bottom:4px; opacity:<%= is_current_month ? '1' : '0.4' %>; color:<%= text_color %>;">
            <%= date.day %>
          </div>
          
          <!-- 메모 표시 영역 -->
          <% if memo.present? %>
            <div style="flex:1; background:#fef3c7; border-radius:8px; padding:4px 5px; border-left:3px solid #f59e0b; opacity:<%= is_current_month ? '1' : '0.6' %>;">
               <div style="font-size:10px; font-weight:700; color:#b45309; line-height:1.2; text-align:left; display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; overflow:hidden;">
                 <%= memo.content %>
               </div>
            </div>
          <% else %>
             <div style="flex:1;"></div>
          <% end %>

        <% end %>
      <% end %>
    </div>
  </div>

  <!-- 간단한 안내 메시지 -->
  <div style="text-align:center; margin-top:8px;">
    <span style="font-size:13px; font-weight:600; color:#9ca3af; display:flex; align-items:center; justify-content:center; gap:6px;">
      💡 날짜를 터치하면 일정 다이어리를 작성할 수 있습니다.
    </span>
  </div>
</div>

<script>
  document.addEventListener("turbo:load", function() {
    let touchStartX = 0;
    let touchEndX = 0;
    const grid = document.getElementById("calendarGrid");

    if (grid) {
      grid.addEventListener("touchstart", function(e) {
        touchStartX = e.changedTouches[0].screenX;
      }, {passive: true});

      grid.addEventListener("touchend", function(e) {
        touchEndX = e.changedTouches[0].screenX;
        handleSwipe();
      }, {passive: true});
    }

    function handleSwipe() {
      const threshold = 50;
      if (touchEndX < touchStartX - threshold) {
        const nextLink = document.getElementById("nextMonthLink");
        if (nextLink) nextLink.click();
      }
      if (touchEndX > touchStartX + threshold) {
        const prevLink = document.getElementById("prevMonthLink");
        if (prevLink) prevLink.click();
      }
    }
  });
</script>
