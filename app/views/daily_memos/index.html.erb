<style>
.hide-scrollbar::-webkit-scrollbar { display: none; }
.hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

@keyframes slideInRight {
  from { transform: translateX(30vw); opacity: 0; }
  to { transform: translateX(0); opacity: 1; }
}
@keyframes slideInLeft {
  from { transform: translateX(-30vw); opacity: 0; }
  to { transform: translateX(0); opacity: 1; }
}
.calendar-animate-in {
  animation: slideInRight 0.3s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
}

#diaryRoot {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: calc(58px + env(safe-area-inset-bottom, 0px));
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: white;
  z-index: 10;
}
@media (min-width: 480px) {
  #diaryRoot {
    left: 50%;
    transform: translateX(-50%);
    width: 430px;
    right: auto;
  }
}
</style>

<div id="diaryRoot">

  <!-- 헤더 -->
  <div style="background:white; padding:18px 20px 14px 20px; border-bottom:1px solid #f0f0f0; position:sticky; top:0; z-index:30;">
    <div style="display:flex; justify-content:space-between; align-items:center;">
      <div style="font-size:24px; color:#111827; font-weight:900; cursor:pointer;" onclick="openDrawer()">☰</div>
      
      <div style="font-size:20px; font-weight:900; color:#111827; position:absolute; left:50%; transform:translateX(-50%); display:flex; align-items:center; gap:6px;">
        <span style="font-size:22px;">📒</span> 일일 다이어리
      </div>

      <%= link_to notifications_path, style: "position:relative; text-decoration:none;" do %>
        <div style="font-size:24px;">🔔</div>
        <% if @unread_notifications_count.to_i > 0 %>
          <div style="position:absolute; top:-4px; right:-6px; min-width:18px; height:18px; padding:0 5px; border-radius:999px; background:#ef4444; color:white; font-size:11px; font-weight:900; display:flex; align-items:center; justify-content:center; box-sizing:border-box;">
            <%= @unread_notifications_count %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- 캘린더 컨테이너 -->
  <div style="background:white; padding:14px 0 0 0; margin-bottom:0; flex:1; display:flex; flex-direction:column; position:relative;">
    
    <!-- 스와이프를 위한 숨김 링크 -->
    <%= link_to "", daily_memos_list_path(year: @prev_month.year, month: @prev_month.month), id: "prevMonthLink", style: "display:none;" %>
    <%= link_to "", daily_memos_list_path(year: @next_month.year, month: @next_month.month), id: "nextMonthLink", style: "display:none;" %>

    <!-- 네이티브 월 선택기 (중앙) -->
    <div style="display:flex; justify-content:center; align-items:center; margin-bottom:14px; position:relative;">
      <div style="position:relative; display:inline-flex; align-items:center; cursor:pointer;">
        <div style="font-size:20px; font-weight:900; color:#111827; letter-spacing:-0.5px;">
          <%= @calendar_year %> . <%= @calendar_month %> <span style="font-size:15px; margin-left:4px; vertical-align:middle; color:#111827;">⌃</span>
        </div>
        <input type="month" 
               value="<%= format('%04d-%02d', @calendar_year, @calendar_month) %>"
               onchange="window.location.href='<%= daily_memos_list_path %>?year=' + this.value.split('-')[0] + '&month=' + parseInt(this.value.split('-')[1])"
               style="position:absolute; top:0; left:0; width:100%; height:100%; opacity:0; cursor:pointer;" />
      </div>
    </div>

    <!-- 달력 본체 영역 (스와이프 + 요일 + 그리드) -->
    <div style="overflow-x:hidden; overflow-y:auto; background:white; flex:1; height:0; display:flex; flex-direction:column; position:relative; touch-action:pan-y; -webkit-overflow-scrolling:touch; overscroll-behavior:contain;">
      <div id="calendarGrid" class="calendar-animate-in" style="flex:1; display:flex; flex-direction:column; width:100%; will-change:transform;">
        
        <!-- 요일 헤더 -->
        <div style="display:grid; grid-template-columns:repeat(7, 1fr); text-align:center; border-bottom:1px solid #f0f0f0;">
          <% ['일', '월', '화', '수', '목', '금', '토'].each_with_index do |day_name, index| %>
            <div style="padding:10px 0; font-size:14px; font-weight:900; color:<%= index == 0 ? '#ef4444' : index == 6 ? '#3b82f6' : '#374151' %>;">
              <%= day_name %>
            </div>
          <% end %>
        </div>

        <!-- 달력 그리드 -->
        <div style="display:grid; grid-template-columns:repeat(7, 1fr); flex:1; align-content:start;">
          <% @calendar_days.each do |date| %>
            <%
              is_current_month = date.month == @calendar_month
              is_today = date == Date.today
              memo = @memos_by_date[date]
              
              # 텍스트 컬러 지정
              text_color = if !is_current_month; '#d1d5db'
                           elsif date.wday == 0; '#ef4444' # 일
                           elsif date.wday == 6; '#3b82f6' # 토
                           else; '#111827' end
              
              bg_color = is_today ? "#eff6ff" : "transparent"
            %>
            
            <%= link_to daily_memo_path(memo_date: date), style: "text-decoration:none; color:inherit; display:flex; flex-direction:column; align-items:center; background:#{bg_color}; border-right:#{date.wday == 6 ? 'none' : '1px solid #f0f0f0'}; border-bottom:1px solid #f0f0f0; padding:12px 2px; height:120px; position:relative;" do %>
              
              <!-- 날짜 번호 -->
              <div style="font-size:18px; font-weight:900; margin-bottom:8px; color:<%= text_color %>;">
                <%= date.day %>
              </div>
              
              <!-- 메모 표시 영역 -->
              <% if memo.present? %>
                 <div style="width:100%; padding:0 4px; font-size:10px; font-weight:700; color:#374151; line-height:1.25; text-align:center; display:-webkit-box; -webkit-line-clamp:4; -webkit-box-orient:vertical; overflow:hidden; word-break:keep-all;">
                   <%= memo.content %>
                 </div>
              <% end %>

            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
// 부드러운 네이티브 스와이프 로직
(function() {
  var swipeStartX = 0, swipeStartY = 0;
  var isSwiping = false;
  var hasMoved = false;
  var grid = document.getElementById("calendarGrid");

  if (!grid) return;

  grid.addEventListener('touchstart', function(e) {
    swipeStartX = e.touches[0].clientX;
    swipeStartY = e.touches[0].clientY;
    isSwiping = true;
    hasMoved = false;
    grid.style.transition = 'none'; // 드래그 중엔 트랜지션 해제
  }, { passive: true });

  grid.addEventListener('touchmove', function(e) {
    if (!isSwiping || !grid) return;
    
    var dx = e.touches[0].clientX - swipeStartX;
    var dy = e.touches[0].clientY - swipeStartY;
    
    // 세로 스크롤이 더 크면 스와이프 인식 취소
    if (!hasMoved && Math.abs(dy) > Math.abs(dx)) {
      isSwiping = false;
      return;
    }
    
    // 약간의 움직임이 있을 때 가로 스와이프로 판단
    if (Math.abs(dx) > 10) {
      hasMoved = true;
      if (e.cancelable) e.preventDefault(); // 스크롤(뒤로가기 제스처 등) 방지
      // 저항감(0.9)
      grid.style.transform = 'translateX(' + (dx * 0.9) + 'px)';
    }
  }, { passive: false });

  grid.addEventListener('touchend', function(e) {
    if (!isSwiping || !grid) return;
    isSwiping = false;
    
    var dx = e.changedTouches[0].clientX - swipeStartX;
    
    // 복귀 / 슬라이드 아웃 애니메이션
    grid.style.transition = 'transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s';
    
    if (dx < -60) {
      // ⬅️ 다음 달 (오른쪽에서 나타남)
      grid.style.transform = 'translateX(-30vw)';
      grid.style.opacity = '0';
      setTimeout(function() {
        var next = document.getElementById('nextMonthLink');
        if (next) next.click();
      }, 150);
    } else if (dx > 60) {
      // ➡️ 이전 달 (왼쪽에서 나타남)
      grid.style.transform = 'translateX(30vw)';
      grid.style.opacity = '0';
      setTimeout(function() {
        var prev = document.getElementById('prevMonthLink');
        if (prev) prev.click();
      }, 150);
    } else {
      // 덜 밀었을 때는 원래 자리로 탄력 복귀
      grid.style.transform = 'translateX(0)';
      grid.style.opacity = '1';
    }
  });
})();
</script>
