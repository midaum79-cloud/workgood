<div style="display:grid; grid-template-columns:repeat(7, 1fr); flex:1; align-content:start;">
  <% @calendar_rows.flatten.compact.each do |date| %>
    <%
      is_current_month = date.month == @calendar_month
      is_today = date == Date.today
      memo = @memos_by_date[date]
      
      holidays = Holidays.on(date, :kr)
      is_holiday = holidays.any?

      # 텍스트 컬러 지정 (세련된 색상 톤)
      text_color = if !is_current_month; '#d1d5db'
                   elsif date.wday == 0 || is_holiday; '#ef4444' # 일, 공휴일
                   elsif date.wday == 6; '#3b82f6' # 토
                   else; '#111827' end
    %>
    
    <%= link_to daily_memo_path(memo_date: date), style: "text-decoration:none; color:inherit; display:flex; flex-direction:column; align-items:center; background:transparent; border-right:#{date.wday == 6 ? 'none' : '1px solid #f3f4f6'}; border-bottom:1px solid #f3f4f6; padding:6px 2px; height:108px; position:relative;" do %>
      
      <!-- 날짜 번호 (가로바 스타일) -->
      <div style="width:100%; padding:0 2px; margin-bottom:4px; box-sizing:border-box;">
        <div style="
          display:flex; align-items:center; justify-content:center;
          width:100%; height:20px; border-radius:4px;
          font-size:14px; font-weight:800;
          color:<%= is_today ? 'white' : text_color %>;
          background:<%= is_today ? '#3b82f6' : 'transparent' %>;
        ">
          <%= date.day %>
        </div>
      </div>
      
      <!-- 메모 표시 영역 (모던한 블록 스타일) -->
      <% if memo.present? %>
         <div style="width:92%; padding:4px 6px; background:#f8fafc; border:1px solid #f1f5f9; border-radius:6px; font-size:10px; font-weight:600; color:#334155; line-height:1.3; text-align:left; display:-webkit-box; -webkit-line-clamp:4; -webkit-box-orient:vertical; overflow:hidden; word-break:break-all;">
           <%= memo.content %>
         </div>
      <% end %>

    <% end %>
  <% end %>
</div>
