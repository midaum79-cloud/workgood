<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>로그인 완료</title>
  <style>
    body {
      margin: 0; padding: 0;
      background: #0a0f1e;
      display: flex; align-items: center; justify-content: center;
      min-height: 100vh;
      font-family: -apple-system, BlinkMacSystemFont, sans-serif;
      color: white;
    }
    .container { text-align: center; padding: 24px; }
    .spinner {
      width: 40px; height: 40px;
      border: 3px solid rgba(255,255,255,0.15);
      border-top: 3px solid #2563eb;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      margin: 0 auto 20px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    h2 { font-size: 18px; margin-bottom: 8px; }
    p { font-size: 14px; color: rgba(255,255,255,0.5); }
    .btn {
      display: inline-block; margin-top: 20px;
      padding: 12px 24px; background: #2563eb;
      color: white; border-radius: 12px;
      text-decoration: none; font-weight: 700; font-size: 14px;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="spinner"></div>
    <h2>✅ Google 로그인 성공!</h2>
    <p>앱으로 돌아가는 중...</p>
    <a class="btn" href="<%= @deep_link %>" id="return-btn" style="display:none;">앱으로 돌아가기</a>
    <a class="btn" href="<%= @web_fallback || "/auth/token_login?token=#{@deep_link.split('token=').last}" %>" id="web-btn" style="display:none; margin-top:10px; background:#374151;">웹에서 계속하기</a>
  </div>
  <script>
    var deepLink = '<%= @deep_link %>';
    var token = deepLink.split('token=')[1];
    var webFallback = window.location.origin + '/auth/token_login?token=' + token;

    // iOS 감지
    var isIOS = /iPhone|iPad|iPod/i.test(navigator.userAgent);

    if (isIOS) {
      // iOS: SFSafariViewController에서 커스텀 스키마가 차단됨
      // 방법 1: iframe으로 딥링크 시도
      var iframe = document.createElement('iframe');
      iframe.style.display = 'none';
      iframe.src = deepLink;
      document.body.appendChild(iframe);

      // 방법 2: 1.5초 후에도 앱으로 못 돌아가면 웹 폴백 URL로 이동
      setTimeout(function() {
        // 직접 웹 세션 생성으로 폴백
        window.location.href = webFallback;
      }, 1500);

      // 3초 후에도 남아있으면 수동 버튼 표시
      setTimeout(function() {
        document.getElementById('return-btn').style.display = 'inline-block';
        document.getElementById('web-btn').style.display = 'inline-block';
      }, 3000);
    } else {
      // Android: 기존 방식 - 직접 딥링크
      window.location.href = deepLink;

      // 2초 후에도 남아있으면 수동 버튼 표시
      setTimeout(function() {
        document.getElementById('return-btn').style.display = 'inline-block';
      }, 2000);
    }
  </script>
</body>
</html>
