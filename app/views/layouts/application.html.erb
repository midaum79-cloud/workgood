<!DOCTYPE html>
<html lang="ko">
  <head>
    <title>일머리</title>
    <meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no,viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="일머리">
    <meta name="theme-color" content="#ffffff">
    <meta name="format-detection" content="telephone=no">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="manifest" href="/manifest.json">
    <link rel="apple-touch-icon" href="/icon-192.png">
    <link rel="icon" href="/icon-192.png">

    <link rel="stylesheet" as="style" crossorigin href="https://cdn.jsdelivr.net/npm/pretendard/dist/web/static/pretendard.css" />

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <style>
      * {
        box-sizing: border-box;
        -webkit-tap-highlight-color: transparent;
      }

      html {
        height: 100%;
      }

      body {
        margin: 0;
        padding: 0;
        height: 100%;
        background: #e8eaed;
        color: #111827;
        font-family: "Pretendard", -apple-system, BlinkMacSystemFont, "Apple SD Gothic Neo", "Noto Sans KR", "Malgun Gothic", sans-serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        overflow-x: hidden;
        -webkit-text-size-adjust: 100%;
      }

      a, button {
        transition: all 0.15s ease;
      }

      a:hover, button:hover {
        opacity: 0.92;
      }

      button, input, select, textarea {
        font-family: inherit;
        -webkit-appearance: none;
      }

      img {
        max-width: 100%;
        display: block;
      }

      /* ========== Mobile App Shell ========== */
      .app-shell {
        max-width: 430px;
        width: 100%;
        margin: 0 auto;
        min-height: 100vh;
        min-height: 100dvh;
        background: #f5f5f5;
        position: relative;
      }

      /* Desktop: show phone-like frame */
      @media (min-width: 480px) {
        body {
          display: flex;
          align-items: flex-start;
          justify-content: center;
        }
        .app-shell {
          box-shadow: 0 0 40px rgba(0,0,0,0.12);
          border-left: 1px solid #d1d5db;
          border-right: 1px solid #d1d5db;
        }
      }

      /* Main content area with safe area padding */
      .app-content {
        padding-top: env(safe-area-inset-top);
        padding-bottom: calc(64px + env(safe-area-inset-bottom));
        min-height: 100vh;
        min-height: 100dvh;
        -webkit-overflow-scrolling: touch;
      }

      /* No bottom padding when nav is hidden (login page) */
      .app-content.no-nav {
        padding-bottom: 0;
      }



      /* ========== Bottom Navigation ========== */
      .bottom-nav {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        z-index: 100;
        background: white;
        border-top: 1px solid #e5e7eb;
        display: flex;
        justify-content: center;
        padding-bottom: env(safe-area-inset-bottom);
      }

      .bottom-nav-inner {
        max-width: 430px;
        width: 100%;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
      }

      .bottom-nav-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 10px 0 8px 0;
        text-decoration: none;
        color: #9ca3af;
        font-size: 11px;
        font-weight: 700;
        gap: 3px;
        position: relative;
        transition: color 0.15s ease;
        -webkit-touch-callout: none;
        user-select: none;
      }

      .bottom-nav-item.active {
        color: #2563eb;
      }

      .bottom-nav-item:hover {
        color: #2563eb;
        opacity: 1;
      }

      .bottom-nav-icon {
        font-size: 22px;
        line-height: 1;
      }

      .bottom-nav-badge {
        position: absolute;
        top: 4px;
        right: calc(50% - 20px);
        min-width: 16px;
        height: 16px;
        padding: 0 4px;
        border-radius: 999px;
        background: #ef4444;
        color: white;
        font-size: 10px;
        font-weight: 900;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      /* ========== Drawer Menu ========== */
      .drawer-overlay {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0,0,0,0.5);
        z-index: 200;
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s ease;
      }

      .drawer-overlay.open {
        opacity: 1;
        visibility: visible;
      }

      .drawer {
        position: fixed;
        top: 0; bottom: 0; left: -280px;
        width: 280px;
        background: white;
        z-index: 210;
        transition: left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 2px 0 10px rgba(0,0,0,0.1);
        display: flex;
        flex-direction: column;
        padding-top: env(safe-area-inset-top);
      }

      .drawer.open {
        left: 0;
      }

      .drawer-header {
        padding: 24px 20px 20px;
        border-bottom: 1px solid #e5e7eb;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .drawer-title {
        font-size: 20px;
        font-weight: 900;
        color: #2563eb;
      }

      .drawer-close {
        font-size: 24px;
        color: #9ca3af;
        cursor: pointer;
        padding: 4px;
        line-height: 1;
      }

      .drawer-menu {
        flex: 1;
        overflow-y: auto;
        padding: 12px 0;
        padding-bottom: env(safe-area-inset-bottom);
        -webkit-overflow-scrolling: touch;
      }

      .drawer-item-icon {
        font-size: 18px;
        margin-right: 10px;
        width: 24px;
        display: inline-block;
        text-align: center;
        flex-shrink: 0;
      }

      .drawer-item {
        display: flex;
        align-items: center;
        padding: 14px 20px;
        color: #374151;
        text-decoration: none;
        font-size: 16px;
        font-weight: 700;
        transition: background 0.2s;
      }

      .drawer-item:hover, .drawer-item:active {
        background: #f3f4f6;
        color: #111827;
      }

      .drawer-item-badge {
        margin-left: auto;
        font-size: 10px;
        font-weight: 800;
        color: #9ca3af;
        background: #f3f4f6;
        border-radius: 999px;
        padding: 2px 8px;
      }
      
      .drawer-divider {
        height: 1px;
        background: #e5e7eb;
        margin: 8px 20px;
      }

      /* ========== Touch optimizations ========== */
      input, select, textarea, button, a {
        touch-action: manipulation;
      }

      /* Minimum touch target 44px for iOS */
      .bottom-nav-item {
        min-height: 44px;
      }
    </style>
  </head>

  <body>
    <div class="app-shell">
      <div class="app-content<%= ' no-nav' unless logged_in? %>">
        <%= yield %>
      </div>
    </div>

    <% unread_count = Notification.where(status: "unread").count rescue 0 %>
    <% current_path = request.path %>

    <% if logged_in? %>
    <nav class="bottom-nav">
      <div class="bottom-nav-inner">
        <%= link_to projects_path, class: "bottom-nav-item #{current_path == '/' || (current_path.start_with?('/projects') && current_path != '/projects/calendar' && current_path != '/projects/new') ? 'active' : ''}" do %>
          <span class="bottom-nav-icon">🏠</span>
          <span>홈</span>
        <% end %>

        <%= link_to new_project_path, class: "bottom-nav-item #{current_path == '/projects/new' ? 'active' : ''}" do %>
          <span class="bottom-nav-icon">➕</span>
          <span>현장추가</span>
        <% end %>

        <%= link_to calendar_projects_path, class: "bottom-nav-item #{current_path == '/projects/calendar' ? 'active' : ''}" do %>
          <span class="bottom-nav-icon">📅</span>
          <span>캘린더</span>
        <% end %>
      </div>
    </nav>
    <% end %>

    <% if logged_in? %>
    <div class="drawer-overlay" id="drawerOverlay" onclick="closeDrawer()"></div>
    <div class="drawer" id="mainDrawer">
      <!-- Drawer Header -->
      <div class="drawer-header">
        <div>
          <div class="drawer-title">일머리</div>
          <% if logged_in? %>
            <div style="font-size:12px; color:#374151; font-weight:700; margin-top:4px;">
              <%= current_user.name %>
              <span style="font-size:10px; color:#fff; background:<%= current_user.premium? ? '#6366f1' : (current_user.standard_or_above? ? '#2563eb' : '#6b7280') %>; padding:2px 7px; border-radius:999px; margin-left:4px;">
                <%= current_user.plan_label %>
              </span>
            </div>
          <% else %>
            <div style="font-size:12px; color:#6b7280; font-weight:600; margin-top:2px;">인테리어 공정관리</div>
          <% end %>
        </div>
        <div class="drawer-close" onclick="closeDrawer()">✕</div>
      </div>

      <!-- Menu Items -->
      <div class="drawer-menu">

        <!-- 계정 / 구독 -->
        <% if logged_in? %>
          <%# 내 계정 — profile card %>
          <%= link_to my_account_path, onclick: "closeDrawer()",
              style: "display:flex; align-items:center; gap:12px; padding:14px 20px; text-decoration:none; border-bottom:1px solid #f3f4f6;" do %>
            <div style="width:42px; height:42px; border-radius:50%; background:#111827; display:flex; align-items:center; justify-content:center; font-size:18px; font-weight:900; color:white; flex-shrink:0;">
              <%= current_user.name.chars.first.upcase %>
            </div>
            <div style="flex:1;">
              <div style="font-size:15px; font-weight:900; color:#111827;"><%= current_user.name %></div>
              <div style="font-size:12px; color:#9ca3af; font-weight:600; margin-top:1px;"><%= current_user.email %></div>
            </div>
            <div style="font-size:16px; color:#d1d5db;">→</div>
          <% end %>
          <%= link_to subscription_path, class: "drawer-item", onclick: "closeDrawer()", style: "flex-direction:column; align-items:flex-start; gap:10px; padding-bottom:16px;" do %>
            <div style="display:flex; align-items:center; gap:8px; width:100%;">
              <span class="drawer-item-icon">💳</span>
              <span style="font-weight:900; color:#111827;">요금제 / 구독</span>
              <span style="margin-left:auto; font-size:11px; font-weight:800; background:linear-gradient(90deg,#6366f1,#818cf8); color:white; padding:3px 9px; border-radius:999px;">
                <%= current_user.plan_label %> 이용중
              </span>
            </div>
            <%# mini pricing table %>
            <div style="width:100%; display:grid; grid-template-columns:1fr 1fr 1fr; gap:6px;">
              <div style="background:<%= current_user.subscription_plan == 'free' ? '#111827' : '#f3f4f6' %>; border-radius:10px; padding:8px 6px; text-align:center;">
                <div style="font-size:11px; font-weight:800; color:<%= current_user.subscription_plan == 'free' ? 'white' : '#6b7280' %>;">FREE</div>
                <div style="font-size:12px; font-weight:900; color:<%= current_user.subscription_plan == 'free' ? 'white' : '#374151' %>; margin-top:2px;">₩0</div>
                <div style="font-size:10px; color:<%= current_user.subscription_plan == 'free' ? 'rgba(255,255,255,0.7)' : '#9ca3af' %>;">1개</div>
              </div>
              <div style="background:<%= current_user.subscription_plan == 'standard' ? '#2563eb' : '#f3f4f6' %>; border-radius:10px; padding:8px 6px; text-align:center;">
                <div style="font-size:11px; font-weight:800; color:<%= current_user.subscription_plan == 'standard' ? 'white' : '#6b7280' %>;">STANDARD</div>
                <div style="font-size:12px; font-weight:900; color:<%= current_user.subscription_plan == 'standard' ? 'white' : '#374151' %>; margin-top:2px;">₩4,900</div>
                <div style="font-size:10px; color:<%= current_user.subscription_plan == 'standard' ? 'rgba(255,255,255,0.7)' : '#9ca3af' %>;">3개</div>
              </div>
              <div style="background:<%= current_user.subscription_plan == 'premium' ? '#312e81' : '#f3f4f6' %>; border-radius:10px; padding:8px 6px; text-align:center;">
                <div style="font-size:11px; font-weight:800; color:<%= current_user.subscription_plan == 'premium' ? '#fde68a' : '#6b7280' %>;">PREMIUM</div>
                <div style="font-size:12px; font-weight:900; color:<%= current_user.subscription_plan == 'premium' ? 'white' : '#374151' %>; margin-top:2px;">₩9,900</div>
                <div style="font-size:10px; color:<%= current_user.subscription_plan == 'premium' ? 'rgba(255,255,255,0.7)' : '#9ca3af' %>;">10개</div>
              </div>
            </div>
          <% end %>
        <% else %>
          <%= link_to login_path, class: "drawer-item", onclick: "closeDrawer()" do %>
            <span class="drawer-item-icon">🔑</span> 로그인
          <% end %>
        <% end %>

        <div class="drawer-divider"></div>

        <!-- 관리 -->
        <%= link_to manage_projects_path, class: "drawer-item", onclick: "closeDrawer()" do %>
          <span class="drawer-item-icon">🏗️</span> 프로젝트 관리
        <% end %>
        <%= link_to process_templates_path, class: "drawer-item", onclick: "closeDrawer()" do %>
          <span class="drawer-item-icon">📋</span> 공정 템플릿 관리
        <% end %>
        <%= link_to vendors_path, class: "drawer-item", onclick: "closeDrawer()" do %>
          <span class="drawer-item-icon">🏢</span> 업체 관리
        <% end %>

        <div class="drawer-divider"></div>

        <!-- 설정 / 알림 -->
        <%= link_to notifications_path, class: "drawer-item", onclick: "closeDrawer()" do %>
          <span class="drawer-item-icon">🔔</span> 알림함
        <% end %>
        <%= link_to widget_settings_path, onclick: "closeDrawer()",
            style: "display:block; margin:2px 8px; text-decoration:none; border-radius:16px; overflow:hidden;" do %>
          <div style="background:linear-gradient(135deg, #1e1b4b 0%, #312e81 100%); padding:14px 16px;">
            <div style="display:flex; align-items:center; gap:8px; margin-bottom:8px;">
              <span style="font-size:18px;">📱</span>
              <span style="font-size:15px; font-weight:900; color:white;">위젯 설정</span>
              <span style="margin-left:auto; font-size:10px; font-weight:800; background:#fde68a; color:#78350f; padding:2px 8px; border-radius:999px;">PREMIUM</span>
            </div>
            <div style="font-size:12px; color:#c7d2fe; font-weight:600; line-height:1.6;">
              잠금화면에서 내일 공정을<br>
              바로 확인하세요 ⭐
            </div>
            <div style="margin-top:10px; font-size:11px; font-weight:800; color:#818cf8;">자세히 보기 →</div>
          </div>
        <% end %>
        <%= link_to app_settings_path, class: "drawer-item", onclick: "closeDrawer()" do %>
          <span class="drawer-item-icon">⚙️</span> 앱 설정
        <% end %>

        <div class="drawer-divider"></div>

        <!-- 고객지원 -->
        <%= link_to announcements_path, class: "drawer-item", onclick: "closeDrawer()" do %>
          <span class="drawer-item-icon">📢</span> 공지사항 / 문의
        <% end %>
        <a href="#" class="drawer-item" style="font-size:13px; color:#9ca3af;">
          <span class="drawer-item-icon">📄</span> 이용약관 / 개인정보처리방침
        </a>

        <div class="drawer-divider"></div>
        <% if logged_in? %>
          <%= button_to logout_path, method: :delete, class: "drawer-item", style: "color:#ef4444; background:none; border:none; width:100%; text-align:left; cursor:pointer; font-family:inherit;" do %>
            <span class="drawer-item-icon">🚪</span> 로그아웃
          <% end %>
        <% end %>
        <div style="padding:10px 20px; font-size:12px; color:#9ca3af; font-weight:500; text-align:center;">
          일머리 v1.0 · © 2026
        </div>

      </div>
    </div>
    <% end %>

    <script>
      function openDrawer() {
        document.getElementById('mainDrawer').classList.add('open');
        document.getElementById('drawerOverlay').classList.add('open');
        document.body.style.overflow = 'hidden';
      }

      function closeDrawer() {
        document.getElementById('mainDrawer').classList.remove('open');
        document.getElementById('drawerOverlay').classList.remove('open');
        document.body.style.overflow = '';
      }
    </script>
  </body>
</html>