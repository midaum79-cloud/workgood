<!DOCTYPE html>
<html lang="ko">
  <head>
    <title>일머리</title>
    <meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no,viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="일머리">
    <meta name="theme-color" content="#ffffff">
    <meta name="format-detection" content="telephone=no">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="manifest" href="/manifest.json">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png">
    <link rel="icon" type="image/png" sizes="512x512" href="/icon-512.png">
    <link rel="apple-touch-startup-image" href="/splash.png">

    <link rel="stylesheet" as="style" crossorigin href="https://cdn.jsdelivr.net/npm/pretendard/dist/web/static/pretendard.css" />

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <style>
      * {
        box-sizing: border-box;
        -webkit-tap-highlight-color: transparent;
      }

      html {
        min-height: 100%;
        overscroll-behavior: none;
        overscroll-behavior-y: none;
      }

      body {
        margin: 0;
        padding: 0;
        min-height: 100%;
        background: #e8eaed;
        color: #111827;
        font-family: "Pretendard", -apple-system, BlinkMacSystemFont, "Apple SD Gothic Neo", "Noto Sans KR", "Malgun Gothic", sans-serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        overflow-x: hidden;
        overscroll-behavior: none;
        overscroll-behavior-y: none;
        -webkit-overflow-scrolling: auto;
        -webkit-text-size-adjust: 100%;
        touch-action: manipulation;
      }

      /* Force 16px input fonts on mobile to prevent Safari auto-zoom which breaks layouts */
      @media screen and (max-width: 768px) {
        input, select, textarea {
          font-size: 16px !important;
        }
      }

      a, button {
        transition: all 0.15s ease;
      }

      a:hover, button:hover {
        opacity: 0.92;
      }

      button, input, select, textarea {
        font-family: inherit;
        -webkit-appearance: none;
      }

      img {
        max-width: 100%;
        display: block;
      }

      /* ========== Mobile App Shell ========== */
      .app-shell {
        width: 100%;
        margin: 0 auto;
        min-height: 100vh;
        min-height: 100dvh;
        background: #f5f5f5;
        position: relative;
      }

      /* Desktop: show phone-like frame */
      @media (min-width: 480px) {
        body {
          display: flex;
          align-items: flex-start;
          justify-content: center;
        }
        .app-shell {
          max-width: 430px;
          box-shadow: 0 0 40px rgba(0,0,0,0.12);
          border-left: 1px solid #d1d5db;
          border-right: 1px solid #d1d5db;
        }
      }

      /* Main content area with safe area padding */
      .app-content {
        padding-bottom: calc(64px + env(safe-area-inset-bottom));
        min-height: 100vh;
        min-height: 100dvh;
        -webkit-overflow-scrolling: touch;
      }

      /* ========== Sticky header safe area ========== */
      /* Applied automatically by JS below to all sticky top-0 headers */
      .safe-sticky-header {
        padding-top: max(env(safe-area-inset-top), 14px) !important;
        top: 0 !important;
      }

      /* No bottom padding when nav is hidden (login page) */
      .app-content.no-nav {
        padding-bottom: 0;
      }



      /* ========== Bottom Navigation ========== */
      .bottom-nav {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        z-index: 100;
        background: white;
        border-top: 1px solid #e5e7eb;
        display: flex;
        justify-content: center;
        padding-bottom: env(safe-area-inset-bottom);
      }

      .bottom-nav-inner {
        width: 100%;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
      }

      @media (min-width: 480px) {
        .bottom-nav-inner {
          max-width: 430px;
        }
      }

      .bottom-nav-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 10px 0 8px 0;
        text-decoration: none;
        color: #9ca3af;
        font-size: 11px;
        font-weight: 700;
        gap: 3px;
        position: relative;
        transition: color 0.15s ease;
        -webkit-touch-callout: none;
        user-select: none;
      }

      .bottom-nav-item.active {
        color: #2563eb;
      }

      .bottom-nav-item:hover {
        color: #2563eb;
        opacity: 1;
      }

      .bottom-nav-icon {
        font-size: 22px;
        line-height: 1;
      }

      .bottom-nav-badge {
        position: absolute;
        top: 4px;
        right: calc(50% - 20px);
        min-width: 16px;
        height: 16px;
        padding: 0 4px;
        border-radius: 999px;
        background: #ef4444;
        color: white;
        font-size: 10px;
        font-weight: 900;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      /* ========== Drawer Menu ========== */
      .drawer-overlay {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0,0,0,0.5);
        z-index: 200;
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s ease;
      }

      .drawer-overlay.open {
        opacity: 1;
        visibility: visible;
      }

      .drawer {
        position: fixed;
        top: 0; bottom: 0; left: -280px;
        width: 280px;
        background: white;
        z-index: 210;
        transition: left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 2px 0 10px rgba(0,0,0,0.1);
        display: flex;
        flex-direction: column;
        padding-top: env(safe-area-inset-top);
      }

      .drawer.open {
        left: 0;
      }

      .drawer-header {
        padding: 24px 20px 20px;
        border-bottom: 1px solid #e5e7eb;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .drawer-title {
        font-size: 20px;
        font-weight: 900;
        color: #2563eb;
      }

      .drawer-close {
        font-size: 24px;
        color: #9ca3af;
        cursor: pointer;
        padding: 4px;
        line-height: 1;
      }

      .drawer-menu {
        flex: 1;
        overflow-y: auto;
        padding: 12px 0;
        padding-bottom: env(safe-area-inset-bottom);
        -webkit-overflow-scrolling: touch;
      }

      .drawer-item-icon {
        font-size: 18px;
        margin-right: 10px;
        width: 24px;
        display: inline-block;
        text-align: center;
        flex-shrink: 0;
      }

      .drawer-item {
        display: flex;
        align-items: center;
        padding: 14px 20px;
        color: #374151;
        text-decoration: none;
        font-size: 16px;
        font-weight: 700;
        transition: background 0.2s;
      }

      .drawer-item:hover, .drawer-item:active {
        background: #f3f4f6;
        color: #111827;
      }

      .drawer-item-badge {
        margin-left: auto;
        font-size: 10px;
        font-weight: 800;
        color: #9ca3af;
        background: #f3f4f6;
        border-radius: 999px;
        padding: 2px 8px;
      }
      
      .drawer-divider {
        height: 1px;
        background: #e5e7eb;
        margin: 8px 20px;
      }

      /* ========== Touch optimizations ========== */
      input, select, textarea, button, a {
        touch-action: manipulation;
      }

      /* Minimum touch target 44px for iOS */
      .bottom-nav-item {
        min-height: 44px;
      }

      /* Hide custom splash screen when running as standalone PWA to prevent double splash */
      @media (display-mode: standalone) {
        #app-splash {
          display: none !important;
        }
      }
    </style>
  </head>

  <body>
    <!-- ===== SPLASH SCREEN ===== -->
    <div id="app-splash" style="
      position:fixed; inset:0; z-index:9999;
      background:#ffffff;
      display:flex; flex-direction:column;
      align-items:center; justify-content:center;
      transition:opacity 0.4s ease;
    ">
      <img src="/icon-512.png" alt="일머리" style="
        width:30vw; max-width:160px; min-width:80px;
        border-radius:22%;
        box-shadow:0 8px 30px rgba(0,0,0,0.12);
      ">
      <div style="
        margin-top:20px; font-size:22px; font-weight:900;
        color:#111827; letter-spacing:-0.5px;
        font-family: 'Pretendard', -apple-system, sans-serif;
      ">일머리</div>
      <div style="
        margin-top:6px; font-size:13px; font-weight:600;
        color:#9ca3af;
        font-family: 'Pretendard', -apple-system, sans-serif;
      ">인테리어 공정관리</div>
    </div>
    <script>
      (function() {
        var splash = document.getElementById('app-splash');
        // Show splash only once per session
        if (sessionStorage.getItem('splashShown')) {
          splash.style.display = 'none';
          return;
        }
        sessionStorage.setItem('splashShown', '1');
        // Fade out after 1.2s
        setTimeout(function() {
          splash.style.opacity = '0';
          setTimeout(function() { splash.style.display = 'none'; }, 420);
        }, 1200);
      })();
    </script>
    <!-- ===== END SPLASH SCREEN ===== -->

    <!-- ===== SAFE AREA: auto-fix sticky headers ===== -->
    <script>
      function applySafeStickyHeader() {
        // Find all elements that are position:sticky and at top:0
        document.querySelectorAll('[style]').forEach(function(el) {
          var s = el.getAttribute('style') || '';
          var isSticky = s.includes('position:sticky') || s.includes('position: sticky');
          var isTop0   = s.includes('top:0') || s.includes('top: 0');
          if (isSticky && isTop0 && !el.classList.contains('safe-sticky-header')) {
            el.classList.add('safe-sticky-header');
          }
        });
      }
      document.addEventListener('DOMContentLoaded', applySafeStickyHeader);
      document.addEventListener('turbo:load', applySafeStickyHeader);
      document.addEventListener('turbo:render', applySafeStickyHeader);
    </script>
    <!-- ===== END SAFE AREA ===== -->

    <div class="app-shell">
      <div class="app-content<%= ' no-nav' unless logged_in? %>">
        <% if flash[:notice] %>
          <div id="flash-notice" class="flash-toast" style="position:fixed; top:env(safe-area-inset-top, 0); left:50%; transform:translateX(-50%); z-index:9999; max-width:430px; width:100%; padding:0 16px; box-sizing:border-box; pointer-events:none; animation:flashIn 0.3s ease-out;">
            <div style="background:#22c55e; color:white; padding:14px 18px; border-radius:14px; font-size:15px; font-weight:800; margin-top:8px; box-shadow:0 4px 16px rgba(0,0,0,0.15); pointer-events:auto;" onclick="this.parentElement.remove()">
              <%= flash[:notice] %>
            </div>
          </div>
        <% end %>
        <% if flash[:alert] %>
          <div id="flash-alert" class="flash-toast" style="position:fixed; top:env(safe-area-inset-top, 0); left:50%; transform:translateX(-50%); z-index:9999; max-width:430px; width:100%; padding:0 16px; box-sizing:border-box; pointer-events:none; animation:flashIn 0.3s ease-out;">
            <div style="background:#ef4444; color:white; padding:14px 18px; border-radius:14px; font-size:15px; font-weight:800; margin-top:8px; box-shadow:0 4px 16px rgba(0,0,0,0.15); pointer-events:auto;" onclick="this.parentElement.remove()">
              <%= flash[:alert] %>
            </div>
          </div>
        <% end %>
        <style>
          @keyframes flashIn { from { opacity:0; transform:translateX(-50%) translateY(-20px); } to { opacity:1; transform:translateX(-50%) translateY(0); } }
          @keyframes flashOut { from { opacity:1; transform:translateX(-50%) translateY(0); } to { opacity:0; transform:translateX(-50%) translateY(-20px); } }
        </style>
        <script>
          document.querySelectorAll('.flash-toast').forEach(function(el) {
            setTimeout(function() {
              el.style.animation = 'flashOut 0.3s ease-in forwards';
              setTimeout(function() { el.remove(); }, 300);
            }, 2000);
          });
        </script>
        <%= yield %>
      </div>
    </div>

    <% unread_count = Notification.where(status: "unread").count rescue 0 %>
    <% current_path = request.path %>

    <% if logged_in? %>
    <nav class="bottom-nav">
      <div class="bottom-nav-inner">
        <%= link_to projects_path, class: "bottom-nav-item #{current_path == '/' || (current_path.start_with?('/projects') && current_path != '/projects/calendar' && current_path != '/projects/new') ? 'active' : ''}" do %>
          <span class="bottom-nav-icon">🏠</span>
          <span>홈</span>
        <% end %>

        <% project_show_match = current_path.match(/\A\/projects\/(\d+)(\/calendar)?\z/) %>
        <% if current_path == '/projects/calendar' %>
          <div class="bottom-nav-item" onclick="document.getElementById('ongoing-processes-modal').style.display='flex'" style="cursor:pointer;">
            <span class="bottom-nav-icon">➕</span>
            <span>공정 추가</span>
          </div>
        <% elsif project_show_match %>
          <%= link_to new_work_process_path(project_id: project_show_match[1]), class: "bottom-nav-item" do %>
            <span class="bottom-nav-icon">➕</span>
            <span>공정 추가</span>
          <% end %>
        <% else %>
          <%= link_to new_project_path, class: "bottom-nav-item #{current_path == '/projects/new' ? 'active' : ''}" do %>
            <span class="bottom-nav-icon">➕</span>
            <span>현장추가</span>
          <% end %>
        <% end %>

        <%= link_to calendar_projects_path, class: "bottom-nav-item #{current_path == '/projects/calendar' ? 'active' : ''}" do %>
          <span class="bottom-nav-icon">📅</span>
          <span>캘린더</span>
        <% end %>
      </div>
    </nav>
    <% end %>

    <% if logged_in? %>
    <div class="drawer-overlay" id="drawerOverlay" onclick="closeDrawer()"></div>
    <div class="drawer" id="mainDrawer">
      <!-- Drawer Header -->
      <div class="drawer-header">
        <div>
          <div class="drawer-title">일머리</div>
          <% if logged_in? %>
            <div style="font-size:12px; color:#374151; font-weight:700; margin-top:4px;">
              <%= current_user.name %>
              <span style="font-size:10px; color:#fff; background:<%= current_user.premium? ? '#6366f1' : (current_user.standard_or_above? ? '#2563eb' : '#6b7280') %>; padding:2px 7px; border-radius:999px; margin-left:4px;">
                <%= current_user.plan_label %>
              </span>
            </div>
          <% else %>
            <div style="font-size:12px; color:#6b7280; font-weight:600; margin-top:2px;">인테리어 공정관리</div>
          <% end %>
        </div>
        <div class="drawer-close" onclick="closeDrawer()">✕</div>
      </div>

      <!-- Menu Items -->
      <div class="drawer-menu">

        <!-- 계정 / 구독 -->
        <% if logged_in? %>
          <%# 내 계정 — profile card %>
          <%= link_to my_account_path, onclick: "closeDrawer()",
              style: "display:flex; align-items:center; gap:12px; padding:14px 20px; text-decoration:none; border-bottom:1px solid #f3f4f6;" do %>
            <div style="width:42px; height:42px; border-radius:50%; background:#111827; display:flex; align-items:center; justify-content:center; font-size:18px; font-weight:900; color:white; flex-shrink:0;">
              <%= current_user.name.chars.first.upcase %>
            </div>
            <div style="flex:1;">
              <div style="font-size:15px; font-weight:900; color:#111827;"><%= current_user.name %></div>
              <div style="font-size:12px; color:#9ca3af; font-weight:600; margin-top:1px;"><%= current_user.email %></div>
            </div>
            <div style="font-size:16px; color:#d1d5db;">→</div>
          <% end %>
          <%= link_to subscription_path, class: "drawer-item", onclick: "closeDrawer()", style: "flex-direction:column; align-items:flex-start; gap:10px; padding-bottom:16px;" do %>
            <div style="display:flex; align-items:center; gap:8px; width:100%;">
              <span class="drawer-item-icon">💳</span>
              <span style="font-weight:900; color:#111827;">요금제 / 구독</span>
              <span style="margin-left:auto; font-size:11px; font-weight:800; background:linear-gradient(90deg,#6366f1,#818cf8); color:white; padding:3px 9px; border-radius:999px;">
                <%= current_user.plan_label %> 이용중
              </span>
            </div>
            <%# mini pricing table %>
            <div style="width:100%; display:grid; grid-template-columns:1fr 1fr 1fr; gap:6px;">
              <div style="background:<%= current_user.subscription_plan == 'free' ? '#111827' : '#f3f4f6' %>; border-radius:10px; padding:8px 6px; text-align:center;">
                <div style="font-size:11px; font-weight:800; color:<%= current_user.subscription_plan == 'free' ? 'white' : '#6b7280' %>;">FREE</div>
                <div style="font-size:12px; font-weight:900; color:<%= current_user.subscription_plan == 'free' ? 'white' : '#374151' %>; margin-top:2px;">₩0</div>
                <div style="font-size:10px; color:<%= current_user.subscription_plan == 'free' ? 'rgba(255,255,255,0.7)' : '#9ca3af' %>;">1개</div>
              </div>
              <div style="background:<%= current_user.subscription_plan == 'standard' ? '#2563eb' : '#f3f4f6' %>; border-radius:10px; padding:8px 6px; text-align:center;">
                <div style="font-size:11px; font-weight:800; color:<%= current_user.subscription_plan == 'standard' ? 'white' : '#6b7280' %>;">STANDARD</div>
                <div style="font-size:12px; font-weight:900; color:<%= current_user.subscription_plan == 'standard' ? 'white' : '#374151' %>; margin-top:2px;">₩4,900</div>
                <div style="font-size:10px; color:<%= current_user.subscription_plan == 'standard' ? 'rgba(255,255,255,0.7)' : '#9ca3af' %>;">3개</div>
              </div>
              <div style="background:<%= current_user.subscription_plan == 'premium' ? '#312e81' : '#f3f4f6' %>; border-radius:10px; padding:8px 6px; text-align:center;">
                <div style="font-size:11px; font-weight:800; color:<%= current_user.subscription_plan == 'premium' ? '#fde68a' : '#6b7280' %>;">PREMIUM</div>
                <div style="font-size:12px; font-weight:900; color:<%= current_user.subscription_plan == 'premium' ? 'white' : '#374151' %>; margin-top:2px;">₩9,900</div>
                <div style="font-size:10px; color:<%= current_user.subscription_plan == 'premium' ? 'rgba(255,255,255,0.7)' : '#9ca3af' %>;">무제한</div>
              </div>
            </div>
          <% end %>
        <% else %>
          <%= link_to login_path, class: "drawer-item", onclick: "closeDrawer()" do %>
            <span class="drawer-item-icon">🔑</span> 로그인
          <% end %>
        <% end %>

        <!-- 사용 방법 안내 -->
        <%= link_to pages_guide_path, class: "drawer-item", onclick: "closeDrawer()", style: "background:#eff6ff;" do %>
          <span class="drawer-item-icon">📘</span> 일머리 사용 설명서 <span style="margin-left:auto; font-size:10px; font-weight:800; background:#dbeafe; color:#1d4ed8; padding:2px 8px; border-radius:999px;">NEW</span>
        <% end %>

        <div class="drawer-divider"></div>

        <!-- 관리 -->
        <%= link_to manage_projects_path, class: "drawer-item", onclick: "closeDrawer()" do %>
          <span class="drawer-item-icon">🏗️</span> 현장관리
        <% end %>
        <%= link_to archive_projects_path, class: "drawer-item", onclick: "closeDrawer()" do %>
          <span class="drawer-item-icon">📁</span> 완료 현장 아카이브
        <% end %>
        <%= link_to process_templates_path, class: "drawer-item", onclick: "closeDrawer()" do %>
          <span class="drawer-item-icon">📋</span> 공정 템플릿 관리
        <% end %>
        <%= link_to vendors_path, class: "drawer-item", onclick: "closeDrawer()" do %>
          <span class="drawer-item-icon">🏢</span> 업체 관리
        <% end %>

        <div class="drawer-divider"></div>

        <!-- 설정 / 알림 -->
        <%= link_to notifications_path, class: "drawer-item", onclick: "closeDrawer()" do %>
          <span class="drawer-item-icon">🔔</span> 알림함
        <% end %>
        <%= link_to widget_settings_path, onclick: "closeDrawer()",
            style: "display:block; margin:2px 8px; text-decoration:none; border-radius:16px; overflow:hidden;" do %>
          <div style="background:linear-gradient(135deg, #1e1b4b 0%, #312e81 100%); padding:14px 16px;">
            <div style="display:flex; align-items:center; gap:8px; margin-bottom:8px;">
              <span style="font-size:18px;">📱</span>
              <span style="font-size:15px; font-weight:900; color:white;">위젯 설정</span>
              <span style="margin-left:auto; font-size:10px; font-weight:800; background:#fde68a; color:#78350f; padding:2px 8px; border-radius:999px;">PREMIUM</span>
            </div>
            <div style="font-size:12px; color:#c7d2fe; font-weight:600; line-height:1.6;">
              잠금화면에서 내일 공정을<br>
              바로 확인하세요 ⭐
            </div>
            <div style="margin-top:10px; font-size:11px; font-weight:800; color:#818cf8;">자세히 보기 →</div>
          </div>
        <% end %>
        <%= link_to app_settings_path, class: "drawer-item", onclick: "closeDrawer()" do %>
          <span class="drawer-item-icon">⚙️</span> 앱 설정
        <% end %>

        <div class="drawer-divider"></div>

        <!-- 고객지원 -->
        <%= link_to guide_path, class: "drawer-item", onclick: "closeDrawer()" do %>
          <span class="drawer-item-icon">📖</span> 일머리 사용설명서
        <% end %>
        <%= link_to announcements_path, class: "drawer-item", onclick: "closeDrawer()" do %>
          <span class="drawer-item-icon">📢</span> 공지사항 / 문의
        <% end %>
        <%= link_to terms_path, class: "drawer-item", onclick: "closeDrawer()", style: "font-size:13px; color:#9ca3af;" do %>
          <span class="drawer-item-icon">📄</span> 이용약관
        <% end %>
        <%= link_to privacy_path, class: "drawer-item", onclick: "closeDrawer()", style: "font-size:13px; color:#9ca3af;" do %>
          <span class="drawer-item-icon">🔒</span> 개인정보처리방침
        <% end %>

        <div class="drawer-divider"></div>
        <% if logged_in? %>
          <%= button_to logout_path, method: :delete, class: "drawer-item", style: "color:#ef4444; background:none; border:none; width:100%; text-align:left; cursor:pointer; font-family:inherit;" do %>
            <span class="drawer-item-icon">🚪</span> 로그아웃
          <% end %>
        <% end %>
        <div style="padding:10px 20px; font-size:12px; color:#9ca3af; font-weight:500; text-align:center;">
          일머리 v1.0 · © 2026
        </div>

      </div>
    </div>
    <% end %>

    <script>
      function openDrawer() {
        document.getElementById('mainDrawer').classList.add('open');
        document.getElementById('drawerOverlay').classList.add('open');
        document.body.style.overflow = 'hidden';
      }

      function closeDrawer() {
        document.getElementById('mainDrawer').classList.remove('open');
        document.getElementById('drawerOverlay').classList.remove('open');
        document.body.style.overflow = '';
      }
    </script>

    <% if logged_in? && VAPID_PUBLIC_KEY.present? %>
    <script>
      // Web Push Subscription
      (function() {
        if (!('serviceWorker' in navigator) || !('PushManager' in window)) return;

        var VAPID_PUBLIC_KEY = '<%= VAPID_PUBLIC_KEY %>';

        function urlBase64ToUint8Array(base64String) {
          var padding = '='.repeat((4 - base64String.length % 4) % 4);
          var base64 = (base64String + padding).replace(/-/g, '+').replace(/_/g, '/');
          var rawData = atob(base64);
          var outputArray = new Uint8Array(rawData.length);
          for (var i = 0; i < rawData.length; ++i) outputArray[i] = rawData.charCodeAt(i);
          return outputArray;
        }

        navigator.serviceWorker.ready.then(function(registration) {
          // Check if already subscribed
          registration.pushManager.getSubscription().then(function(existingSub) {
            if (existingSub) {
              // Already subscribed, sync with server
              sendSubToServer(existingSub);
              return;
            }

            // First visit or permission not granted — ask after 3 seconds
            if (Notification.permission === 'default') {
              setTimeout(function() {
                Notification.requestPermission().then(function(permission) {
                  if (permission === 'granted') subscribePush(registration);
                });
              }, 3000);
            } else if (Notification.permission === 'granted') {
              subscribePush(registration);
            }
          });
        });

        function subscribePush(registration) {
          registration.pushManager.subscribe({
            userVisibleOnly: true,
            applicationServerKey: urlBase64ToUint8Array(VAPID_PUBLIC_KEY)
          }).then(function(subscription) {
            sendSubToServer(subscription);
          }).catch(function(err) {
            console.error('[WebPush] Subscribe failed:', err);
          });
        }

        function sendSubToServer(subscription) {
          var subJSON = subscription.toJSON();
          var csrfToken = document.querySelector('meta[name="csrf-token"]').content;

          fetch('/web_push_subscriptions', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
            body: JSON.stringify({
              subscription: {
                endpoint: subJSON.endpoint,
                keys: { p256dh: subJSON.keys.p256dh, auth: subJSON.keys.auth }
              }
            })
          }).then(function(res) {
            if (res.ok) console.log('[WebPush] Subscription synced');
          }).catch(function(err) {
            console.error('[WebPush] Sync failed:', err);
          });
        }
      })();
    </script>
    <% end %>
  </body>
</html>