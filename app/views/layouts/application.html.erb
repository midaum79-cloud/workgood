<!DOCTYPE html>
<html lang="ko">
  <head>
    <title>일머리</title>
    <meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no,viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="일머리">
    <meta name="theme-color" content="#ffffff">
    <meta name="format-detection" content="telephone=no">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="manifest" href="/manifest.json">
    <link rel="apple-touch-icon" href="/icon-192.png">
    <link rel="icon" href="/icon-192.png">

    <link rel="stylesheet" as="style" crossorigin href="https://cdn.jsdelivr.net/npm/pretendard/dist/web/static/pretendard.css" />

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <style>
      * {
        box-sizing: border-box;
        -webkit-tap-highlight-color: transparent;
      }

      html {
        height: 100%;
      }

      body {
        margin: 0;
        padding: 0;
        height: 100%;
        background: #e8eaed;
        color: #111827;
        font-family: "Pretendard", -apple-system, BlinkMacSystemFont, "Apple SD Gothic Neo", "Noto Sans KR", "Malgun Gothic", sans-serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        overflow-x: hidden;
        -webkit-text-size-adjust: 100%;
      }

      a, button {
        transition: all 0.15s ease;
      }

      a:hover, button:hover {
        opacity: 0.92;
      }

      button, input, select, textarea {
        font-family: inherit;
        -webkit-appearance: none;
      }

      img {
        max-width: 100%;
        display: block;
      }

      /* ========== Mobile App Shell ========== */
      .app-shell {
        max-width: 430px;
        width: 100%;
        margin: 0 auto;
        min-height: 100vh;
        min-height: 100dvh;
        background: #f5f5f5;
        position: relative;
      }

      /* Desktop: show phone-like frame */
      @media (min-width: 480px) {
        body {
          display: flex;
          align-items: flex-start;
          justify-content: center;
        }
        .app-shell {
          box-shadow: 0 0 40px rgba(0,0,0,0.12);
          border-left: 1px solid #d1d5db;
          border-right: 1px solid #d1d5db;
        }
      }

      /* Main content area with safe area padding */
      .app-content {
        padding-top: env(safe-area-inset-top);
        padding-bottom: calc(64px + env(safe-area-inset-bottom));
        min-height: 100vh;
        min-height: 100dvh;
        -webkit-overflow-scrolling: touch;
      }

      /* ========== Bottom Navigation ========== */
      .bottom-nav {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        z-index: 100;
        background: white;
        border-top: 1px solid #e5e7eb;
        display: flex;
        justify-content: center;
        padding-bottom: env(safe-area-inset-bottom);
      }

      .bottom-nav-inner {
        max-width: 430px;
        width: 100%;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
      }

      .bottom-nav-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 10px 0 8px 0;
        text-decoration: none;
        color: #9ca3af;
        font-size: 11px;
        font-weight: 700;
        gap: 3px;
        position: relative;
        transition: color 0.15s ease;
        -webkit-touch-callout: none;
        user-select: none;
      }

      .bottom-nav-item.active {
        color: #2563eb;
      }

      .bottom-nav-item:hover {
        color: #2563eb;
        opacity: 1;
      }

      .bottom-nav-icon {
        font-size: 22px;
        line-height: 1;
      }

      .bottom-nav-badge {
        position: absolute;
        top: 4px;
        right: calc(50% - 20px);
        min-width: 16px;
        height: 16px;
        padding: 0 4px;
        border-radius: 999px;
        background: #ef4444;
        color: white;
        font-size: 10px;
        font-weight: 900;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      /* ========== Drawer Menu ========== */
      .drawer-overlay {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0,0,0,0.5);
        z-index: 200;
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s ease;
      }

      .drawer-overlay.open {
        opacity: 1;
        visibility: visible;
      }

      .drawer {
        position: fixed;
        top: 0; bottom: 0; left: -280px;
        width: 280px;
        background: white;
        z-index: 210;
        transition: left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 2px 0 10px rgba(0,0,0,0.1);
        display: flex;
        flex-direction: column;
        padding-top: env(safe-area-inset-top);
      }

      .drawer.open {
        left: 0;
      }

      .drawer-header {
        padding: 24px 20px 20px;
        border-bottom: 1px solid #e5e7eb;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .drawer-title {
        font-size: 20px;
        font-weight: 900;
        color: #2563eb;
      }

      .drawer-close {
        font-size: 24px;
        color: #9ca3af;
        cursor: pointer;
        padding: 4px;
        line-height: 1;
      }

      .drawer-menu {
        flex: 1;
        overflow-y: auto;
        padding: 12px 0;
        padding-bottom: env(safe-area-inset-bottom);
        -webkit-overflow-scrolling: touch;
      }

      .drawer-item-icon {
        font-size: 18px;
        margin-right: 10px;
        width: 24px;
        display: inline-block;
        text-align: center;
        flex-shrink: 0;
      }

      .drawer-item {
        display: flex;
        align-items: center;
        padding: 14px 20px;
        color: #374151;
        text-decoration: none;
        font-size: 16px;
        font-weight: 700;
        transition: background 0.2s;
      }

      .drawer-item:hover, .drawer-item:active {
        background: #f3f4f6;
        color: #111827;
      }

      .drawer-item-badge {
        margin-left: auto;
        font-size: 10px;
        font-weight: 800;
        color: #9ca3af;
        background: #f3f4f6;
        border-radius: 999px;
        padding: 2px 8px;
      }
      
      .drawer-divider {
        height: 1px;
        background: #e5e7eb;
        margin: 8px 20px;
      }

      /* ========== Touch optimizations ========== */
      input, select, textarea, button, a {
        touch-action: manipulation;
      }

      /* Minimum touch target 44px for iOS */
      .bottom-nav-item {
        min-height: 44px;
      }
    </style>
  </head>

  <body>
    <div class="app-shell">
      <div class="app-content">
        <%= yield %>
      </div>
    </div>

    <% unread_count = Notification.where(status: "unread").count rescue 0 %>
    <% current_path = request.path %>

    <nav class="bottom-nav">
      <div class="bottom-nav-inner">
        <%= link_to projects_path, class: "bottom-nav-item #{current_path == '/' || (current_path.start_with?('/projects') && current_path != '/projects/calendar' && current_path != '/projects/new') ? 'active' : ''}" do %>
          <span class="bottom-nav-icon">🏠</span>
          <span>홈</span>
        <% end %>

        <%= link_to new_project_path, class: "bottom-nav-item #{current_path == '/projects/new' ? 'active' : ''}" do %>
          <span class="bottom-nav-icon">➕</span>
          <span>현장추가</span>
        <% end %>

        <%= link_to calendar_projects_path, class: "bottom-nav-item #{current_path == '/projects/calendar' ? 'active' : ''}" do %>
          <span class="bottom-nav-icon">📅</span>
          <span>캘린더</span>
        <% end %>
      </div>
    </nav>

    <div class="drawer-overlay" id="drawerOverlay" onclick="closeDrawer()"></div>
    <div class="drawer" id="mainDrawer">
      <!-- Drawer Header -->
      <div class="drawer-header">
        <div>
          <div class="drawer-title">일머리</div>
          <div style="font-size:12px; color:#6b7280; font-weight:600; margin-top:2px;">인테리어 공정관리</div>
        </div>
        <div class="drawer-close" onclick="closeDrawer()">✕</div>
      </div>

      <!-- Menu Items -->
      <div class="drawer-menu">

        <!-- 계정 / 구독 -->
        <a href="#" class="drawer-item">
          <span class="drawer-item-icon">👤</span> 내 계정
          <span class="drawer-item-badge">준비중</span>
        </a>
        <a href="#" class="drawer-item">
          <span class="drawer-item-icon">💳</span> 요금제 / 결제
          <span class="drawer-item-badge">준비중</span>
        </a>

        <div class="drawer-divider"></div>

        <!-- 관리 -->
        <%= link_to projects_path, class: "drawer-item", onclick: "closeDrawer()" do %>
          <span class="drawer-item-icon">🏗️</span> 프로젝트 관리
        <% end %>
        <a href="#" class="drawer-item">
          <span class="drawer-item-icon">📋</span> 공정 템플릿 관리
          <span class="drawer-item-badge">준비중</span>
        </a>
        <a href="#" class="drawer-item">
          <span class="drawer-item-icon">🏢</span> 업체 관리
          <span class="drawer-item-badge">준비중</span>
        </a>

        <div class="drawer-divider"></div>

        <!-- 설정 / 알림 -->
        <%= link_to notifications_path, class: "drawer-item" do %>
          <span class="drawer-item-icon">🔔</span> 알림함
        <% end %>
        <a href="#" class="drawer-item">
          <span class="drawer-item-icon">⚙️</span> 앱 설정
          <span class="drawer-item-badge">준비중</span>
        </a>

        <div class="drawer-divider"></div>

        <!-- 고객지원 -->
        <a href="#" class="drawer-item">
          <span class="drawer-item-icon">📢</span> 공지사항 / 문의
          <span class="drawer-item-badge">준비중</span>
        </a>
        <a href="#" class="drawer-item" style="font-size:13px; color:#9ca3af;">
          <span class="drawer-item-icon">📄</span> 이용약관 / 개인정보처리방침
        </a>

        <div class="drawer-divider"></div>
        <div style="padding:10px 20px; font-size:12px; color:#9ca3af; font-weight:500; text-align:center;">
          일머리 v1.0 · © 2026
        </div>

      </div>
    </div>

    <script>
      function openDrawer() {
        document.getElementById('mainDrawer').classList.add('open');
        document.getElementById('drawerOverlay').classList.add('open');
        document.body.style.overflow = 'hidden';
      }

      function closeDrawer() {
        document.getElementById('mainDrawer').classList.remove('open');
        document.getElementById('drawerOverlay').classList.remove('open');
        document.body.style.overflow = '';
      }
    </script>
  </body>
</html>