<div style="max-width:430px; margin:0 auto; min-height:100vh; background:#f5f5f5;">

  <%# Header %>
  <div style="background:white; padding:18px 20px 14px 20px; border-bottom:1px solid #ececec; position:sticky; top:0; z-index:30; margin-bottom:16px;">
    <div style="display:flex; justify-content:space-between; align-items:center;">
      <div style="font-size:24px; color:#111827; font-weight:900; cursor:pointer;" onclick="openDrawer()">☰</div>
      <div style="font-size:20px; font-weight:900;">앱 설정</div>
      <div style="width:40px;"></div>
    </div>
  </div>



  <div style="padding:0 16px 100px 16px; display:flex; flex-direction:column; gap:16px;">

    <%# ── 1. 내 프로필 ── %>
    <div style="background:white; border-radius:20px; overflow:hidden;">
      <div style="padding:16px 18px; border-bottom:1px solid #f3f4f6; display:flex; align-items:center; gap:10px;">
        <span style="font-size:18px;">👤</span>
        <span style="font-size:16px; font-weight:900; color:#111827;">내 프로필</span>
      </div>

      <%# 이메일 (읽기 전용) %>
      <div style="padding:14px 18px; border-bottom:1px solid #f9fafb;">
        <div style="font-size:12px; font-weight:700; color:#9ca3af; margin-bottom:4px;">이메일 (변경 불가)</div>
        <div style="font-size:15px; font-weight:700; color:#374151;"><%= current_user.email %></div>
      </div>

      <%= form_with url: update_profile_app_settings_path, method: :patch, local: true do |f| %>
        <div style="padding:14px 18px 0; display:flex; flex-direction:column; gap:12px;">
          <div>
            <label style="font-size:12px; font-weight:800; color:#6b7280; display:block; margin-bottom:6px;">이름</label>
            <%= f.text_field :name, name: "user[name]", value: current_user.name,
                style: "width:100%; height:46px; border:1.5px solid #e5e7eb; border-radius:12px; padding:0 14px; font-size:15px; font-family:inherit; outline:none; box-sizing:border-box;",
                onfocus: "this.style.borderColor='#2563eb'", onblur: "this.style.borderColor='#e5e7eb'" %>
          </div>
          <div>
            <label style="font-size:12px; font-weight:800; color:#6b7280; display:block; margin-bottom:6px;">전화번호</label>
            <%= f.text_field :phone, name: "user[phone]", value: current_user.phone,
                id: "user_phone_input", placeholder: "010-0000-0000",
                style: "width:100%; height:46px; border:1.5px solid #e5e7eb; border-radius:12px; padding:0 14px; font-size:15px; font-family:inherit; outline:none; box-sizing:border-box;",
                onfocus: "this.style.borderColor='#2563eb'", onblur: "this.style.borderColor='#e5e7eb'" %>
          </div>
        </div>
        <div style="padding:14px 18px;">
          <%= f.submit "프로필 저장",
              style: "width:100%; height:46px; background:#111827; color:white; border:none; border-radius:12px; font-size:15px; font-weight:900; cursor:pointer; font-family:inherit;" %>
        </div>
      <% end %>

      <script>
      (function() {
        function formatPhoneNumber(value) {
          if (!value) return value;
          value = value.replace(/[^0-9]/g, '');
          if (!value) return '';
          
          if (value.startsWith('02')) {
            if (value.length <= 2) return value;
            if (value.length <= 5) return value.replace(/(\d{2})(\d{1,3})/, '$1-$2');
            if (value.length <= 9) return value.replace(/(\d{2})(\d{3})(\d{1,4})/, '$1-$2-$3');
            return value.replace(/(\d{2})(\d{4})(\d{1,4})/, '$1-$2-$3');
          } else if (value.startsWith('15') || value.startsWith('16') || value.startsWith('18')) {
            if (value.length <= 4) return value;
            return value.replace(/(\d{4})(\d{1,4})/, '$1-$2');
          } else {
            if (value.length <= 3) return value;
            if (value.length <= 7) return value.replace(/(\d{3})(\d{1,3})/, '$1-$2');
            return value.replace(/(\d{3})(\d{4})(\d{1,4})/, '$1-$2-$3');
          }
        }

        function initPhoneFormat() {
          var phoneInput = document.getElementById('user_phone_input');
          if (phoneInput && !phoneInput.dataset.formatted) {
            phoneInput.dataset.formatted = 'true';
            phoneInput.value = formatPhoneNumber(phoneInput.value);
            phoneInput.addEventListener('input', function(e) {
              e.target.value = formatPhoneNumber(e.target.value);
            });
          }
        }

        initPhoneFormat();
        document.addEventListener('turbo:load', initPhoneFormat);
        document.addEventListener('turbo:render', initPhoneFormat);
      })();
      </script>

    </div>

    <%# ── 3. 알림 설정 (알림함에서 설정) ── %>
    <div style="background:white; border-radius:20px; overflow:hidden;">
      <div style="padding:16px 18px; border-bottom:1px solid #f3f4f6; display:flex; align-items:center; gap:10px;">
        <span style="font-size:18px;">🔔</span>
        <span style="font-size:16px; font-weight:900; color:#111827;">알림 설정</span>
      </div>
      <%= link_to notifications_path(tab: 'settings'), style: "display:flex; justify-content:space-between; align-items:center; padding:16px 18px; text-decoration:none;" do %>
        <div>
          <div style="font-size:14px; font-weight:800; color:#111827;">아침·저녁·미수금 알림 관리</div>
          <div style="font-size:12px; color:#9ca3af; margin-top:2px;">알림함에서 알림 시간과 종류를 설정하세요</div>
        </div>
        <div style="font-size:16px; color:#9ca3af;">→</div>
      <% end %>
    </div>

    <%# ── 4. 앱 정보 ── %>
    <div style="background:white; border-radius:20px; overflow:hidden;">
      <div style="padding:16px 18px; border-bottom:1px solid #f3f4f6; display:flex; align-items:center; gap:10px;">
        <span style="font-size:18px;">ℹ️</span>
        <span style="font-size:16px; font-weight:900; color:#111827;">앱 정보</span>
      </div>
      <div style="padding:14px 18px; border-bottom:1px solid #f9fafb; display:flex; justify-content:space-between;">
        <span style="font-size:14px; color:#374151; font-weight:600;">앱 버전</span>
        <span style="font-size:14px; color:#9ca3af; font-weight:700;">v1.0.0</span>
      </div>
      <div style="padding:14px 18px; border-bottom:1px solid #f9fafb; display:flex; justify-content:space-between;">
        <span style="font-size:14px; color:#374151; font-weight:600;">가입일</span>
        <span style="font-size:14px; color:#9ca3af; font-weight:700;"><%= current_user.created_at.strftime("%Y년 %-m월 %-d일") %></span>
      </div>
      <a href="mailto:midaum79@gmail.com" style="display:flex; justify-content:space-between; padding:14px 18px; text-decoration:none; border-bottom:1px solid #f9fafb;">
        <span style="font-size:14px; color:#374151; font-weight:600;">📧 문의하기</span>
        <span style="font-size:14px; color:#2563eb; font-weight:700;">midaum79@gmail.com</span>
      </a>
      <div style="padding:14px 18px; display:flex; justify-content:space-between;">
        <span style="font-size:14px; color:#374151; font-weight:600;">이용약관 / 개인정보처리방침</span>
        <span style="font-size:14px; color:#9ca3af;">→</span>
      </div>
    </div>

    <%# ── 5. 계정 위험 구역 ── %>
    <div style="background:white; border-radius:20px; overflow:hidden;">
      <div style="padding:16px 18px; border-bottom:1px solid #f3f4f6;">
        <span style="font-size:14px; font-weight:900; color:#9ca3af;">계정</span>
      </div>
      <%= button_to logout_path, method: :delete,
          style: "width:100%; padding:16px 18px; background:none; border:none; text-align:left; font-size:15px; font-weight:800; color:#ef4444; cursor:pointer; font-family:inherit; display:block;" do %>
        🚪 로그아웃
      <% end %>
    </div>

  </div>
</div>
