          const textMsg = `[현장 전문가 명함]\n이름: ${tName}\n직함: ${tRole}\n전화: ${tPhone}`;

          if (navigator.canShare && navigator.canShare({ files: [file] })) {
            await navigator.share({
              title: '모바일 명함',
              text: textMsg,
              files: [file]
            });
            showSuccess();
          } else if (navigator.share) {
            await navigator.share({
              title: '모바일 명함',
              text: textMsg
            });
            showSuccess();
          } else {
             navigator.clipboard.writeText(textMsg);
             const url = URL.createObjectURL(blob);
             const a = document.createElement('a');
             a.href = url;
             a.download = 'biz_card.png';
             a.click();
             alert("명함 정보가 복사되었고 이미지가 다운로드 되었습니다.");
             showSuccess();
          }
        }, 'image/png', 1.0);
      } catch (e) {
        alert("일시적인 오류로 이미지를 생성하지 못했습니다.");
      } finally {
        setTimeout(() => {
          btn.disabled = false;
          btn.innerHTML = originalText;
          btn.style.transform = 'scale(1)';
        }, 800);
      }
      
      function showSuccess() {
        status.style.display = 'block';
        setTimeout(() => { status.style.display = 'none'; }, 5000);
      }
    }

    async function downloadBankCardImage() {
      const btn = document.getElementById('downloadBankCardBtn');
      const cardEl = document.getElementById('bankCardElement');
      btn.disabled = true;
      const originalText = btn.innerHTML;
      btn.innerHTML = '⏳ 저장 중...';
      try {
        const canvas = await html2canvas(cardEl, { scale: 4, backgroundColor: null, logging: false });
        canvas.toBlob(function(blob) {
          const url = URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url;
          a.download = 'bank_card.png';
          a.click();
          setTimeout(() => URL.revokeObjectURL(url), 100);
          const status = document.getElementById('cardShareStatus');
          if(status) {
            status.innerHTML = '✅ 기기에 이미지가 저장되었습니다!';
            status.style.display = 'block';
            setTimeout(() => { status.style.display = 'none'; }, 5000);
          }
        }, 'image/png', 1.0);
      } catch(e) {
        alert("일시적인 오류로 저장하지 못했습니다.");
      } finally {
        btn.disabled = false;
        btn.innerHTML = originalText;
      }
    }

    function copyBankCardText() {
      const bankName = document.getElementById('bankNameInput').value;
      const bankAcc = document.getElementById('bankAccountInput').value;
      const bankHolder = document.getElementById('bankHolderInput').value;
      if (!bankName || !bankAcc) {
