      const textMsg = `[일잘러 정산 계좌안내]\n${bankName} ${bankAcc} ${bankHolder}`;
      navigator.clipboard.writeText(textMsg).then(() => {
        const status = document.getElementById('cardShareStatus');
        if(status) {
          status.innerHTML = '✅ 텍스트가 복사되었습니다!';
          status.style.display = 'block';
          setTimeout(() => { status.style.display = 'none'; }, 5000);
        }
