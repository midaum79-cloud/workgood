      const tPhone = document.getElementById('bcPhoneInput').value;
      const textMsg = `[현장 전문가 명함]\n이름: ${tName}\n직함: ${tRole}\n전화: ${tPhone}`;
      navigator.clipboard.writeText(textMsg).then(() => {
        const status = document.getElementById('bcShareStatus');
        if(status) {
          status.innerHTML = '✅ 텍스트가 복사되었습니다!';
          status.style.display = 'block';
          setTimeout(() => { status.style.display = 'none'; }, 5000);
        }
      });
    }
  </script>

  <script>
    // 파일 업로드 시 브라우저 단에서 PNG로 자동 변환 및 리사이징
    document.addEventListener("turbo:load", function() {
      setTimeout(function() {
        document.querySelectorAll('.auto-png-convert').forEach(function(input) {
          if(input.dataset.pngConvertBounded) return;
          input.dataset.pngConvertBounded = "true";
          
          input.addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (!file) return;
            if (!file.type.startsWith('image/')) return;
            
            const submitBtn = input.closest('form').querySelector('input[type="submit"]');
            if (submitBtn) {
              submitBtn.dataset.originalText = submitBtn.value;
              submitBtn.value = "이미지 변환 중...";
              submitBtn.disabled = true;
              submitBtn.style.opacity = '0.7';
            }
            
            const img = new Image();
            img.onload = function() {
              const canvas = document.createElement('canvas');
              let width = img.width;
              let height = img.height;
              const max = 1600;
              
              if (width > max || height > max) {
                if (width > height) {
                  height = Math.round(height * max / width);
                  width = max;
                } else {
                  width = Math.round(width * max / height);
                  height = max;
                }
              }
              
              canvas.width = width;
              canvas.height = height;
              const ctx = canvas.getContext('2d');
              ctx.drawImage(img, 0, 0, width, height);
              
              canvas.toBlob(function(blob) {
                const newFileName = file.name.replace(/\.[^/.]+$/, "") + ".png";
                const newFile = new File([blob], newFileName, { type: "image/png" });
                
                const dt = new DataTransfer();
                dt.items.add(newFile);
                input.files = dt.files;
                
                if (submitBtn) {
                  submitBtn.value = submitBtn.dataset.originalText;
                  submitBtn.disabled = false;
                  submitBtn.style.opacity = '1';
                }
              }, "image/png", 1.0);
            };
            img.onerror = function() {
              if (submitBtn) {
                submitBtn.value = submitBtn.dataset.originalText;
                submitBtn.disabled = false;
                submitBtn.style.opacity = '1';
              }
            };
            img.src = URL.createObjectURL(file);
          });
        });
      }, 100);
    });
  </script>
</div>
