<div style="max-width:430px; margin:0 auto; min-height:100vh; background:#f5f5f5;">

  <%# Header %>
  <div style="background:white; padding:18px 20px 14px 20px; border-bottom:1px solid #ececec; position:sticky; top:0; z-index:30; margin-bottom:0;">
    <div style="display:flex; justify-content:space-between; align-items:center;">
      <div style="font-size:24px; color:#111827; font-weight:900; cursor:pointer;" onclick="openDrawer()">☰</div>
      <div style="font-size:20px; font-weight:900;">내 계정</div>
      <div style="width:40px;"></div>
    </div>
  </div>

  <div style="padding:0 16px 100px 16px; display:flex; flex-direction:column; gap:14px;">

    <% if notice %>
      <div style="background:#dcfce7; color:#166534; border-radius:14px; padding:12px 16px; margin-top:16px; margin-bottom:2px; font-size:14px; font-weight:700;"><%= notice %></div>
    <% end %>
    <% if alert %>
      <div style="background:#fef2f2; color:#991b1b; border-radius:14px; padding:12px 16px; margin-top:16px; margin-bottom:2px; font-size:14px; font-weight:700;"><%= alert %></div>
    <% end %>

  <%# ── Profile Hero Card ── %>
  <div style="background:linear-gradient(135deg, #111827 0%, #1e3a5f 100%); padding:32px 24px 28px; margin-bottom:2px; border-radius:20px; margin-top:16px;">
    <div style="display:flex; align-items:center; gap:16px; margin-bottom:20px;">
      <%# Avatar initials %>
      <div style="width:64px; height:64px; border-radius:50%; background:rgba(255,255,255,0.15); display:flex; align-items:center; justify-content:center; font-size:24px; font-weight:900; color:white; flex-shrink:0; border:2px solid rgba(255,255,255,0.2);">
        <%= current_user.name.chars.first.upcase %>
      </div>
      <div>
        <div style="font-size:22px; font-weight:900; color:white; margin-bottom:4px;"><%= current_user.name %></div>
        <div style="font-size:13px; color:rgba(255,255,255,0.65);"><%= current_user.email %></div>
        <% if current_user.phone.present? %>
          <div style="font-size:13px; color:rgba(255,255,255,0.65); margin-top:2px;"><%= current_user.phone %></div>
        <% end %>
      </div>
    </div>

    <%# Plan badge %>
    <div style="display:flex; align-items:center; gap:10px;">
      <span style="font-size:13px; font-weight:800;
        background:<%= current_user.premium? ? 'linear-gradient(90deg,#6366f1,#818cf8)' : (current_user.standard_or_above? ? '#2563eb' : 'rgba(255,255,255,0.2)') %>;
        color:white; padding:5px 14px; border-radius:999px;">
        <%= current_user.plan_label %> 플랜
      </span>
      <% if current_user.subscription_expires_at.present? %>
        <span style="font-size:12px; color:rgba(255,255,255,0.55);">~<%= current_user.subscription_expires_at.strftime("%Y.%m.%d") %></span>
      <% end %>
    </div>

    <%# Usage bar %>
    <div style="margin-top:16px;">
      <div style="display:flex; justify-content:space-between; margin-bottom:6px;">
        <span style="font-size:12px; color:rgba(255,255,255,0.65); font-weight:600;">이번 달 현장 등록</span>
        <span style="font-size:12px; color:rgba(255,255,255,0.65); font-weight:700;">
          <%= @monthly_project_count %>개 / <%= @plan_limit == Float::INFINITY ? "무제한" : "#{@plan_limit}개" %>
        </span>
      </div>
      <% usage_pct = @plan_limit == Float::INFINITY ? 0 : [(@monthly_project_count.to_f / @plan_limit * 100).round, 100].min %>
      <div style="width:100%; height:6px; background:rgba(255,255,255,0.15); border-radius:999px; overflow:hidden;">
        <div style="width:<%= usage_pct %>%; height:100%; background:<%= usage_pct >= 100 ? '#ef4444' : '#4ade80' %>; border-radius:999px; transition:width 0.5s;"></div>
      </div>
    </div>
  </div>



    <%# Promo Code %>
    <div style="background:white; border-radius:20px; padding:18px; box-shadow:0 2px 8px rgba(0,0,0,0.02); margin-bottom:2px;">
      <div style="font-size:14px; font-weight:900; color:#111827; margin-bottom:12px;">🎁 프로모션 쿠폰 등록</div>
      <%= form_with url: apply_promo_code_path, method: :post, local: true, style: "display:flex; gap:8px;" do |f| %>
        <%= f.text_field :code, placeholder: "쿠폰 번호를 입력하세요", style: "flex:1; padding:12px; border:1px solid #e5e7eb; border-radius:12px; font-size:14px; font-weight:700; box-sizing:border-box;" %>
        <button type="submit" style="padding:0 16px; background:#111827; color:white; border:none; border-radius:12px; font-size:13px; font-weight:800; cursor:pointer;">등록</button>
      <% end %>
    </div>

    <%# ── 빠른 메뉴 ── %>
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">

      <%= link_to app_settings_path, style: "background:white; border-radius:18px; padding:18px 16px; text-decoration:none; display:flex; flex-direction:column; align-items:flex-start; gap:8px;" do %>
        <span style="font-size:24px;">✏️</span>
        <div style="font-size:14px; font-weight:900; color:#111827;">프로필 수정</div>
        <div style="font-size:12px; color:#9ca3af; font-weight:600;">이름 / 전화번호</div>
      <% end %>

      <%= link_to subscription_path, style: "background:white; border-radius:18px; padding:18px 16px; text-decoration:none; display:flex; flex-direction:column; align-items:flex-start; gap:8px;" do %>
        <span style="font-size:24px;">💳</span>
        <div style="font-size:14px; font-weight:900; color:#111827;">요금제 변경</div>
        <div style="font-size:12px; color:#9ca3af; font-weight:600;">현재: <%= current_user.plan_label %></div>
      <% end %>


      <%= link_to notifications_path, style: "background:white; border-radius:18px; padding:18px 16px; text-decoration:none; display:flex; flex-direction:column; align-items:flex-start; gap:8px;" do %>
        <span style="font-size:20px;">🔔</span>
        <div style="font-size:14px; font-weight:900; color:#111827;">알림함</div>
        <div style="font-size:12px; color:#9ca3af; font-weight:600;">공정 알림 확인</div>
      <% end %>



    </div>

    <%# ── 내 통계 ── %>
    <div style="background:white; border-radius:20px; padding:18px;">
      <div style="font-size:14px; font-weight:900; color:#111827; margin-bottom:14px;">📊 내 현황</div>
      <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:8px;">
        <div style="text-align:center; background:#f9fafb; border-radius:14px; padding:14px 8px;">
          <div style="font-size:22px; font-weight:900; color:#111827;"><%= @project_count %></div>
          <div style="font-size:11px; color:#9ca3af; font-weight:700; margin-top:3px;">현장 수</div>
        </div>
        <div style="text-align:center; background:#f9fafb; border-radius:14px; padding:14px 8px;">
          <% total_processes = current_user.projects.joins(:work_processes).count rescue 0 %>
          <div style="font-size:22px; font-weight:900; color:#2563eb;"><%= total_processes %></div>
          <div style="font-size:11px; color:#9ca3af; font-weight:700; margin-top:3px;">전체 공정</div>
        </div>
        <div style="text-align:center; background:#f9fafb; border-radius:14px; padding:14px 8px;">
          <div style="font-size:22px; font-weight:900; color:#6b7280;"><%= current_user.created_at.strftime("%-m/%-d") %></div>
          <div style="font-size:11px; color:#9ca3af; font-weight:700; margin-top:3px;">가입일</div>
        </div>
      </div>
    </div>

    <%# ── 프리미엄 업그레이드 upsell (무료/스탠다드만) ── %>
    <% unless current_user.premium? %>
      <%= link_to subscription_path, style: "display:block; text-decoration:none;" do %>
        <div style="background:linear-gradient(135deg,#1e1b4b,#312e81); border-radius:20px; padding:18px 20px; display:flex; align-items:center; gap:14px;">
          <div style="font-size:32px;">⭐</div>
          <div>
            <div style="font-size:14px; font-weight:900; color:white; margin-bottom:4px;">프리미엄으로 업그레이드</div>
            <div style="font-size:12px; color:#a5b4fc; font-weight:600; line-height:1.5;">무제한 프로젝트 · 세금 · 통계 관리<br>월 ₩9,900 — 지금 시작하기 →</div>
          </div>
        </div>
      <% end %>
    <% end %>

    <% if current_user.is_admin? %>
      <div style="margin-bottom:14px;">
        <%= link_to admin_promo_codes_path, style: "display:block; text-decoration:none;" do %>
          <div style="background:#fee2e2; border-radius:16px; padding:14px 18px; display:flex; justify-content:space-between; align-items:center; border:1px solid #fca5a5;">
            <div style="display:flex; align-items:center; gap:10px;">
              <span style="font-size:20px;">🛠️</span>
              <span style="font-size:14px; font-weight:900; color:#991b1b;">관리자 전용 메뉴 (쿠폰 발급)</span>
            </div>
            <span style="color:#ef4444; font-weight:900;">→</span>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# ── 로그아웃 / 계정정보 ── %>
    <div style="background:white; border-radius:20px; overflow:hidden;">
      <div style="padding:14px 18px; border-bottom:1px solid #f9fafb; display:flex; justify-content:space-between;">
        <span style="font-size:13px; color:#6b7280; font-weight:600;">가입일</span>
        <span style="font-size:13px; color:#374151; font-weight:700;"><%= current_user.created_at.strftime("%Y년 %-m월 %-d일") %></span>
      </div>
      <div style="padding:14px 18px; border-bottom:1px solid #f9fafb; display:flex; justify-content:space-between;">
        <span style="font-size:13px; color:#6b7280; font-weight:600;">이메일</span>
        <span style="font-size:13px; color:#374151; font-weight:700;"><%= current_user.email %></span>
      </div>
      <%= button_to logout_path, method: :delete,
          style: "width:100%; padding:16px 18px; background:none; border:none; text-align:left; font-size:15px; font-weight:800; color:#ef4444; cursor:pointer; font-family:inherit;" do %>
        🚪 로그아웃
      <% end %>
    </div>

    <%# ── 회원 탈퇴 ── %>
    <div style="margin-top:8px; text-align:center;">
      <%= button_to delete_account_path, method: :delete, form: { onsubmit: "return confirm('정말 계정을 삭제하시겠습니까? 관련 데이터가 모두 삭제되며 복구할 수 없습니다.');" },
          style: "background:none; border:none; color:#9ca3af; font-size:13px; font-weight:600; text-decoration:underline; cursor:pointer; font-family:inherit; padding:12px;" do %>
        회원 탈퇴하기
      <% end %>
    </div>

  </div>
</div>
