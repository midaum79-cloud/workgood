<style>
  /* 화면 가로넘침 방지를 위한 전역 박스 사이징 강제 */
  #bcFormWrap * { box-sizing: border-box !important; }
  input, button, label, select { max-width: 100%; box-sizing: border-box !important; }
  /* 안드로이드 웹뷰에서 이미지 길게 누르기(다운로드)를 허용하기 위한 CSS */
  img#downloadedImagePreview {
    -webkit-touch-callout: default !important;
    -webkit-user-select: auto !important;
    user-select: auto !important;
    pointer-events: auto !important;
  }
</style>
<div style="min-height:100vh; background:#f5f5f5; padding-bottom:env(safe-area-inset-bottom);">
  <div style="background:white; padding:18px 20px 14px 20px; border-bottom:1px solid #ececec; position:sticky; top:0; z-index:30;" class="safe-sticky-header">
    <div style="display:flex; justify-content:space-between; align-items:center;">
      <div style="font-size:24px; color:#111827; font-weight:900; cursor:pointer;" onclick="openDrawer()">☰</div>
