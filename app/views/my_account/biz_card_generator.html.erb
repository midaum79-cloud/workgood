  <!-- 이미지 다운로드용 모달 -->
  <div id="imageDownloadModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.85); z-index:9999; justify-content:center; align-items:center; flex-direction:column;">
    <div style="background:white; padding:12px 20px; border-radius:12px; font-weight:800; font-size:15px; margin-bottom:16px; color:#1e293b; display:flex; flex-direction:column; align-items:center; gap:4px; text-align:center;">
      <span style="font-size:18px;">🎉 명함 생성이 완료되었습니다!</span>
      <span style="color:#64748b; font-size:12px; margin-top:4px;">기기에 따라 아래 버튼이나<br>이미지를 길게 눌러 저장해주세요.</span>
      <button onclick="document.getElementById('imageDownloadModal').style.display='none';" style="margin-top:10px; padding:6px 12px; border-radius:8px; background:#e2e8f0; border:none; font-weight:bold; cursor:pointer;">닫기</button>
    </div>
    
    <img id="downloadedImagePreview" src="" style="max-width:90%; max-height:50vh; border-radius:12px; border:1px solid rgba(255,255,255,0.2); -webkit-touch-callout: default !important; user-select: auto !important; pointer-events: auto !important;">
    
    <div style="display:flex; gap:10px; margin-top:20px; width:90%; max-width:320px;">
      <button onclick="shareImage('business_card.png', '명함 이미지 저장', '일잘러에서 명함이 전송되었습니다 클릭해서 저장하기를 누르세요')" style="flex:1; background:#0f172a; color:white; border:none; padding:16px 0; border-radius:14px; font-weight:900; font-size:14px; cursor:pointer; box-shadow:0 6px 16px rgba(15,23,42,0.4); display:flex; flex-direction:column; align-items:center; gap:4px;">
        <span style="font-size:24px;">💬</span>
        <span>메시지로 공유</span>
      </button>

      <button onclick="saveToGallery('business_card.png')" style="flex:1; background:#3b82f6; color:white; border:none; padding:16px 0; border-radius:14px; font-weight:900; font-size:14px; cursor:pointer; box-shadow:0 6px 16px rgba(59,130,246,0.4); display:flex; flex-direction:column; align-items:center; gap:4px;">
        <span style="font-size:24px;">💾</span>
        <span>갤러리에 저장</span>
      </button>
    </div>
  </div>
</div>

<script>
  async function shareImage(filename, title, text) {
    try {
      if (navigator.share) {
        await navigator.share({
          title: title,
          text: text,
          url: 'https://workgood.co.kr/d/<%= current_user.document_share_token %>?docs=card'
        });
      } else {
        alert("현재 기기에서는 공유를 지원하지 않습니다.\n대신 '갤러리에 저장'을 이용해주세요.");
      }
    } catch (e) {
      console.error(e);
      alert("공유 중 오류가 발생했습니다.");
    }
  }

  async function saveToGallery(filename) {
    const src = document.getElementById('downloadedImagePreview').src;
    try {
      const res = await fetch(src);
      const blob = await res.blob();
      const file = new File([blob], filename, { type: 'image/png' });

      // Capacitor 네이티브 앱이거나 안드로이드 웹뷰인 경우 (다운로드 및 꾹누르기 불가)
      if (window.Capacitor || (navigator.userAgent.match(/Android/i) && navigator.userAgent.match(/wv|MicroMessenger|Instagram|KAKAOTALK/i))) {
        if (navigator.canShare && navigator.canShare({ files: [file] })) {
          alert("앱(웹뷰) 환경에서는 전용 다운로드가 제한됩니다.\n대신 뛰워드리는 [공유] 알림창에서 '사진 저장'을 누르시거나 카톡으로 전송해 주세요!");
          await navigator.share({
            files: [file],
            title: filename,
            text: '명함 이미지 저장/공유'
          });
          return;
        } else {
          // Web Share API를 지원하지 않는 극한의 갤럭시 웹뷰 환경 우회
          const uploadRes = await fetch('<%= cache_image_for_download_path %>', {
            method: 'POST',
            headers: {'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content},
            body: JSON.stringify({ image_base64: src })
          });
          const uploadData = await uploadRes.json();
          if (uploadData.success) {
            alert("전용 앱 보안 한계로 인해 이미지를 외부 새 창에 띄워드립니다!\n\n💡 열린 창에서 명함을 2~3초간 꾹~ 눌러 [이미지 저장]을 선택해주세요.");
            if (window.Capacitor && window.Capacitor.Plugins && window.Capacitor.Plugins.Browser) {
              await window.Capacitor.Plugins.Browser.open({ url: uploadData.url });
            } else {
              window.open(uploadData.url, '_blank') || (window.location.href = uploadData.url);
            }
            return;
          }
        }
      }

      // 일반 브라우저 다운로드 시도
      const fallbackBlobUrl = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = fallbackBlobUrl;
      a.download = filename;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      
      setTimeout(() => URL.revokeObjectURL(fallbackBlobUrl), 1000);
      alert("다운로드를 시도했습니다!\n저장이 안 될 경우, 화면 캡처(스크린샷)를 이용해주시거나 '메시지로 공유' 버튼을 사용해주세요.");
      
    } catch (e) {
      console.error(e);
      alert("이미지 처리 중 오류가 발생했습니다.");
    }
  }
</script>

<script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
<script>
  let currentBcTemplate = 'A';
  function setBcTemplate(type) {
    currentBcTemplate = type;
    if(type === 'A') {
      document.getElementById('bcTemplateA').style.display = 'block';
      document.getElementById('bcTemplateB').style.display = 'none';
      document.getElementById('btnTplA').style.background = '#4c1d95';
      document.getElementById('btnTplA').style.color = 'white';
      document.getElementById('btnTplA').style.border = 'none';
      
      document.getElementById('btnTplB').style.background = '#f1f5f9';
      document.getElementById('btnTplB').style.color = '#475569';
      document.getElementById('btnTplB').style.border = '1px solid #cbd5e1';
    } else {
      document.getElementById('bcTemplateA').style.display = 'none';
      document.getElementById('bcTemplateB').style.display = 'block';
      
      document.getElementById('btnTplB').style.background = '#4c1d95';
      document.getElementById('btnTplB').style.color = 'white';
      document.getElementById('btnTplB').style.border = 'none';
      
      document.getElementById('btnTplA').style.background = '#f1f5f9';
      document.getElementById('btnTplA').style.color = '#475569';
      document.getElementById('btnTplA').style.border = '1px solid #cbd5e1';
    }
  }

  function autoFormatPhone(obj) {
    let v = obj.value.replace(/[^0-9]/g, "");
    let res = "";
    if (v.startsWith("02")) {
      if (v.length < 3) res = v;
      else if (v.length < 6) res = v.substr(0, 2) + "-" + v.substr(2);
      else if (v.length < 10) res = v.substr(0, 2) + "-" + v.substr(2, 3) + "-" + v.substr(5);
      else res = v.substr(0, 2) + "-" + v.substr(2, 4) + "-" + v.substr(6, 4);
    } else {
      if (v.length < 4) res = v;
      else if (v.length < 7) res = v.substr(0, 3) + "-" + v.substr(3);
      else if (v.length < 11) res = v.substr(0, 3) + "-" + v.substr(3, 3) + "-" + v.substr(6);
      else res = v.substr(0, 3) + "-" + v.substr(3, 4) + "-" + v.substr(7, 4);
    }
    // Update value and trigger any listening 'input' events to update the card preview
    if (obj.value !== res) {
      obj.value = res;
      obj.dispatchEvent(new Event('input', { bubbles: true }));
    }
  }

  function initBizCard() {
    const bTeamInfo = document.getElementById('bcTeamInput');
    const bRoleInfo = document.getElementById('bcRoleInput');
    const bNameInfo = document.getElementById('bcNameInput');
    const bPhoneInfo = document.getElementById('bcPhoneInput');
    const logoInput = document.getElementById('bcLogoInput');
    
    // 이전에 이벤트가 바인딩되었는지 확인하여 중복 방지
    if(!bTeamInfo || bTeamInfo.dataset.initialized) return;
    bTeamInfo.dataset.initialized = 'true';

    function updateBizCard() {
      if(!bTeamInfo) return;
      document.getElementById('bcA_Team').textContent = bTeamInfo.value || '업체명';
      document.getElementById('bcB_Team').textContent = bTeamInfo.value || '업체명';
      document.getElementById('bcA_Role').textContent = bRoleInfo.value || '직책';
      document.getElementById('bcB_Role').textContent = bRoleInfo.value || '직책';
      
      const nameVal = bNameInfo.value || '일잘러';
      document.getElementById('bcA_Name').textContent = nameVal;
      if(nameVal.length >= 2) {
        document.getElementById('bcB_Name').innerHTML = '<strong>' + nameVal.substring(0, 1) + '</strong>' + nameVal.substring(1);
      } else {
        document.getElementById('bcB_Name').innerHTML = '<strong>' + nameVal + '</strong>';
      }
      
      document.getElementById('bcA_Phone').textContent = bPhoneInfo.value || '전화번호';
      document.getElementById('bcB_Phone').textContent = bPhoneInfo.value || '전화번호';
      
      const addrVal = document.getElementById('bcAddressInput').value;
      if (addrVal) {
        document.getElementById('bcA_Address_Container').style.display = 'flex';
        document.getElementById('bcA_Address').textContent = addrVal;
        document.getElementById('bcB_Address').style.display = 'block';
        document.getElementById('bcB_Address').textContent = addrVal;
      } else {
        document.getElementById('bcA_Address_Container').style.display = 'none';
        document.getElementById('bcB_Address').style.display = 'none';
      }
    }

    if(logoInput) {
      logoInput.addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (file) {
          document.getElementById('bcLogoLabel').textContent = file.name;
          const reader = new FileReader();
          reader.onload = function(evt) {
            const resultUrl = evt.target.result;
            const logoA = document.getElementById('bcA_LogoImg');
            const logoB = document.getElementById('bcB_LogoImg');
            if(logoA) { logoA.src = resultUrl; logoA.style.display = 'block'; }
            if(logoB) { logoB.src = resultUrl; logoB.style.display = 'block'; }
          };
          reader.readAsDataURL(file);
        }
      });
    }

    bTeamInfo.addEventListener('input', updateBizCard);
    bRoleInfo.addEventListener('input', updateBizCard);
    bNameInfo.addEventListener('input', updateBizCard);
    bPhoneInfo.addEventListener('input', updateBizCard);
    document.getElementById('bcAddressInput').addEventListener('input', updateBizCard);
    
    // 초기화
    updateBizCard();
  }
  
  // 스크립트가 로드될 때 즉시 실행
  initBizCard();
  // 뒤로가기나 turbo 네비게이션 시에도 보장하기 위해
  document.addEventListener("turbo:load", initBizCard);

  const originalData = {
    team: "<%= j current_user.team_name.to_s %>",
    role: "<%= j current_user.role.to_s %>",
    name: "<%= j current_user.name.to_s %>",
    phone: "<%= j current_user.phone.to_s %>",
    address: "<%= j current_user.address.to_s %>"
  };

  async function generateImageWithLimit() {
    const isChanged = (
      document.getElementById('bcTeamInput').value !== originalData.team ||
      document.getElementById('bcRoleInput').value !== originalData.role ||
      document.getElementById('bcNameInput').value !== originalData.name ||
      document.getElementById('bcPhoneInput').value !== originalData.phone ||
      document.getElementById('bcAddressInput').value !== originalData.address
    );

    const btn = document.getElementById('downloadBizCardBtn');
    btn.disabled = true;
    const originalText = btn.innerHTML;

    try {
      if (isChanged) {
        btn.innerHTML = '⏳ 권한 확인 중...';
        const response = await fetch('<%= increment_biz_card_gen_path %>', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
            'Accept': 'application/json'
          }
        });
        const data = await response.json();
        
        if (!data.success && data.limit_reached) {
          alert("⚠️ 무료 체험 횟수(10회)를 모두 소진하셨습니다!\n\n무제한 생성을 원하시면 프리미엄 플랜을 구독해주세요.");
          window.location.href = '<%= subscription_path %>';
          return;
        }

        originalData.team = document.getElementById('bcTeamInput').value;
        originalData.role = document.getElementById('bcRoleInput').value;
        originalData.name = document.getElementById('bcNameInput').value;
        originalData.phone = document.getElementById('bcPhoneInput').value;
        originalData.address = document.getElementById('bcAddressInput').value;
      }
      
      btn.innerHTML = '⏳ 굽는 중...';
      const cardEl = document.getElementById('bcTemplate' + currentBcTemplate);
      const bgColor = currentBcTemplate === 'A' ? '#111827' : '#ffffff';
      
      document.getElementById('imageDownloadModal').style.display = 'flex';
      const canvas = await html2canvas(cardEl, { scale: 4, backgroundColor: bgColor, logging: false });
      document.getElementById('downloadedImagePreview').src = canvas.toDataURL('image/png');
      
      // Update info in backend async
      const formData = new FormData();
      formData.append('user[team_name]', document.getElementById('bcTeamInput').value);
      formData.append('user[role]', document.getElementById('bcRoleInput').value);
      formData.append('user[name]', document.getElementById('bcNameInput').value);
      formData.append('user[phone]', document.getElementById('bcPhoneInput').value);
      formData.append('user[address]', document.getElementById('bcAddressInput').value);
      formData.append('business_card_base64_direct', canvas.toDataURL('image/png'));
      
      fetch('<%= update_my_account_documents_path %>.json', {
        method: 'PATCH',
        headers: {
          'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
          'Accept': 'application/json'
        },
        body: formData
      });
      
    } catch (e) {
      alert("오류가 발생했습니다.");
    } finally {
      btn.disabled = false;
      btn.innerHTML = originalText;
    }
  }
</script>

<script src="//t1.daumcdn.net/mapjsapi/bundle/postcode/prod/postcode.v2.js"></script>

<!-- Daum Postcode 팝업 레이어 -->
<div id="daumPostcodeLayer" style="display:none; position:fixed; overflow:hidden; z-index:99999; -webkit-overflow-scrolling:touch; width:100%; height:100%; top:0; left:0; background:rgba(0,0,0,0.6);">
  <div style="position:absolute; top:50%; left:50%; transform:translate(-50%, -50%); width:90%; max-width:400px; height:80vh; max-height:600px; background:white; border-radius:12px; overflow:hidden; display:flex; flex-direction:column; box-shadow:0 10px 30px rgba(0,0,0,0.3);">
    <div style="display:flex; justify-content:space-between; align-items:center; padding:12px 16px; border-bottom:1px solid #f0f0f0; background:#f8fafc;">
      <span style="font-weight:800; font-size:15px; color:#334155;">📍 주소 검색</span>
      <button type="button" onclick="closeDaumPostcode()" style="background:none; border:none; font-size:24px; line-height:1; color:#94a3b8; cursor:pointer;">&times;</button>
    </div>
    <div id="daumPostcodeWrap" style="width:100%; flex:1; overflow-y:auto; -webkit-overflow-scrolling:touch;"></div>
  </div>
</div>

<script>
  function execDaumPostcode() {
    const layer = document.getElementById('daumPostcodeLayer');
    const wrap = document.getElementById('daumPostcodeWrap');
    layer.style.display = 'block';

    new daum.Postcode({
      oncomplete: function(data) {
        let addr = data.userSelectedType === 'R' ? data.roadAddress : data.jibunAddress;
        let extraAddr = '';
        if(data.userSelectedType === 'R'){
          if(data.bname !== '' && /[동|로|가]$/g.test(data.bname)){
            extraAddr += data.bname;
          }
          if(data.buildingName !== '' && data.apartment === 'Y'){
            extraAddr += (extraAddr !== '' ? ', ' + data.buildingName : data.buildingName);
          }
          if(extraAddr !== ''){
            extraAddr = ' (' + extraAddr + ')';
          }
        }
        const fullAddress = addr + extraAddr;
        const addrInput = document.getElementById('bcAddressInput');
        addrInput.value = fullAddress;
        addrInput.dispatchEvent(new Event('input'));
        
        closeDaumPostcode();
      },
      width: '100%',
      height: '100%'
    }).embed(wrap);
  }

  function closeDaumPostcode() {
    document.getElementById('daumPostcodeLayer').style.display = 'none';
  }
</script>
