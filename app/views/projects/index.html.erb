<script>
  // Turbo 캐시에서 이 페이지 제외 — 캐시 복원 시 이전 날짜가 보이는 문제 방지
  if (typeof Turbo !== 'undefined' && Turbo.cache) {
    Turbo.cache.exemptPageFromCache();
  }

  // 자정 넘으면 자동 새로고침 — 서버에서 새 날짜로 다시 렌더링
  (function() {
    var pageLoadDate = new Date().toDateString();
    setInterval(function() {
      var now = new Date();
      if (now.toDateString() !== pageLoadDate) {
        window.location.reload();
      }
    }, 30000); // 30초마다 체크
  })();
</script>
