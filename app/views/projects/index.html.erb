  <script>
  (function() {
    var days = ['일요일', '월요일', '화요일', '수요일', '목요일', '금요일', '토요일'];
    function pad(n) { return n < 10 ? '0' + n : n; }
    function tick() {
      var now = new Date();
      var m = now.getMonth() + 1;
      var d = now.getDate();
      var h = now.getHours();
      var mi = now.getMinutes();
      var s = now.getSeconds();
      var dayName = days[now.getDay()];
      var ampm = h < 12 ? '오전' : '오후';
      var h12 = h % 12 || 12;

      var dateEl = document.getElementById('clockDate');
      var timeEl = document.getElementById('clockTime');
      var secEl = document.getElementById('clockSeconds');
      var dayEl = document.getElementById('clockDay');
      var pulseEl = document.getElementById('clockPulse');
      var greetingEl = document.getElementById('clockGreeting');

      if (dateEl) dateEl.textContent = now.getFullYear() + '년 ' + m + '월 ' + d + '일';
      if (timeEl) timeEl.textContent = ampm + ' ' + h12 + ':' + pad(mi);
      if (secEl) secEl.textContent = ':' + pad(s);
      if (dayEl) dayEl.textContent = dayName;
      if (pulseEl) pulseEl.style.opacity = s % 2 === 0 ? '1' : '0.3';
      
      if (greetingEl) {
        if (h < 7) {
          greetingEl.textContent = "좋은 아침입니다!";
        } else if (h === 12 || (h === 13 && mi <= 30)) {
          greetingEl.textContent = "식사 맛있게 하세요!";
        } else if (h >= 18) {
          greetingEl.textContent = "오늘 하루도 수고 하셨습니다!";
        } else {
          greetingEl.textContent = "오늘도 화이팅!";
        }
      }
    }
    tick();
    setInterval(tick, 1000);
  })();
  </script>

