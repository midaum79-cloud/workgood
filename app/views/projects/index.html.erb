  <script>
    // 날씨 위젯 로직
    function getWeatherEmoji(code) {
      if (code === 0) return '☀️'; 
      if (code === 1) return '🌤️';
      if (code === 2) return '⛅'; 
      if (code === 3) return '☁️';
      if (code === 45 || code === 48) return '🌫️'; 
      if (code >= 51 && code <= 57) return '🌦️';
      if (code >= 61 && code <= 67) return '🌧️'; 
      if (code >= 71 && code <= 77) return '❄️'; 
      if (code >= 80 && code <= 82) return '🌧️'; 
      if (code >= 85 && code <= 86) return '🌨️'; 
      if (code >= 95 && code <= 99) return '⛈️'; 
      return '☀️'; 
    }

    function getWeatherDesc(code) {
      if (code === 0) return '맑음';
      if (code === 1) return '대체로 맑음';
      if (code === 2) return '구름 조금';
      if (code === 3) return '흐림';
      if (code === 45 || code === 48) return '안개';
      if (code >= 51 && code <= 57) return '이슬비';
      if (code >= 61 && code <= 65) return '비';
      if (code === 66 || code === 67) return '빗방울';
      if (code >= 71 && code <= 77) return '눈';
      if (code >= 80 && code <= 82) return '소나기';
      if (code >= 85 && code <= 86) return '눈보라';
      if (code >= 95 && code <= 99) return '뇌우';
      return '맑음';
    }

    function getWeatherGradient(code, hour) {
      if (hour >= 6 && hour < 9) {
        if (code <= 2) return 'linear-gradient(135deg, #f97316 0%, #fb923c 40%, #fbbf24 100%)';
        return 'linear-gradient(135deg, #94a3b8 0%, #64748b 100%)';
      }
      if (hour >= 9 && hour < 17) {
        if (code === 0) return 'linear-gradient(135deg, #0ea5e9 0%, #38bdf8 50%, #7dd3fc 100%)';
        if (code <= 3) return 'linear-gradient(135deg, #0ea5e9 0%, #6366f1 50%, #8b5cf6 100%)';
        if (code >= 51 && code <= 82) return 'linear-gradient(135deg, #475569 0%, #64748b 50%, #94a3b8 100%)';
        if (code >= 95) return 'linear-gradient(135deg, #1e293b 0%, #334155 50%, #475569 100%)';
        return 'linear-gradient(135deg, #0ea5e9 0%, #6366f1 100%)';
      }
      if (hour >= 17 && hour < 20) {
        if (code <= 2) return 'linear-gradient(135deg, #f97316 0%, #e11d48 50%, #7c3aed 100%)';
        return 'linear-gradient(135deg, #475569 0%, #1e293b 100%)';
      }
      if (code <= 2) return 'linear-gradient(135deg, #1e1b4b 0%, #312e81 50%, #4c1d95 100%)';
      return 'linear-gradient(135deg, #0f172a 0%, #1e293b 100%)';
    }

    function updateWeatherDisplay(name, lat, lng) {
      document.getElementById('weatherLocName').innerText = name;
      
      fetch('https://api.open-meteo.com/v1/forecast?latitude=' + lat + '&longitude=' + lng + '&current=temperature_2m,weathercode,windspeed_10m&daily=weathercode,temperature_2m_max,temperature_2m_min&timezone=Asia%2FSeoul')
        .then(function(res) { return res.json(); })
        .then(function(data) {
          if(data && data.daily && data.current) {
            var codes = data.daily.weathercode;
            var maxTemps = data.daily.temperature_2m_max;
            var minTemps = data.daily.temperature_2m_min;
            var currentTemp = Math.round(data.current.temperature_2m);
            var currentCode = data.current.weathercode;
            var hour = new Date().getHours();

            document.getElementById('weatherTodayTemp').textContent = currentTemp + '°';
            // 큰 아이콘은 UI 최적화를 위해 삭제되었으므로 제외함
            // document.getElementById('weatherTodayIcon').textContent = getWeatherEmoji(currentCode);
            
            var desc = getWeatherDesc(currentCode);
            var wind = data.current.windspeed_10m ? ' · 바람 ' + Math.round(data.current.windspeed_10m) + 'km/h' : '';
            document.getElementById('weatherTodayDesc').textContent = desc + wind;

            document.getElementById('weatherWidget').style.background = getWeatherGradient(currentCode, hour);

            for (var i = 0; i < 3; i++) {
              var iconEl = document.getElementById('weatherDay' + i + 'Icon');
              var tempEl = document.getElementById('weatherDay' + i + 'Temp');
              if (iconEl) iconEl.textContent = getWeatherEmoji(codes[i]);
              if (tempEl) tempEl.textContent = Math.round(maxTemps[i]) + '°';
            }
          }
        })
        .catch(function(e) {
          console.error('Weather Fetch Error:', e);
          document.getElementById('weatherTodayDesc').textContent = '날씨 정보를 불러올 수 없습니다';
        });
    }

    function initWeatherWidget() {
      var savedName = localStorage.getItem('workgood_weather_name') || '서울특별시';
      var savedLat = localStorage.getItem('workgood_weather_lat') || '37.566';
      var savedLng = localStorage.getItem('workgood_weather_lng') || '126.9784';
      updateWeatherDisplay(savedName, savedLat, savedLng);
    }

    function changeWeatherLocation() {
      var q = prompt("현장의 지역명을 입력하세요\n(예: 부산, 수원, 강남구 등)");
      if (q && q.trim()) {
        document.getElementById('weatherLocName').innerText = '검색 중...';
        fetch('https://geocoding-api.open-meteo.com/v1/search?name=' + encodeURIComponent(q.trim()) + '&language=ko&count=1')
          .then(function(res) { return res.json(); })
          .then(function(data) {
            if (data.results && data.results.length > 0) {
              var res = data.results[0];
              var cleanName = res.name; 
              if (res.admin1 && res.admin1 !== res.name) {
                cleanName = res.admin1 + ' ' + res.name;
              }
              localStorage.setItem('workgood_weather_name', cleanName);
              localStorage.setItem('workgood_weather_lat', res.latitude);
              localStorage.setItem('workgood_weather_lng', res.longitude);
              updateWeatherDisplay(cleanName, res.latitude, res.longitude);
            } else {
              alert("해당 지역 정보를 찾을 수 없습니다. 다르게 검색해주세요.");
              initWeatherWidget();
            }
          })
          .catch(function(e) {
            alert("검색 중 오류가 발생했습니다.");
            initWeatherWidget();
          });
      }
    }

    document.addEventListener('turbo:load', initWeatherWidget);
    document.addEventListener('DOMContentLoaded', initWeatherWidget);
    initWeatherWidget();
  </script>

