<style>
.hide-scrollbar::-webkit-scrollbar { display: none; }
.hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<div style="min-height:100dvh; background:white; padding:0 0 80px 0; display:flex; flex-direction:column;">

  <div style="background:white; padding:18px 20px 14px 20px; border-bottom:1px solid #f0f0f0; position:sticky; top:0; z-index:30;">
    <div style="display:flex; justify-content:space-between; align-items:center;">
      <div style="font-size:24px; color:#111827; font-weight:900; cursor:pointer;" onclick="openDrawer()">☰</div>

      <div style="display:flex; align-items:center;">
        <img src="/logo.png" alt="일잘러" style="height:44px;">
      </div>

      <%= link_to notifications_path, style: "position:relative; text-decoration:none;" do %>
        <div style="font-size:20px;">🔔</div>
        <% if @unread_notifications_count.to_i > 0 %>
          <div style="
            position:absolute;
            top:-6px;
            right:-8px;
            min-width:18px;
            height:18px;
            padding:0 5px;
            border-radius:999px;
            background:#ef4444;
            color:white;
            font-size:11px;
            font-weight:900;
            display:flex;
            align-items:center;
            justify-content:center;
            box-sizing:border-box;
          ">
            <%= @unread_notifications_count %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>

  <div style="background:white; padding:14px 0 0 0; margin-bottom:0; flex:1; display:flex; flex-direction:column;">
    <div style="display:flex; justify-content:center; align-items:center; margin-bottom:14px; padding:0 16px; position:relative;">
      
      <!-- 스와이프 로직용 숨김 링크 -->
      <%= link_to "", calendar_projects_path(status: @selected_status, view_mode: @view_mode, year: @prev_month.year, month: @prev_month.month, selected_date: @selected_date), id: "prevMonthLink", style: "display:none;" %>
      <%= link_to "", calendar_projects_path(status: @selected_status, view_mode: @view_mode, year: @next_month.year, month: @next_month.month, selected_date: @selected_date), id: "nextMonthLink", style: "display:none;" %>

      <!-- 센터 네이티브 월 선택기 -->
      <div style="position:relative; display:inline-flex; align-items:center; cursor:pointer;">
        <div style="font-size:20px; font-weight:900; color:#111827; letter-spacing:-0.5px;">
          <%= @calendar_year %>. <%= @calendar_month %> <span style="font-size:15px; margin-left:2px; vertical-align:middle;">⌃</span>
        </div>
        <input type="month" 
               value="<%= format('%04d-%02d', @calendar_year, @calendar_month) %>"
               onchange="window.location.href='<%= calendar_projects_path(status: @selected_status, view_mode: @view_mode, selected_date: @selected_date) %>&year=' + this.value.split('-')[0] + '&month=' + parseInt(this.value.split('-')[1])"
               style="position:absolute; top:0; left:0; width:100%; height:100%; opacity:0; cursor:pointer;" />
      </div>
    </div>





    <div style="overflow:hidden; background:white; flex:1; display:flex; flex-direction:column; position:relative; touch-action:pan-y;">
      <div id="calendarSwipeBody" class="calendar-animate-in" style="flex:1; display:flex; flex-direction:column; width:100%; will-change:transform;">
        <div style="display:grid; grid-template-columns:repeat(7, 1fr); border-bottom:1px solid #f0f0f0; background:white;">
        <% ["일", "월", "화", "수", "목", "금", "토"].each do |weekday| %>
          <% header_color = case weekday
              when "일" then "#ef4444"
              when "토" then "#3b82f6"
              else "#6b7280"
             end %>
          <div style="padding:12px 0; text-align:center; font-size:14px; font-weight:800; color:<%= header_color %>;">
            <%= weekday %>
          </div>
        <% end %>
      </div>

      <% @calendar_rows.each_with_index do |row_days, row_index| %>
        <div style="flex:1; border-bottom:<%= row_index == @calendar_rows.length - 1 ? 'none' : '1px solid #f3f4f6' %>; display:flex; flex-direction:column;">
          <div style="display:grid; grid-template-columns:repeat(7, 1fr);">
            <% row_days.each do |day| %>
              <% is_current_month = (day.month == @calendar_month) %>
              <% is_selected = (day == @selected_date) %>
              <% day_projects = @projects_by_date[day] || [] %>
              <% has_work = day_projects.any? %>
              
              <% date_text_color = if !is_current_month
                  '#9ca3af'
                elsif day.sunday?
                  '#ef4444'
                elsif day.saturday?
                  '#3b82f6'
                else
                  '#111827'
                end %>

              <div class="calendar-date-cell"
                   data-date="<%= day.to_s %>"
                   style="
                    min-height:60px;
                    border-right:none;
                    padding:3px 2px 2px 2px;
                    box-sizing:border-box;
                    background:white;
                    display:flex;
                    flex-direction:column;
                    align-items:stretch;
                  ">
                <div style="display:flex; justify-content:center; margin-bottom:2px;">
                  <span style="
                    display:inline-flex;
                    align-items:center;
                    justify-content:center;
                    width:24px;
                    height:24px;
                    border-radius:50%;
                    font-size:13px;
                    font-weight:900;
                    color:<%= is_selected ? 'white' : date_text_color %>;
                    background:<%= is_selected ? '#f59e0b' : 'transparent' %>;
                  "><%= format('%02d', day.day) %></span>
                </div>
                <% if is_current_month %>
                  <% day_projects.each do |proj| %>
                    <div class="schedule-chip"
                         draggable="true"
                         data-project-id="<%= proj.id %>"
                         data-date="<%= day.to_s %>"
                         onclick="window.location.href='<%= project_path(proj) %>'"
                         style="
                          font-size:9px;
                          font-weight:800;
                          color:<%= proj.theme_color_hex %>;
                          background:<%= proj.theme_color_hex %>1a;
                          border:1px solid <%= proj.theme_color_hex %>4d;
                          border-radius:4px;
                          padding:2px 3px;
                          margin-bottom:1px;
                          overflow:hidden;
                          white-space:nowrap;
                          text-overflow:ellipsis;
                          cursor:grab;
                          user-select:none;
                          -webkit-user-select:none;
                         ">
                      <%= proj.client_name.presence || proj.project_name %>
                    </div>
                  <% end %>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
      </div>
    </div>

  </div>
</div>

<!-- Bottom Sheet Overlay -->
<div id="bsOverlay" onclick="closeBottomSheet()" style="
  position:fixed; top:0; left:0; right:0; bottom:0;
  background:rgba(0,0,0,0.5); z-index:500;
  opacity:0; visibility:hidden;
  transition:all 0.3s ease;
"></div>

<!-- Bottom Sheet - 거래처 선택 -->
<div id="bottomSheet" style="
  position:fixed; left:0; right:0; bottom:0;
  background:white; z-index:510;
  border-radius:24px 24px 0 0;
  box-shadow:0 -4px 30px rgba(0,0,0,0.15);
  transform:translateY(100%);
  transition:transform 0.35s cubic-bezier(0.4,0,0.2,1);
  max-height:70vh; overflow-y:auto;
  padding-bottom:env(safe-area-inset-bottom);
">
  <div style="display:flex; justify-content:center; padding:12px 0 4px 0;">
    <div style="width:40px; height:4px; border-radius:99px; background:#d1d5db;"></div>
  </div>

  <div style="padding:8px 20px 14px 20px; display:flex; justify-content:space-between; align-items:center;">
    <div>
      <div id="bsTitle" style="font-size:20px; font-weight:900; color:#111827;">현장 추가</div>
      <div id="bsSubtitle" style="font-size:13px; font-weight:700; color:#9ca3af; margin-top:2px;"></div>
    </div>
    <div onclick="closeBottomSheet()" style="font-size:22px; color:#9ca3af; cursor:pointer; padding:4px 8px;">✕</div>
  </div>

  <div style="padding:0 16px 20px 16px;">
    <div style="display:flex; gap:8px; margin-bottom:14px;">
      <button type="button" id="bsTabCompany" onclick="bsSwitchTab('company')" style="flex:1; padding:10px; border:none; border-radius:12px; font-size:14px; font-weight:800; cursor:pointer; background:#111827; color:white;">🏢 업체</button>
      <button type="button" id="bsTabPersonal" onclick="bsSwitchTab('personal')" style="flex:1; padding:10px; border:none; border-radius:12px; font-size:14px; font-weight:800; cursor:pointer; background:#f3f4f6; color:#6b7280;">👤 개인</button>
      <button type="button" id="bsTabDirect" onclick="bsSwitchTab('direct')" style="flex:1; padding:10px; border:none; border-radius:12px; font-size:14px; font-weight:800; cursor:pointer; background:#f3f4f6; color:#6b7280;">✏️ 직접입력</button>
    </div>

    <div id="bsSearchArea">
      <div id="bsSearchResults" style="display:flex; flex-direction:column; gap:6px; max-height:260px; overflow-y:auto; padding-bottom:10px;"></div>
    </div>

    <div id="bsDirectArea" style="display:none;">
      <input type="text" id="bsDirectName" placeholder="거래처명을 입력하세요"
        style="width:100%; padding:14px 16px; border:1px solid #dcdfe4; border-radius:12px; font-size:15px; box-sizing:border-box; margin-bottom:10px;">
      <button type="button" onclick="bsGoToNewProject(document.getElementById('bsDirectName').value)"
        style="width:100%; padding:14px; border:none; border-radius:12px; background:#2563eb; color:white; font-size:16px; font-weight:900; cursor:pointer;">
        일정에 바로 추가하기
      </button>
    </div>
  </div>
</div>

<script>
var bsSelectedDate = null;
var bsCurrentTab = 'company';

function openBottomSheet(dateStr) {
  bsSelectedDate = dateStr;
  var parts = dateStr.split('-');
  document.getElementById('bsSubtitle').textContent = parts[0] + '년 ' + parseInt(parts[1]) + '월 ' + parseInt(parts[2]) + '일';
  document.getElementById('bsSearchResults').innerHTML = '';
  document.getElementById('bsDirectName').value = '';
  bsSwitchTab('company');

  document.getElementById('bsOverlay').style.opacity = '1';
  document.getElementById('bsOverlay').style.visibility = 'visible';
  document.getElementById('bottomSheet').style.transform = 'translateY(0)';
  document.body.style.overflow = 'hidden';
}

function closeBottomSheet() {
  document.getElementById('bsOverlay').style.opacity = '0';
  document.getElementById('bsOverlay').style.visibility = 'hidden';
  document.getElementById('bottomSheet').style.transform = 'translateY(100%)';
  document.body.style.overflow = '';
}

function bsSwitchTab(tab) {
  bsCurrentTab = tab;
  var tabs = {company: 'bsTabCompany', personal: 'bsTabPersonal', direct: 'bsTabDirect'};
  Object.keys(tabs).forEach(function(k) {
    var el = document.getElementById(tabs[k]);
    if (k === tab) {
      el.style.background = '#111827'; el.style.color = 'white';
    } else {
      el.style.background = '#f3f4f6'; el.style.color = '#6b7280';
    }
  });

  if (tab === 'direct') {
    document.getElementById('bsSearchArea').style.display = 'none';
    document.getElementById('bsDirectArea').style.display = 'block';
  } else {
    document.getElementById('bsSearchArea').style.display = 'block';
    document.getElementById('bsDirectArea').style.display = 'none';
    document.getElementById('bsSearchResults').innerHTML = '<div style="text-align:center; padding:16px; color:#9ca3af; font-size:14px; font-weight:700;">불러오는 중...</div>';
    bsLoadVendors();
  }
}

function bsLoadVendors() {
  var results = document.getElementById('bsSearchResults');
  var vendorType = bsCurrentTab === 'company' ? 'company' : 'individual';
  
  fetch('/vendors/search?q=&vendor_type=' + vendorType)
    .then(function(res) { return res.json(); })
    .then(function(vendors) {
      results.innerHTML = '';
      if (vendors.length === 0) {
        results.innerHTML = '<div style="text-align:center; padding:16px; color:#9ca3af; font-size:14px; font-weight:700;">등록된 거래처가 없습니다.</div>';
        return;
      }
      vendors.forEach(function(v) {
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.onclick = function() { bsGoToNewProject(v.name); };
        btn.style.cssText = 'display:flex; align-items:center; gap:10px; width:100%; padding:14px 16px; border:1px solid #e5e7eb; border-radius:14px; background:white; cursor:pointer; font-family:inherit; text-align:left;';
        btn.innerHTML = '<span style="font-size:16px; font-weight:800; color:#111827;">' + v.name + '</span>' +
          (v.contact_name ? '<span style="font-size:13px; color:#9ca3af; margin-left:auto;">' + v.contact_name + '</span>' : '') +
          '<span style="color:#d1d5db;">→</span>';
        results.appendChild(btn);
      });
    });
}

function bsGoToNewProject(clientName) {
  if (!clientName || !clientName.trim()) { alert('거래처명을 입력해주세요.'); return; }
  
  fetch('<%= quick_create_projects_path %>', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
      'Accept': 'application/json'
    },
    body: JSON.stringify({
      date: bsSelectedDate,
      client_name: clientName.trim()
    })
  })
  .then(function(res) { return res.json(); })
  .then(function(data) {
    if (data.success) {
      window.location.reload();
    } else {
      alert(data.error || '일정 추가에 실패했습니다.');
    }
  })
  .catch(function(err) {
    console.error('Quick create error:', err);
    alert('네트워크 오류가 발생했습니다.');
  });
}
</script>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var csrfToken = document.querySelector('meta[name="csrf-token"]').content;

  // 날짜 셀 클릭 → 바텀시트 열기 (칩이 아닌 빈 영역 클릭 시)
  document.querySelectorAll('.calendar-date-cell').forEach(function(cell) {
    cell.addEventListener('click', function(e) {
      if (e.target.closest('.schedule-chip')) return; // 칩 클릭은 무시
      var dateStr = cell.dataset.date;
      if (dateStr) openBottomSheet(dateStr);
    });
  });

  // === 드래그 앤 드롭 (데스크톱) ===
  var draggedChip = null;
  var dragProjectId = null;
  var dragOldDate = null;

  document.querySelectorAll('.schedule-chip').forEach(function(chip) {
    chip.addEventListener('dragstart', function(e) {
      draggedChip = chip;
      dragProjectId = chip.dataset.projectId;
      dragOldDate = chip.dataset.date;
      chip.style.opacity = '0.4';
      e.dataTransfer.effectAllowed = 'move';
      e.dataTransfer.setData('text/plain', dragProjectId + '|' + dragOldDate);
    });

    chip.addEventListener('dragend', function(e) {
      chip.style.opacity = '1';
      draggedChip = null;
      clearDropHighlights();
    });

    // 칩 클릭 시 페이지 이동 (드래그와 구분)
    var clickTimer = null;
    chip.addEventListener('mousedown', function() { clickTimer = Date.now(); });
    chip.addEventListener('mouseup', function(e) {
      if (Date.now() - clickTimer < 200) {
        // 짧은 클릭은 onclick으로 처리됨
      }
    });
  });

  document.querySelectorAll('.calendar-date-cell').forEach(function(cell) {
    cell.addEventListener('dragover', function(e) {
      e.preventDefault();
      e.dataTransfer.dropEffect = 'move';
      cell.style.background = '#dbeafe';
    });

    cell.addEventListener('dragleave', function(e) {
      cell.style.background = '';
    });

    cell.addEventListener('drop', function(e) {
      e.preventDefault();
      cell.style.background = '';
      var newDate = cell.dataset.date;
      var data = e.dataTransfer.getData('text/plain').split('|');
      var projectId = data[0];
      var oldDate = data[1];
      if (oldDate === newDate) return;
      moveSchedule(projectId, oldDate, newDate);
    });
  });

  // === 터치 드래그 앤 드롭 (모바일) ===
  var touchChip = null;
  var touchProjectId = null;
  var touchOldDate = null;
  var touchClone = null;
  var touchStartTime = 0;
  var touchMoved = false;
  var longPressTimer = null;

  document.querySelectorAll('.schedule-chip').forEach(function(chip) {
    chip.addEventListener('touchstart', function(e) {
      touchStartTime = Date.now();
      touchMoved = false;
      var self = this;

      // 길게 누르면 드래그 시작
      longPressTimer = setTimeout(function() {
        touchChip = self;
        touchProjectId = self.dataset.projectId;
        touchOldDate = self.dataset.date;
        touchMoved = true;

        // 드래그 클론 생성
        touchClone = self.cloneNode(true);
        touchClone.style.position = 'fixed';
        touchClone.style.zIndex = '9999';
        touchClone.style.opacity = '0.85';
        touchClone.style.pointerEvents = 'none';
        touchClone.style.transform = 'scale(1.15)';
        touchClone.style.boxShadow = '0 4px 12px rgba(0,0,0,0.3)';
        touchClone.style.width = self.offsetWidth + 'px';
        document.body.appendChild(touchClone);

        self.style.opacity = '0.3';

        // 진동 피드백
        if (navigator.vibrate) navigator.vibrate(30);

        var touch = e.touches[0];
        touchClone.style.left = (touch.clientX - 30) + 'px';
        touchClone.style.top = (touch.clientY - 10) + 'px';
      }, 400);
    }, { passive: false });

    chip.addEventListener('touchmove', function(e) {
      if (!touchClone) {
        clearTimeout(longPressTimer);
        return;
      }
      e.preventDefault();
      var touch = e.touches[0];
      touchClone.style.left = (touch.clientX - 30) + 'px';
      touchClone.style.top = (touch.clientY - 10) + 'px';

      // 드롭 대상 하이라이트
      clearDropHighlights();
      var elem = document.elementFromPoint(touch.clientX, touch.clientY);
      if (elem) {
        var cell = elem.closest('.calendar-date-cell');
        if (cell) cell.style.background = '#dbeafe';
      }
    }, { passive: false });

    chip.addEventListener('touchend', function(e) {
      clearTimeout(longPressTimer);

      if (touchClone) {
        // 드롭 처리
        var touch = e.changedTouches[0];
        var elem = document.elementFromPoint(touch.clientX, touch.clientY);
        clearDropHighlights();

        if (elem) {
          var cell = elem.closest('.calendar-date-cell');
          if (cell && cell.dataset.date !== touchOldDate) {
            moveSchedule(touchProjectId, touchOldDate, cell.dataset.date);
          }
        }

        if (touchChip) touchChip.style.opacity = '1';
        touchClone.remove();
        touchClone = null;
        touchChip = null;
        e.preventDefault();
        return;
      }

      // 짧은 탭은 클릭으로 처리
      if (!touchMoved && Date.now() - touchStartTime < 300) {
        // onclick이 처리
      }
    });

    chip.addEventListener('touchcancel', function() {
      clearTimeout(longPressTimer);
      if (touchClone) {
        if (touchChip) touchChip.style.opacity = '1';
        touchClone.remove();
        touchClone = null;
        touchChip = null;
      }
    });
  });

  function clearDropHighlights() {
    document.querySelectorAll('.calendar-date-cell').forEach(function(c) {
      c.style.background = '';
    });
  }

  function moveSchedule(projectId, oldDate, newDate) {
    fetch('<%= move_schedule_projects_path %>', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': csrfToken,
        'Accept': 'application/json'
      },
      body: JSON.stringify({
        project_id: projectId,
        old_date: oldDate,
        new_date: newDate
      })
    })
    .then(function(res) { return res.json(); })
    .then(function(data) {
      if (data.success) {
        window.location.reload();
      } else {
        alert(data.error || '이동에 실패했습니다.');
      }
    })
    .catch(function(err) {
      console.error('Move error:', err);
      alert('네트워크 오류가 발생했습니다.');
    });
  }
});
</script>

<style>
/* 캘린더 애니메이션 클래스 */
@keyframes slideInRight {
  from { transform: translateX(30vw); opacity: 0; }
  to { transform: translateX(0); opacity: 1; }
}
@keyframes slideInLeft {
  from { transform: translateX(-30vw); opacity: 0; }
  to { transform: translateX(0); opacity: 1; }
}
.calendar-animate-in {
  /* 페이지 첫 로드 시 혹은 렌더 완료 시 부드럽게 등장 */
  animation: slideInRight 0.3s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
}
</style>

<script>
// 부드러운 네이티브 스와이프 로직
(function() {
  var swipeStartX = 0, swipeStartY = 0;
  var isSwiping = false;
  var hasMoved = false;
  var bodyElem = document.getElementById('calendarSwipeBody');

  // 첫 진입 시 애니메이션 효과를 위해 방향 캐치 (Turbo 환경 대응)
  // 이전/다음 클릭 여부에 따라 애니메이션 방향을 다르게 하려면 세션 스토리지 등을 활용할 수 있지만,
  // 여기서는 부드러운 스와이프 트랜지션 자체에 집중합니다.

  document.addEventListener('touchstart', function(e) {
    if (!bodyElem) bodyElem = document.getElementById('calendarSwipeBody');
    if (e.target.closest('.schedule-chip')) return;
    
    swipeStartX = e.touches[0].clientX;
    swipeStartY = e.touches[0].clientY;
    isSwiping = true;
    hasMoved = false;
    
    if (bodyElem) {
      bodyElem.style.transition = 'none'; // 드래그 중엔 트랜지션 해제
    }
  }, { passive: true });

  document.addEventListener('touchmove', function(e) {
    if (!isSwiping || !bodyElem) return;
    
    var dx = e.touches[0].clientX - swipeStartX;
    var dy = e.touches[0].clientY - swipeStartY;
    
    // 세로 스크롤이 더 크면 스와이프 인식 취소
    if (!hasMoved && Math.abs(dy) > Math.abs(dx)) {
      isSwiping = false;
      return;
    }
    
    // 약간의 움직임이 있을 때 가로 스와이프로 판단
    if (Math.abs(dx) > 10) {
      hasMoved = true;
      e.preventDefault(); // 스크롤(뒤로가기 제스처 등) 방지
      // 저항감(0.9)을 주어서 화면 끝까지 빠르게 안가게 함
      bodyElem.style.transform = 'translateX(' + (dx * 0.9) + 'px)';
    }
  }, { passive: false });

  document.addEventListener('touchend', function(e) {
    if (!isSwiping || !bodyElem) return;
    isSwiping = false;
    
    var dx = e.changedTouches[0].clientX - swipeStartX;
    
    // 복귀 / 슬라이드 아웃 애니메이션
    bodyElem.style.transition = 'transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s';
    
    // 넘길 만큼 पर्याप्त히 민 경우 처리
    if (dx < -60) {
      // ⬅️ 다음 달 (오른쪽에서 나타남)
      bodyElem.style.transform = 'translateX(-30vw)';
      bodyElem.style.opacity = '0';
      setTimeout(function() {
        var next = document.getElementById('nextMonthLink');
        if (next) next.click();
      }, 150);
    } else if (dx > 60) {
      // ➡️ 이전 달 (왼쪽에서 나타남)
      bodyElem.style.transform = 'translateX(30vw)';
      bodyElem.style.opacity = '0';
      setTimeout(function() {
        var prev = document.getElementById('prevMonthLink');
        if (prev) prev.click();
      }, 150);
    } else {
      // 덜 밀었을 때는 원래 자리로 탄력 복귀
      bodyElem.style.transform = 'translateX(0)';
      bodyElem.style.opacity = '1';
    }
  });
})();
</script>
