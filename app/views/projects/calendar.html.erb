<style>
.hide-scrollbar::-webkit-scrollbar { display: none; }
.hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
/* 캘린더 전용: app-content 스크롤 차단, 높이/패딩은 건드리지 않음 */
.app-content:has(#calendarRoot) {
  overflow: hidden !important;
  display: flex !important;
  flex-direction: column !important;
}
</style>

<script>
(function() {
  function applyCalendarLayout() {
    var root = document.getElementById('calendarRoot');
    if (!root) return;
    var appContent = document.querySelector('.app-content');
    if (appContent) {
      /* overflow만 제어 — height/paddingBottom은 절대 건드리지 않음 */
      appContent.style.overflow = 'hidden';
      appContent.style.display = 'flex';
      appContent.style.flexDirection = 'column';
    }
  }
  document.addEventListener('DOMContentLoaded', applyCalendarLayout);
  document.addEventListener('turbo:load', applyCalendarLayout);
})();
</script>

<div id="calendarRoot" style="display:flex; flex-direction:column; flex:1; overflow:hidden; min-height:0;">

  <div style="background:white; padding:18px 20px 14px 20px; border-bottom:1px solid #f0f0f0; position:sticky; top:0; z-index:30;">
    <div style="display:flex; justify-content:space-between; align-items:center;">
      <div style="font-size:24px; color:#111827; font-weight:900; cursor:pointer;" onclick="openDrawer()">☰</div>

      <div style="display:flex; align-items:center;">
        <img src="/logo.png" alt="일잘러" style="height:44px;">
      </div>

      <%= link_to notifications_path, style: "position:relative; text-decoration:none;" do %>
        <div style="font-size:20px;">🔔</div>
        <% if @unread_notifications_count.to_i > 0 %>
          <div style="
            position:absolute;
            top:-6px;
            right:-8px;
            min-width:18px;
            height:18px;
            padding:0 5px;
            border-radius:999px;
            background:#ef4444;
            color:white;
            font-size:11px;
            font-weight:900;
            display:flex;
            align-items:center;
            justify-content:center;
            box-sizing:border-box;
          ">
            <%= @unread_notifications_count %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>

  <div style="background:white; padding:14px 0 0 0; margin-bottom:0; flex:1; display:flex; flex-direction:column;">
    <div style="display:flex; justify-content:center; align-items:center; margin-bottom:14px; padding:0 16px; position:relative;">

      <!-- 센터 네이티브 월 선택기 -->
      <div style="position:relative; display:inline-flex; align-items:center; cursor:pointer;">
        <div id="monthLabel" style="font-size:20px; font-weight:900; color:#111827; letter-spacing:-0.5px;">
          <%= @calendar_year %>. <%= @calendar_month %> <span style="font-size:15px; margin-left:2px; vertical-align:middle;">⌃</span>
        </div>
        <input type="month" 
               value="<%= format('%04d-%02d', @calendar_year, @calendar_month) %>"
               onchange="window.location.href='<%= calendar_projects_path(status: @selected_status, view_mode: @view_mode, selected_date: @selected_date) %>&year=' + this.value.split('-')[0] + '&month=' + parseInt(this.value.split('-')[1])"
               style="position:absolute; top:0; left:0; width:100%; height:100%; opacity:0; cursor:pointer;" />
      </div>
    </div>

    <!-- 요일 헤더 (고정) -->
    <div style="display:grid; grid-template-columns:repeat(7, 1fr); border-bottom:1px solid #f0f0f0; background:white;">
      <% ["일", "월", "화", "수", "목", "금", "토"].each do |weekday| %>
        <% header_color = case weekday
            when "일" then "#ef4444"
            when "토" then "#3b82f6"
            else "#6b7280"
           end %>
        <div style="padding:12px 0; text-align:center; font-size:14px; font-weight:800; color:<%= header_color %>;">
          <%= weekday %>
        </div>
      <% end %>
    </div>

    <!-- 3패널 캐러셀 컨테이너 -->
    <div id="carouselViewport" style="overflow:hidden; background:white; flex:1; height:0; position:relative;">
      <div id="carouselTrack" style="display:flex; width:300%; height:100%; transform:translateX(-33.333%); will-change:transform;">
        
        <!-- 패널 0: 이전달 -->
        <div class="carousel-panel" data-year="<%= @prev_calendar[:year] %>" data-month="<%= @prev_calendar[:month] %>" style="width:33.333%; height:100%; flex-shrink:0; overflow-y:auto; -webkit-overflow-scrolling:touch; display:flex; flex-direction:column;">
          <% 
            saved_rows = @calendar_rows
            saved_month = @calendar_month
            saved_pbd = @projects_by_date
            saved_selected = @selected_date
            @calendar_rows = @prev_calendar[:rows]
            @calendar_month = @prev_calendar[:month]
            @projects_by_date = @prev_calendar[:projects_by_date]
            @selected_date = nil
          %>
          <%= render partial: 'projects/calendar_grid' %>
          <% 
            @calendar_rows = saved_rows
            @calendar_month = saved_month
            @projects_by_date = saved_pbd
            @selected_date = saved_selected
          %>
        </div>

        <!-- 패널 1: 현재달 (활성) -->
        <div class="carousel-panel" data-year="<%= @calendar_year %>" data-month="<%= @calendar_month %>" style="width:33.333%; height:100%; flex-shrink:0; overflow-y:auto; -webkit-overflow-scrolling:touch; display:flex; flex-direction:column;">
          <%= render partial: 'projects/calendar_grid' %>

          <!-- 캘린더 사용 가이드 -->
          <div style="padding:20px 16px 30px; background:linear-gradient(180deg, #f8fafc 0%, #f0f4ff 100%);">
            <div style="text-align:center; margin-bottom:16px;">
              <span style="font-size:13px; font-weight:900; color:#6366f1; background:#ede9fe; padding:5px 14px; border-radius:999px;">💡 캘린더 활용 TIP</span>
            </div>

            <div style="display:flex; flex-direction:column; gap:12px;">

              <!-- TIP 1: 드래그 앤 드롭 -->
              <div class="guide-card" style="display:flex; align-items:center; gap:14px; background:white; border-radius:16px; padding:14px 16px; box-shadow:0 2px 8px rgba(0,0,0,0.04); border:1px solid #e5e7eb; animation: guideSlideIn 0.5s ease-out both;">
                <div style="font-size:28px; animation: guideBounce 2s ease-in-out infinite;">🖐️</div>
                <div>
                  <div style="font-size:14px; font-weight:900; color:#111827; margin-bottom:2px;">현장을 드래그해서 이동</div>
                  <div style="font-size:12px; color:#6b7280; line-height:1.5;">거래처명을 길게 누른 후 원하는 날짜로<br>끌어다 놓으면 일정이 이동돼요</div>
                </div>
              </div>

              <!-- TIP 2: 클릭하여 수정 -->
              <div class="guide-card" style="display:flex; align-items:center; gap:14px; background:white; border-radius:16px; padding:14px 16px; box-shadow:0 2px 8px rgba(0,0,0,0.04); border:1px solid #e5e7eb; animation: guideSlideIn 0.5s ease-out 0.1s both;">
                <div style="font-size:28px; animation: guidePulse 2s ease-in-out infinite;">👆</div>
                <div>
                  <div style="font-size:14px; font-weight:900; color:#111827; margin-bottom:2px;">거래처명 클릭 → 현장 수정</div>
                  <div style="font-size:12px; color:#6b7280; line-height:1.5;">캘린더의 거래처 이름을 탭하면<br>해당 현장 상세 페이지로 이동해요</div>
                </div>
              </div>

              <!-- TIP 3: 좌우 스와이프 -->
              <div class="guide-card" style="display:flex; align-items:center; gap:14px; background:white; border-radius:16px; padding:14px 16px; box-shadow:0 2px 8px rgba(0,0,0,0.04); border:1px solid #e5e7eb; animation: guideSlideIn 0.5s ease-out 0.2s both;">
                <div style="font-size:28px; animation: guideSwipe 2.5s ease-in-out infinite;">👈👉</div>
                <div>
                  <div style="font-size:14px; font-weight:900; color:#111827; margin-bottom:2px;">좌우 스와이프로 월 이동</div>
                  <div style="font-size:12px; color:#6b7280; line-height:1.5;">캘린더를 좌우로 밀면<br>이전달/다음달로 빠르게 이동해요</div>
                </div>
              </div>

              <!-- TIP 4: 날짜 클릭 -->
              <div class="guide-card" style="display:flex; align-items:center; gap:14px; background:white; border-radius:16px; padding:14px 16px; box-shadow:0 2px 8px rgba(0,0,0,0.04); border:1px solid #e5e7eb; animation: guideSlideIn 0.5s ease-out 0.3s both;">
                <div style="font-size:28px; animation: guidePulse 2.5s ease-in-out 0.5s infinite;">📅</div>
                <div>
                  <div style="font-size:14px; font-weight:900; color:#111827; margin-bottom:2px;">날짜 클릭 → 간편 현장 추가</div>
                  <div style="font-size:12px; color:#6b7280; line-height:1.5;">빈 날짜를 탭하면 해당 날짜에<br>바로 현장을 추가할 수 있어요</div>
                </div>
              </div>

            </div>
          </div>
          <style>
            @keyframes guideSlideIn {
              from { opacity:0; transform:translateY(12px); }
              to { opacity:1; transform:translateY(0); }
            }
            @keyframes guideBounce {
              0%, 100% { transform:translateY(0); }
              50% { transform:translateY(-4px); }
            }
            @keyframes guidePulse {
              0%, 100% { transform:scale(1); }
              50% { transform:scale(1.15); }
            }
            @keyframes guideSwipe {
              0%, 100% { transform:translateX(0); }
              25% { transform:translateX(-5px); }
              75% { transform:translateX(5px); }
            }
          </style>
        </div>

        <!-- 패널 2: 다음달 -->
        <div class="carousel-panel" data-year="<%= @next_calendar[:year] %>" data-month="<%= @next_calendar[:month] %>" style="width:33.333%; height:100%; flex-shrink:0; overflow-y:auto; -webkit-overflow-scrolling:touch; display:flex; flex-direction:column;">
          <% 
            @calendar_rows = @next_calendar[:rows]
            @calendar_month = @next_calendar[:month]
            @projects_by_date = @next_calendar[:projects_by_date]
            @selected_date = nil
          %>
          <%= render partial: 'projects/calendar_grid' %>
          <% 
            @calendar_rows = saved_rows
            @calendar_month = saved_month
            @projects_by_date = saved_pbd
            @selected_date = saved_selected
          %>
        </div>

      </div>
    </div>

  </div>
</div>

<!-- 캐러셀 상태 (JS에서 사용) -->
<script>
  var CAROUSEL_STATE = {
    currentYear: <%= @calendar_year %>,
    currentMonth: <%= @calendar_month %>,
    status: '<%= @selected_status || "" %>',
    panelUrl: '<%= calendar_panel_projects_path %>'
  };
  var TODAY_YEAR = <%= Date.current.year %>;
  var TODAY_MONTH = <%= Date.current.month %>;
</script>

<!-- 오늘로 돌아가기 버튼 -->
<div id="goTodayBtn" onclick="window.location.href='<%= calendar_projects_path(status: @selected_status) %>'" style="
  display:none;
  position:fixed;
  bottom:100px;
  left:50%;
  transform:translateX(-50%);
  z-index:40;
  background:#111827;
  color:white;
  padding:10px 20px;
  border-radius:999px;
  font-size:13px;
  font-weight:900;
  box-shadow:0 4px 16px rgba(0,0,0,0.25);
  cursor:pointer;
  transition:opacity 0.3s, transform 0.3s;
  white-space:nowrap;
">
  📅 오늘로
</div>

<!-- Bottom Sheet Overlay -->
<div id="bsOverlay" onclick="closeBottomSheet()" style="
  position:fixed; top:0; left:0; right:0; bottom:0;
  background:rgba(0,0,0,0.5); z-index:500;
  opacity:0; visibility:hidden;
  transition:all 0.3s ease;
"></div>

<!-- Bottom Sheet - 거래처 선택 -->
<div id="bottomSheet" style="
  position:fixed; left:0; right:0; bottom:0;
  background:white; z-index:510;
  border-radius:24px 24px 0 0;
  box-shadow:0 -4px 30px rgba(0,0,0,0.15);
  transform:translateY(100%);
  transition:transform 0.35s cubic-bezier(0.4,0,0.2,1);
  max-height:70vh; overflow-y:auto;
  padding-bottom:env(safe-area-inset-bottom);
">
  <div style="display:flex; justify-content:center; padding:12px 0 4px 0;">
    <div style="width:40px; height:4px; border-radius:99px; background:#d1d5db;"></div>
  </div>

  <div style="padding:8px 20px 14px 20px; display:flex; justify-content:space-between; align-items:center;">
    <div>
      <div id="bsTitle" style="font-size:20px; font-weight:900; color:#111827;">현장 추가</div>
      <div id="bsSubtitle" style="font-size:13px; font-weight:700; color:#9ca3af; margin-top:2px;"></div>
    </div>
    <div onclick="closeBottomSheet()" style="font-size:22px; color:#9ca3af; cursor:pointer; padding:4px 8px;">✕</div>
  </div>

  <div style="padding:0 16px 20px 16px;">
    <div style="display:flex; gap:8px; margin-bottom:14px;">
      <button type="button" id="bsTabCompany" onclick="bsSwitchTab('company')" style="flex:1; padding:10px; border:none; border-radius:12px; font-size:14px; font-weight:800; cursor:pointer; background:#111827; color:white;">🏢 업체</button>
      <button type="button" id="bsTabPersonal" onclick="bsSwitchTab('personal')" style="flex:1; padding:10px; border:none; border-radius:12px; font-size:14px; font-weight:800; cursor:pointer; background:#f3f4f6; color:#6b7280;">👤 개인</button>
      <button type="button" id="bsTabDirect" onclick="bsSwitchTab('direct')" style="flex:1; padding:10px; border:none; border-radius:12px; font-size:14px; font-weight:800; cursor:pointer; background:#f3f4f6; color:#6b7280;">✏️ 직접입력</button>
    </div>

    <div id="bsSearchArea">
      <div id="bsSearchResults" style="display:flex; flex-direction:column; gap:6px; max-height:260px; overflow-y:auto; padding-bottom:10px;"></div>
    </div>

    <div id="bsDirectArea" style="display:none;">
      <input type="text" id="bsDirectName" placeholder="거래처명을 입력하세요"
        style="width:100%; padding:14px 16px; border:1px solid #dcdfe4; border-radius:12px; font-size:15px; box-sizing:border-box; margin-bottom:10px;">
      <button type="button" onclick="bsGoToNewProject(document.getElementById('bsDirectName').value)"
        style="width:100%; padding:14px; border:none; border-radius:12px; background:#2563eb; color:white; font-size:16px; font-weight:900; cursor:pointer;">
        일정에 바로 추가하기
      </button>
    </div>
  </div>
</div>

<script>
var bsSelectedDate = null;
var bsCurrentTab = 'company';

function openBottomSheet(dateStr) {
  bsSelectedDate = dateStr;
  var parts = dateStr.split('-');
  document.getElementById('bsSubtitle').textContent = parts[0] + '년 ' + parseInt(parts[1]) + '월 ' + parseInt(parts[2]) + '일';
  document.getElementById('bsSearchResults').innerHTML = '';
  document.getElementById('bsDirectName').value = '';
  bsSwitchTab('company');

  document.getElementById('bsOverlay').style.opacity = '1';
  document.getElementById('bsOverlay').style.visibility = 'visible';
  document.getElementById('bottomSheet').style.transform = 'translateY(0)';
  document.body.style.overflow = 'hidden';
}

function closeBottomSheet() {
  document.getElementById('bsOverlay').style.opacity = '0';
  document.getElementById('bsOverlay').style.visibility = 'hidden';
  document.getElementById('bottomSheet').style.transform = 'translateY(100%)';
  document.body.style.overflow = '';
}

function bsSwitchTab(tab) {
  bsCurrentTab = tab;
  var tabs = {company: 'bsTabCompany', personal: 'bsTabPersonal', direct: 'bsTabDirect'};
  Object.keys(tabs).forEach(function(k) {
    var el = document.getElementById(tabs[k]);
    if (k === tab) {
      el.style.background = '#111827'; el.style.color = 'white';
    } else {
      el.style.background = '#f3f4f6'; el.style.color = '#6b7280';
    }
  });

  if (tab === 'direct') {
    document.getElementById('bsSearchArea').style.display = 'none';
    document.getElementById('bsDirectArea').style.display = 'block';
  } else {
    document.getElementById('bsSearchArea').style.display = 'block';
    document.getElementById('bsDirectArea').style.display = 'none';
    document.getElementById('bsSearchResults').innerHTML = '<div style="text-align:center; padding:16px; color:#9ca3af; font-size:14px; font-weight:700;">불러오는 중...</div>';
    bsLoadVendors();
  }
}

function bsLoadVendors() {
  var results = document.getElementById('bsSearchResults');
  var vendorType = bsCurrentTab === 'company' ? 'company' : 'individual';
  
  fetch('/vendors/search?q=&vendor_type=' + vendorType)
    .then(function(res) { return res.json(); })
    .then(function(vendors) {
      results.innerHTML = '';
      if (vendors.length === 0) {
        results.innerHTML = '<div style="text-align:center; padding:16px; color:#9ca3af; font-size:14px; font-weight:700;">등록된 거래처가 없습니다.</div>';
        return;
      }
      vendors.forEach(function(v) {
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.onclick = function() { bsGoToNewProject(v.name); };
        btn.style.cssText = 'display:flex; align-items:center; gap:10px; width:100%; padding:14px 16px; border:1px solid #e5e7eb; border-radius:14px; background:white; cursor:pointer; font-family:inherit; text-align:left;';
        btn.innerHTML = '<span style="font-size:16px; font-weight:800; color:#111827;">' + v.name + '</span>' +
          (v.contact_name ? '<span style="font-size:13px; color:#9ca3af; margin-left:auto;">' + v.contact_name + '</span>' : '') +
          '<span style="color:#d1d5db;">→</span>';
        results.appendChild(btn);
      });
    });
}

function bsGoToNewProject(clientName) {
  if (!clientName || !clientName.trim()) { alert('거래처명을 입력해주세요.'); return; }
  
  fetch('<%= quick_create_projects_path %>', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
      'Accept': 'application/json'
    },
    body: JSON.stringify({
      date: bsSelectedDate,
      client_name: clientName.trim()
    })
  })
  .then(function(res) { return res.json(); })
  .then(function(data) {
    if (data.success) {
      window.location.reload();
    } else {
      alert(data.error || '일정 추가에 실패했습니다.');
    }
  })
  .catch(function(err) {
    console.error('Quick create error:', err);
    alert('네트워크 오류가 발생했습니다.');
  });
}
</script>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var csrfToken = document.querySelector('meta[name="csrf-token"]').content;

  // 날짜 셀 클릭 → 바텀시트 열기 (칩이 아닌 빈 영역 클릭 시)
  document.querySelectorAll('.calendar-date-cell').forEach(function(cell) {
    cell.addEventListener('click', function(e) {
      if (e.target.closest('.schedule-chip')) return; // 칩 클릭은 무시
      var dateStr = cell.dataset.date;
      if (dateStr) openBottomSheet(dateStr);
    });
  });

  // === 드래그 앤 드롭 (데스크톱) ===
  var draggedChip = null;
  var dragProjectId = null;
  var dragOldDate = null;

  document.querySelectorAll('.schedule-chip').forEach(function(chip) {
    chip.addEventListener('dragstart', function(e) {
      draggedChip = chip;
      dragProjectId = chip.dataset.projectId;
      dragOldDate = chip.dataset.date;
      chip.style.opacity = '0.4';
      e.dataTransfer.effectAllowed = 'move';
      e.dataTransfer.setData('text/plain', dragProjectId + '|' + dragOldDate);
    });

    chip.addEventListener('dragend', function(e) {
      chip.style.opacity = '1';
      draggedChip = null;
      clearDropHighlights();
    });

    // 칩 클릭 시 페이지 이동 (드래그와 구분)
    var clickTimer = null;
    chip.addEventListener('mousedown', function() { clickTimer = Date.now(); });
    chip.addEventListener('mouseup', function(e) {
      if (Date.now() - clickTimer < 200) {
        // 짧은 클릭은 onclick으로 처리됨
      }
    });
  });

  document.querySelectorAll('.calendar-date-cell').forEach(function(cell) {
    cell.addEventListener('dragover', function(e) {
      e.preventDefault();
      e.dataTransfer.dropEffect = 'move';
      cell.style.background = '#dbeafe';
    });

    cell.addEventListener('dragleave', function(e) {
      cell.style.background = '';
    });

    cell.addEventListener('drop', function(e) {
      e.preventDefault();
      cell.style.background = '';
      var newDate = cell.dataset.date;
      var data = e.dataTransfer.getData('text/plain').split('|');
      var projectId = data[0];
      var oldDate = data[1];
      if (oldDate === newDate) return;
      moveSchedule(projectId, oldDate, newDate);
    });
  });

  // === 터치 드래그 앤 드롭 (모바일) ===
  var touchChip = null;
  var touchProjectId = null;
  var touchOldDate = null;
  var touchClone = null;
  var touchStartTime = 0;
  var touchMoved = false;
  var longPressTimer = null;

  document.querySelectorAll('.schedule-chip').forEach(function(chip) {
    chip.addEventListener('touchstart', function(e) {
      touchStartTime = Date.now();
      touchMoved = false;
      var self = this;

      // 길게 누르면 드래그 시작
      longPressTimer = setTimeout(function() {
        touchChip = self;
        touchProjectId = self.dataset.projectId;
        touchOldDate = self.dataset.date;
        touchMoved = true;

        // 드래그 클론 생성
        touchClone = self.cloneNode(true);
        touchClone.style.position = 'fixed';
        touchClone.style.zIndex = '9999';
        touchClone.style.opacity = '0.85';
        touchClone.style.pointerEvents = 'none';
        touchClone.style.transform = 'scale(1.15)';
        touchClone.style.boxShadow = '0 4px 12px rgba(0,0,0,0.3)';
        touchClone.style.width = self.offsetWidth + 'px';
        document.body.appendChild(touchClone);

        self.style.opacity = '0.3';

        // 진동 피드백
        if (navigator.vibrate) navigator.vibrate(30);

        var touch = e.touches[0];
        touchClone.style.left = (touch.clientX - 30) + 'px';
        touchClone.style.top = (touch.clientY - 10) + 'px';
      }, 400);
    }, { passive: false });

    chip.addEventListener('touchmove', function(e) {
      if (!touchClone) {
        clearTimeout(longPressTimer);
        return;
      }
      e.preventDefault();
      var touch = e.touches[0];
      touchClone.style.left = (touch.clientX - 30) + 'px';
      touchClone.style.top = (touch.clientY - 10) + 'px';

      // 드롭 대상 하이라이트
      clearDropHighlights();
      var elem = document.elementFromPoint(touch.clientX, touch.clientY);
      if (elem) {
        var cell = elem.closest('.calendar-date-cell');
        if (cell) cell.style.background = '#dbeafe';
      }
    }, { passive: false });

    chip.addEventListener('touchend', function(e) {
      clearTimeout(longPressTimer);

      if (touchClone) {
        // 드롭 처리
        var touch = e.changedTouches[0];
        var elem = document.elementFromPoint(touch.clientX, touch.clientY);
        clearDropHighlights();

        if (elem) {
          var cell = elem.closest('.calendar-date-cell');
          if (cell && cell.dataset.date !== touchOldDate) {
            moveSchedule(touchProjectId, touchOldDate, cell.dataset.date);
          }
        }

        if (touchChip) touchChip.style.opacity = '1';
        touchClone.remove();
        touchClone = null;
        touchChip = null;
        e.preventDefault();
        return;
      }

      // 짧은 탭은 클릭으로 처리
      if (!touchMoved && Date.now() - touchStartTime < 300) {
        // onclick이 처리
      }
    });

    chip.addEventListener('touchcancel', function() {
      clearTimeout(longPressTimer);
      if (touchClone) {
        if (touchChip) touchChip.style.opacity = '1';
        touchClone.remove();
        touchClone = null;
        touchChip = null;
      }
    });
  });

  function clearDropHighlights() {
    document.querySelectorAll('.calendar-date-cell').forEach(function(c) {
      c.style.background = '';
    });
  }

  function moveSchedule(projectId, oldDate, newDate) {
    fetch('<%= move_schedule_projects_path %>', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': csrfToken,
        'Accept': 'application/json'
      },
      body: JSON.stringify({
        project_id: projectId,
        old_date: oldDate,
        new_date: newDate
      })
    })
    .then(function(res) { return res.json(); })
    .then(function(data) {
      if (data.success) {
        window.location.reload();
      } else {
        alert(data.error || '이동에 실패했습니다.');
      }
    })
    .catch(function(err) {
      console.error('Move error:', err);
      alert('네트워크 오류가 발생했습니다.');
    });
  }
});
</script>

<style>
#carouselTrack { transition: none; }
#carouselTrack.animating { transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
.carousel-panel { height: 100%; overflow-y: auto; -webkit-overflow-scrolling: touch; }
</style>

<script>
// === 진짜 3패널 캐러셀 엔진 ===
(function() {
  var track = document.getElementById('carouselTrack');
  var viewport = document.getElementById('carouselViewport');
  if (!track || !viewport) return;

  var swipeStartX = 0, swipeStartY = 0;
  var isSwiping = false;
  var hasMoved = false;
  var isAnimating = false;
  var BASE_OFFSET = -33.333; // 중앙 패널 표시 위치 (%)

  function getPanels() {
    return track.querySelectorAll('.carousel-panel');
  }

  function getMonthInfo(year, month, delta) {
    var d = new Date(year, month - 1 + delta, 1);
    return { year: d.getFullYear(), month: d.getMonth() + 1 };
  }

  function updateMonthLabel() {
    var label = document.getElementById('monthLabel');
    if (label) {
      label.innerHTML = CAROUSEL_STATE.currentYear + '. ' + CAROUSEL_STATE.currentMonth +
        ' <span style="font-size:15px; margin-left:2px; vertical-align:middle;">⌃</span>';
    }
    // month picker 값도 업데이트
    var picker = viewport.closest('div')?.querySelector('input[type="month"]');
    if (picker) {
      picker.value = CAROUSEL_STATE.currentYear + '-' + String(CAROUSEL_STATE.currentMonth).padStart(2, '0');
    }
    // 오늘로 버튼 표시/숨김
    var todayBtn = document.getElementById('goTodayBtn');
    if (todayBtn) {
      var isCurrentMonth = (CAROUSEL_STATE.currentYear === TODAY_YEAR && CAROUSEL_STATE.currentMonth === TODAY_MONTH);
      todayBtn.style.display = isCurrentMonth ? 'none' : 'block';
    }
  }

  function fetchPanel(year, month, callback) {
    var url = CAROUSEL_STATE.panelUrl + '?year=' + year + '&month=' + month;
    if (CAROUSEL_STATE.status) url += '&status=' + encodeURIComponent(CAROUSEL_STATE.status);

    fetch(url, { headers: { 'Accept': 'text/html' } })
      .then(function(res) { return res.text(); })
      .then(function(html) { callback(html, year, month); })
      .catch(function(err) { console.error('Panel fetch error:', err); });
  }

  function slideToNext() {
    if (isAnimating) return;
    isAnimating = true;
    track.classList.add('animating');
    track.style.transform = 'translateX(-66.666%)';

    track.addEventListener('transitionend', function onEnd() {
      track.removeEventListener('transitionend', onEnd);
      finishSlideNext();
    });

    // 안전장치: 트랜지션이 끝나지 않을 경우
    setTimeout(function() { if (isAnimating) finishSlideNext(); }, 400);
  }

  function finishSlideNext() {
    if (!isAnimating) return;
    isAnimating = false;
    track.classList.remove('animating');

    var panels = getPanels();
    CAROUSEL_STATE.currentYear = parseInt(panels[2].dataset.year);
    CAROUSEL_STATE.currentMonth = parseInt(panels[2].dataset.month);

    // 깜빡임 방지: DOM 변경 동안 숨김
    track.style.visibility = 'hidden';
    panels[0].remove();
    track.style.transform = 'translateX(' + BASE_OFFSET + '%)';
    track.offsetHeight; // 강제 리플로우
    track.style.visibility = '';

    updateMonthLabel();
    rebindCellEvents();

    // 새로운 다음달 패널을 AJAX로 로드
    var futureMonth = getMonthInfo(CAROUSEL_STATE.currentYear, CAROUSEL_STATE.currentMonth, 1);
    fetchPanel(futureMonth.year, futureMonth.month, function(html, y, m) {
      var newPanel = document.createElement('div');
      newPanel.className = 'carousel-panel';
      newPanel.dataset.year = y;
      newPanel.dataset.month = m;
      newPanel.style.cssText = 'width:33.333%; height:100%; flex-shrink:0; overflow-y:auto; -webkit-overflow-scrolling:touch; display:flex; flex-direction:column;';
      newPanel.innerHTML = html;
      track.appendChild(newPanel);
      rebindCellEvents();
    });
  }

  function slideToPrev() {
    if (isAnimating) return;
    isAnimating = true;
    track.classList.add('animating');
    track.style.transform = 'translateX(0%)';

    track.addEventListener('transitionend', function onEnd() {
      track.removeEventListener('transitionend', onEnd);
      finishSlidePrev();
    });

    setTimeout(function() { if (isAnimating) finishSlidePrev(); }, 400);
  }

  function finishSlidePrev() {
    if (!isAnimating) return;
    isAnimating = false;
    track.classList.remove('animating');

    var panels = getPanels();
    CAROUSEL_STATE.currentYear = parseInt(panels[0].dataset.year);
    CAROUSEL_STATE.currentMonth = parseInt(panels[0].dataset.month);

    // 패널 제거 후 2개만 남음: [현재월, 다음월]
    // translateX(0%)로 panel 0(현재월)을 표시해야 함
    track.style.visibility = 'hidden';
    panels[panels.length - 1].remove();
    track.style.transform = 'translateX(0%)';
    track.offsetHeight;
    track.style.visibility = '';

    updateMonthLabel();
    rebindCellEvents();

    // 새로운 이전달 패널을 AJAX로 로드
    var pastMonth = getMonthInfo(CAROUSEL_STATE.currentYear, CAROUSEL_STATE.currentMonth, -1);
    fetchPanel(pastMonth.year, pastMonth.month, function(html, y, m) {
      var newPanel = document.createElement('div');
      newPanel.className = 'carousel-panel';
      newPanel.dataset.year = y;
      newPanel.dataset.month = m;
      newPanel.style.cssText = 'width:33.333%; flex-shrink:0; display:flex; flex-direction:column;';
      newPanel.innerHTML = html;
      // prepend 시 기존 패널이 밀리므로 transform도 동시에 업데이트
      track.style.visibility = 'hidden';
      track.insertBefore(newPanel, track.firstChild);
      track.style.transform = 'translateX(' + BASE_OFFSET + '%)';
      track.offsetHeight;
      track.style.visibility = '';
      rebindCellEvents();
    });
  }

  function snapBack() {
    track.classList.add('animating');
    track.style.transform = 'translateX(' + BASE_OFFSET + '%)';
    setTimeout(function() { track.classList.remove('animating'); }, 350);
  }

  // 터치 이벤트
  viewport.addEventListener('touchstart', function(e) {
    if (isAnimating) return;
    if (e.target.closest('.schedule-chip')) return;

    swipeStartX = e.touches[0].clientX;
    swipeStartY = e.touches[0].clientY;
    isSwiping = true;
    hasMoved = false;
    track.classList.remove('animating');
  }, { passive: true });

  viewport.addEventListener('touchmove', function(e) {
    if (!isSwiping || isAnimating) return;

    var dx = e.touches[0].clientX - swipeStartX;
    var dy = e.touches[0].clientY - swipeStartY;

    if (!hasMoved && Math.abs(dy) > Math.abs(dx)) {
      isSwiping = false;
      return;
    }

    if (Math.abs(dx) > 10) {
      hasMoved = true;
      e.preventDefault();
      // 뷰포트 너비 기준 퍼센트 변환
      var vpWidth = viewport.offsetWidth;
      var pxToPct = (dx / vpWidth) * 100;
      // 3패널 트랙에서는 1/3씩 이동
      var shiftPct = pxToPct / 3;
      track.style.transform = 'translateX(' + (BASE_OFFSET + shiftPct) + '%)';
    }
  }, { passive: false });

  viewport.addEventListener('touchend', function(e) {
    if (!isSwiping || isAnimating) return;
    isSwiping = false;

    var dx = e.changedTouches[0].clientX - swipeStartX;

    if (dx < -60) {
      slideToNext();
    } else if (dx > 60) {
      slideToPrev();
    } else {
      snapBack();
    }
  });

  // 셀 클릭 이벤트 재바인드 (AJAX로 새 패널 로드 후)
  function rebindCellEvents() {
    var centerPanel = getPanels()[1];
    if (!centerPanel) return;
    
    centerPanel.querySelectorAll('.calendar-date-cell').forEach(function(cell) {
      // 이미 바인드된 경우 스킵
      if (cell._bound) return;
      cell._bound = true;
      cell.addEventListener('click', function(e) {
        if (e.target.closest('.schedule-chip')) return;
        var dateStr = cell.dataset.date;
        if (dateStr && typeof openBottomSheet === 'function') openBottomSheet(dateStr);
      });
    });
  }

  // 최초 바인드
  rebindCellEvents();
})();
</script>

