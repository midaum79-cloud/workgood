<div style="background:white; padding:18px 20px 14px 20px; border-bottom:1px solid #ececec; position:sticky; top:0; z-index:50;">
  <div style="display:flex; justify-content:space-between; align-items:center;">
    <%= link_to "←", project_path(@project), style: "font-size:24px; color:#111; text-decoration:none; font-weight:800;" %>

    <div style="display:flex; align-items:center; min-width:0; flex:1; justify-content:center; padding:0 8px;">
      <span style="
        font-size: clamp(13px, 4.5vw, 22px);
        font-weight:900;
        color:<%= @project.theme_color_hex %>;
        white-space:nowrap;
        overflow:hidden;
        text-overflow:ellipsis;
        max-width:100%;
        display:block;
      "><%= @client_name %> 일정표</span>
    </div>

    <%= link_to notifications_path, style: "position:relative; text-decoration:none;" do %>
      <div style="font-size:20px;">🔔</div>
      <% if @unread_notifications_count.to_i > 0 %>
        <div style="
          position:absolute;
          top:-6px;
          right:-8px;
          min-width:18px;
          height:18px;
          padding:0 5px;
          border-radius:999px;
          background:#ef4444;
          color:white;
          font-size:11px;
          font-weight:900;
          display:flex;
          align-items:center;
          justify-content:center;
          box-sizing:border-box;
        ">
          <%= @unread_notifications_count %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>

<div style="min-height:100dvh; background:white; padding:0 0 80px 0; display:flex; flex-direction:column;">
  <div style="background:white; padding:14px 0 0 0; margin-bottom:0; flex:1; display:flex; flex-direction:column;">
    <div style="display:flex; justify-content:center; align-items:center; margin-bottom:14px; padding:0 16px; position:relative;">
      
      <!-- 스와이프 로직용 숨김 링크 -->
      <%= link_to "", project_calendar_project_path(@project, view_mode: @view_mode, year: @prev_month.year, month: @prev_month.month, selected_date: @selected_date), id: "prevMonthLink", style: "display:none;" %>
      <%= link_to "", project_calendar_project_path(@project, view_mode: @view_mode, year: @next_month.year, month: @next_month.month, selected_date: @selected_date), id: "nextMonthLink", style: "display:none;" %>

      <!-- 센터 네이티브 월 선택기 -->
      <div style="position:relative; display:inline-flex; align-items:center; cursor:pointer;">
        <div style="font-size:20px; font-weight:900; color:#111827; letter-spacing:-0.5px;">
          <%= @calendar_year %>. <%= @calendar_month %> <span style="font-size:15px; margin-left:2px; vertical-align:middle;">⌃</span>
        </div>
        <input type="month" 
               value="<%= format('%04d-%02d', @calendar_year, @calendar_month) %>"
               onchange="window.location.href='<%= project_calendar_project_path(@project, view_mode: @view_mode, selected_date: @selected_date) %><%='?'unless project_calendar_project_path(@project, view_mode: @view_mode, selected_date: @selected_date).include?('?')%><%='&'if project_calendar_project_path(@project, view_mode: @view_mode, selected_date: @selected_date).include?('?')%>year=' + this.value.split('-')[0] + '&month=' + parseInt(this.value.split('-')[1])"
               style="position:absolute; top:0; left:0; width:100%; height:100%; opacity:0; cursor:pointer;" />
      </div>
    </div>





    <div style="overflow:hidden; background:white; flex:1; display:flex; flex-direction:column; position:relative; touch-action:pan-y;">
      <div id="calendarSwipeBody" class="calendar-animate-in" style="flex:1; display:flex; flex-direction:column; width:100%; will-change:transform;">
        <div style="display:grid; grid-template-columns:repeat(7, 1fr); border-bottom:1px solid #f0f0f0; background:white;">
        <% ["일", "월", "화", "수", "목", "금", "토"].each do |weekday| %>
          <% header_color = case weekday
              when "일" then "#ef4444"
              when "토" then "#3b82f6"
              else "#6b7280"
             end %>
          <div style="padding:12px 0; text-align:center; font-size:14px; font-weight:800; color:<%= header_color %>;">
            <%= weekday %>
          </div>
        <% end %>
      </div>

      <% @calendar_rows.each_with_index do |row_days, row_index| %>
        <div style="flex:1; border-bottom:<%= row_index == @calendar_rows.length - 1 ? 'none' : '1px solid #f3f4f6' %>; display:flex; flex-direction:column;">
          <div style="display:grid; grid-template-columns:repeat(7, 1fr);">
            <% row_days.each do |day| %>
              <% is_current_month = (day.month == @calendar_month) %>
              <% is_selected = (day == @selected_date) %>
              <% day_projects = @projects_by_date[day] || [] %>

              <% date_text_color = if !is_current_month
                  '#9ca3af'
                elsif day.sunday?
                  '#ef4444'
                elsif day.saturday?
                  '#3b82f6'
                else
                  '#111827'
                end %>

              <div class="calendar-date-cell"
                   data-date="<%= day.to_s %>"
                   style="
                    min-height:60px;
                    border-right:none;
                    padding:3px 2px 2px 2px;
                    box-sizing:border-box;
                    background:<%= is_selected ? '#f6e8b0' : 'white' %>;
                    display:flex;
                    flex-direction:column;
                    align-items:stretch;
                    cursor:pointer;
                    transition: background 0.2s;
                  ">
                
                <div style="display:flex; justify-content:center; margin-bottom:2px;">
                  <span style="
                    display:inline-flex;
                    align-items:center;
                    justify-content:center;
                    width:24px;
                    height:24px;
                    border-radius:50%;
                    font-size:13px;
                    font-weight:900;
                    color:<%= is_selected ? 'white' : date_text_color %>;
                    background:<%= is_selected ? '#f59e0b' : 'transparent' %>;
                  "><%= format('%02d', day.day) %></span>
                </div>

                <% if is_current_month %>
                  <% day_projects.each do |proj| %>
                    <div class="schedule-chip"
                         style="
                          font-size:9px;
                          font-weight:800;
                          color:<%= proj.theme_color_hex %>;
                          background:<%= proj.theme_color_hex %>1a;
                          border:1px solid <%= proj.theme_color_hex %>4d;
                          border-radius:4px;
                          padding:2px 3px;
                          margin-bottom:1px;
                          overflow:hidden;
                          white-space:nowrap;
                          text-overflow:ellipsis;
                          user-select:none;
                          -webkit-user-select:none;
                         ">
                      <%= proj.client_name.presence || proj.project_name %>
                    </div>
                  <% end %>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
      </div>
    </div>


  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var csrfToken = document.querySelector('meta[name="csrf-token"]').content;

  // 날짜 셀 클릭 시 일정 토글
  document.querySelectorAll('.calendar-date-cell').forEach(function(cell) {
    cell.addEventListener('click', function(e) {
      if (cell.dataset.isProcessing === "true") return; // 중복 방지
      
      var dateStr = cell.dataset.date;
      if (!dateStr) return;
      
      // 약간의 시각적 피드백
      cell.dataset.isProcessing = "true";
      cell.style.opacity = "0.5";

      fetch('<%= project_path(@project) %>/toggle_schedule', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': csrfToken,
          'Accept': 'application/json'
        },
        body: JSON.stringify({ date: dateStr })
      })
      .then(function(res) { return res.json(); })
      .then(function(data) {
        if (data.success) {
          window.location.reload(); 
        } else {
          alert('에러가 발생했습니다: ' + (data.error || ''));
          cell.dataset.isProcessing = "false";
          cell.style.opacity = "1";
        }
      })
      .catch(function(err) {
        alert('네트워크 오류가 발생했습니다.');
        cell.dataset.isProcessing = "false";
        cell.style.opacity = "1";
      });
    });
  });
});
</script>

<style>
/* 캘린더 애니메이션 클래스 */
@keyframes slideInRight {
  from { transform: translateX(30vw); opacity: 0; }
  to { transform: translateX(0); opacity: 1; }
}
@keyframes slideInLeft {
  from { transform: translateX(-30vw); opacity: 0; }
  to { transform: translateX(0); opacity: 1; }
}
.calendar-animate-in {
  animation: slideInRight 0.3s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
}
</style>

<script>
// 부드러운 네이티브 스와이프 로직
(function() {
  var swipeStartX = 0, swipeStartY = 0;
  var isSwiping = false;
  var hasMoved = false;
  var bodyElem = document.getElementById('calendarSwipeBody');

  document.addEventListener('touchstart', function(e) {
    if (!bodyElem) bodyElem = document.getElementById('calendarSwipeBody');
    if (e.target.closest('.schedule-chip')) return;
    
    swipeStartX = e.touches[0].clientX;
    swipeStartY = e.touches[0].clientY;
    isSwiping = true;
    hasMoved = false;
    
    if (bodyElem) {
      bodyElem.style.transition = 'none'; // 드래그 중엔 트랜지션 해제
    }
  }, { passive: true });

  document.addEventListener('touchmove', function(e) {
    if (!isSwiping || !bodyElem) return;
    
    var dx = e.touches[0].clientX - swipeStartX;
    var dy = e.touches[0].clientY - swipeStartY;
    
    if (!hasMoved && Math.abs(dy) > Math.abs(dx)) {
      isSwiping = false;
      return;
    }
    
    if (Math.abs(dx) > 10) {
      hasMoved = true;
      e.preventDefault(); 
      bodyElem.style.transform = 'translateX(' + (dx * 0.9) + 'px)';
    }
  }, { passive: false });

  document.addEventListener('touchend', function(e) {
    if (!isSwiping || !bodyElem) return;
    isSwiping = false;
    
    var dx = e.changedTouches[0].clientX - swipeStartX;
    
    bodyElem.style.transition = 'transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s';
    
    if (dx < -60) {
      bodyElem.style.transform = 'translateX(-30vw)';
      bodyElem.style.opacity = '0';
      setTimeout(function() {
        var next = document.getElementById('nextMonthLink');
        if (next) next.click();
      }, 150);
    } else if (dx > 60) {
      bodyElem.style.transform = 'translateX(30vw)';
      bodyElem.style.opacity = '0';
      setTimeout(function() {
        var prev = document.getElementById('prevMonthLink');
        if (prev) prev.click();
      }, 150);
    } else {
      bodyElem.style.transform = 'translateX(0)';
      bodyElem.style.opacity = '1';
    }
  });
})();
</script>
