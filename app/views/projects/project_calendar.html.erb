<style>
#projectCalendarRoot {
  position: fixed;
  top: env(safe-area-inset-top, 0px);
  left: 0;
  right: 0;
  bottom: 58px;
  display: flex;
  flex-direction: column;
  background: white;
  z-index: 10;
}

@media (min-width: 480px) {
  #projectCalendarRoot {
    left: 50%;
    transform: translateX(-50%);
    width: 430px;
    right: auto;
  }
}
</style>
<script>
  function syncProjectCalendarBottom() {
    var nav = document.querySelector('.bottom-nav');
    var root = document.getElementById('projectCalendarRoot');
    if (nav && root) {
      requestAnimationFrame(function() {
        root.style.bottom = nav.offsetHeight + 'px';
      });
    }
  }
  document.addEventListener('DOMContentLoaded', function() {
    syncProjectCalendarBottom();
    setTimeout(syncProjectCalendarBottom, 100);
  });
  document.addEventListener('turbo:load', function() {
    syncProjectCalendarBottom();
    setTimeout(syncProjectCalendarBottom, 100);
  });
  window.addEventListener('resize', syncProjectCalendarBottom);
</script>
<div id="projectCalendarRoot">

<div style="background:white; padding:18px 20px 14px 20px; border-bottom:1px solid #ececec; z-index:50; flex-shrink:0;">
  <div style="display:flex; justify-content:space-between; align-items:center;">
    <%= link_to "←", project_path(@project), style: "font-size:24px; color:#111; text-decoration:none; font-weight:800;" %>

    <div style="display:flex; align-items:center; min-width:0; flex:1; justify-content:center; padding:0 8px;">
      <span style="
        font-size: clamp(13px, 4.5vw, 22px);
        font-weight:900;
        color:<%= @project.theme_color_hex %>;
        white-space:nowrap;
        overflow:hidden;
        text-overflow:ellipsis;
        max-width:100%;
        display:block;
      "><%= @client_name %> 일정표</span>
    </div>

    <%= link_to notifications_path, style: "position:relative; text-decoration:none;" do %>
      <div style="font-size:20px;">🔔</div>
      <% if @unread_notifications_count.to_i > 0 %>
        <div style="
          position:absolute;
          top:-6px;
          right:-8px;
          min-width:18px;
          height:18px;
          padding:0 5px;
          border-radius:999px;
          background:#ef4444;
          color:white;
          font-size:11px;
          font-weight:900;
          display:flex;
          align-items:center;
          justify-content:center;
          box-sizing:border-box;
        ">
          <%= @unread_notifications_count %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
  <div style="background:white; padding:14px 0 0 0; margin-bottom:0; flex:1; min-height:0; overflow:hidden; display:flex; flex-direction:column;">
    <div style="display:flex; justify-content:center; align-items:center; margin-bottom:14px; padding:0 16px; position:relative;">

      <!-- 센터 네이티브 월 선택기 -->
      <div style="position:relative; display:inline-flex; align-items:center; cursor:pointer;">
        <div id="monthLabel" style="font-size:20px; font-weight:900; color:#111827; letter-spacing:-0.5px;">
          <%= @calendar_year %>. <%= @calendar_month %> <span style="font-size:15px; margin-left:2px; vertical-align:middle;">⌃</span>
        </div>
        <input type="month" 
               value="<%= format('%04d-%02d', @calendar_year, @calendar_month) %>"
               onchange="window.location.href='<%= project_calendar_project_path(@project, view_mode: @view_mode, selected_date: @selected_date) %><%= '?' unless project_calendar_project_path(@project, view_mode: @view_mode, selected_date: @selected_date).include?('?') %><%= '&' if project_calendar_project_path(@project, view_mode: @view_mode, selected_date: @selected_date).include?('?') %>year=' + this.value.split('-')[0] + '&month=' + parseInt(this.value.split('-')[1])"
               style="position:absolute; top:0; left:0; width:100%; height:100%; opacity:0; cursor:pointer;" />
      </div>
    </div>

    <!-- 요일 헤더 (고정) -->
    <div style="display:grid; grid-template-columns:repeat(7, 1fr); border-bottom:1px solid #f0f0f0; background:white;">
      <% ["일", "월", "화", "수", "목", "금", "토"].each do |weekday| %>
        <% header_color = case weekday
            when "일" then "#ef4444"
            when "토" then "#3b82f6"
            else "#6b7280"
           end %>
        <div style="padding:12px 0; text-align:center; font-size:14px; font-weight:800; color:<%= header_color %>;">
          <%= weekday %>
        </div>
      <% end %>
    </div>

    <!-- 3패널 캐러셀 컨테이너 -->
    <div id="carouselViewport" style="overflow-x:hidden; overflow-y:auto; background:white; flex:1; min-height:0; position:relative; touch-action:pan-y; -webkit-overflow-scrolling:touch;">
      <div id="carouselTrack" style="display:flex; width:300%; min-height:100%; transform:translateX(-33.333%); will-change:transform;">
        
        <!-- 패널 0: 이전달 -->
        <div class="carousel-panel" data-year="<%= @prev_calendar[:year] %>" data-month="<%= @prev_calendar[:month] %>" style="width:33.333%; flex-shrink:0; display:flex; flex-direction:column;">
          <% 
            saved_rows = @calendar_rows
            saved_month = @calendar_month
            saved_pbd = @projects_by_date
            saved_selected = @selected_date
            @calendar_rows = @prev_calendar[:rows]
            @calendar_month = @prev_calendar[:month]
            @projects_by_date = @prev_calendar[:projects_by_date]
            @selected_date = nil
          %>
          <%= render partial: 'projects/calendar_grid', locals: { cell_min_height: '108px' } %>
          <% 
            @calendar_rows = saved_rows
            @calendar_month = saved_month
            @projects_by_date = saved_pbd
            @selected_date = saved_selected
          %>
        </div>

        <!-- 패널 1: 현재달 (활성) -->
        <div class="carousel-panel" data-year="<%= @calendar_year %>" data-month="<%= @calendar_month %>" style="width:33.333%; flex-shrink:0; display:flex; flex-direction:column;">
          <%= render partial: 'projects/calendar_grid', locals: { cell_min_height: '108px' } %>
        </div>

        <!-- 패널 2: 다음달 -->
        <div class="carousel-panel" data-year="<%= @next_calendar[:year] %>" data-month="<%= @next_calendar[:month] %>" style="width:33.333%; flex-shrink:0; display:flex; flex-direction:column;">
          <% 
            @calendar_rows = @next_calendar[:rows]
            @calendar_month = @next_calendar[:month]
            @projects_by_date = @next_calendar[:projects_by_date]
            @selected_date = nil
          %>
          <%= render partial: 'projects/calendar_grid', locals: { cell_min_height: '108px' } %>
          <% 
            @calendar_rows = saved_rows
            @calendar_month = saved_month
            @projects_by_date = saved_pbd
            @selected_date = saved_selected
          %>
        </div>

      </div>
    </div>

  </div>
</div>

<!-- 프로젝트 캘린더: 날짜 셀 클릭 없음 (단독 현장 캘린더), 거래처명 칩은 현장 상세로 이동 -->

<!-- 캐러셀 상태 -->
<script>
  var CAROUSEL_STATE = {
    currentYear: <%= @calendar_year %>,
    currentMonth: <%= @calendar_month %>,
    projectId: '<%= @project.id %>',
    panelUrl: '<%= project_calendar_panel_project_path(@project) %>'
  };
  var TODAY_YEAR = <%= Date.current.year %>;
  var TODAY_MONTH = <%= Date.current.month %>;
</script>

<!-- 오늘로 돌아가기 버튼 -->
<div id="goTodayBtn" onclick="window.location.href='<%= project_calendar_project_path(@project) %>'" style="
  display:none;
  position:fixed;
  bottom:100px;
  left:50%;
  transform:translateX(-50%);
  z-index:40;
  background:#111827;
  color:white;
  padding:10px 20px;
  border-radius:999px;
  font-size:13px;
  font-weight:900;
  box-shadow:0 4px 16px rgba(0,0,0,0.25);
  cursor:pointer;
  transition:opacity 0.3s, transform 0.3s;
  white-space:nowrap;
">
  📅 오늘로
</div>

<style>
#carouselTrack { transition: none; }
#carouselTrack.animating { transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
.carousel-panel { height: 100%; }
</style>

<script>
// === 진짜 3패널 캐러셀 엔진 (프로젝트 캘린더) ===
(function() {
  var track = document.getElementById('carouselTrack');
  var viewport = document.getElementById('carouselViewport');
  if (!track || !viewport) return;

  var swipeStartX = 0, swipeStartY = 0;
  var isSwiping = false;
  var hasMoved = false;
  var isAnimating = false;
  var BASE_OFFSET = -33.333;

  function getPanels() {
    return track.querySelectorAll('.carousel-panel');
  }

  function getMonthInfo(year, month, delta) {
    var d = new Date(year, month - 1 + delta, 1);
    return { year: d.getFullYear(), month: d.getMonth() + 1 };
  }

  function updateMonthLabel() {
    var label = document.getElementById('monthLabel');
    if (label) {
      label.innerHTML = CAROUSEL_STATE.currentYear + '. ' + CAROUSEL_STATE.currentMonth +
        ' <span style="font-size:15px; margin-left:2px; vertical-align:middle;">⌃</span>';
    }
    var picker = document.querySelector('input[type="month"]');
    if (picker) {
      picker.value = CAROUSEL_STATE.currentYear + '-' + String(CAROUSEL_STATE.currentMonth).padStart(2, '0');
    }
    // 오늘로 버튼 표시/숨김
    var todayBtn = document.getElementById('goTodayBtn');
    if (todayBtn) {
      var isCurrentMonth = (CAROUSEL_STATE.currentYear === TODAY_YEAR && CAROUSEL_STATE.currentMonth === TODAY_MONTH);
      todayBtn.style.display = isCurrentMonth ? 'none' : 'block';
    }
  }

  function fetchPanel(year, month, callback) {
    var url = CAROUSEL_STATE.panelUrl + '?year=' + year + '&month=' + month;

    fetch(url, { headers: { 'Accept': 'text/html' } })
      .then(function(res) { return res.text(); })
      .then(function(html) { callback(html, year, month); })
      .catch(function(err) { console.error('Panel fetch error:', err); });
  }

  function slideToNext() {
    if (isAnimating) return;
    isAnimating = true;
    track.classList.add('animating');
    track.style.transform = 'translateX(-66.666%)';

    track.addEventListener('transitionend', function onEnd() {
      track.removeEventListener('transitionend', onEnd);
      finishSlideNext();
    });
    setTimeout(function() { if (isAnimating) finishSlideNext(); }, 400);
  }

  function finishSlideNext() {
    if (!isAnimating) return;
    isAnimating = false;
    track.classList.remove('animating');

    var panels = getPanels();
    CAROUSEL_STATE.currentYear = parseInt(panels[2].dataset.year);
    CAROUSEL_STATE.currentMonth = parseInt(panels[2].dataset.month);
    track.style.visibility = 'hidden';
    panels[0].remove();
    track.style.transform = 'translateX(' + BASE_OFFSET + '%)';
    track.offsetHeight;
    track.style.visibility = '';

    updateMonthLabel();

    var futureMonth = getMonthInfo(CAROUSEL_STATE.currentYear, CAROUSEL_STATE.currentMonth, 1);
    fetchPanel(futureMonth.year, futureMonth.month, function(html, y, m) {
      var np = document.createElement('div');
      np.className = 'carousel-panel';
      np.dataset.year = y;
      np.dataset.month = m;
      np.style.cssText = 'width:33.333%; flex-shrink:0; display:flex; flex-direction:column;';
      np.innerHTML = html;
      track.appendChild(np);
    });
  }

  function slideToPrev() {
    if (isAnimating) return;
    isAnimating = true;
    track.classList.add('animating');
    track.style.transform = 'translateX(0%)';

    track.addEventListener('transitionend', function onEnd() {
      track.removeEventListener('transitionend', onEnd);
      finishSlidePrev();
    });
    setTimeout(function() { if (isAnimating) finishSlidePrev(); }, 400);
  }

  function finishSlidePrev() {
    if (!isAnimating) return;
    isAnimating = false;
    track.classList.remove('animating');

    var panels = getPanels();
    CAROUSEL_STATE.currentYear = parseInt(panels[0].dataset.year);
    CAROUSEL_STATE.currentMonth = parseInt(panels[0].dataset.month);
    track.style.visibility = 'hidden';
    panels[panels.length - 1].remove();
    track.style.transform = 'translateX(0%)';
    track.offsetHeight;
    track.style.visibility = '';

    updateMonthLabel();

    var pastMonth = getMonthInfo(CAROUSEL_STATE.currentYear, CAROUSEL_STATE.currentMonth, -1);
    fetchPanel(pastMonth.year, pastMonth.month, function(html, y, m) {
      var np = document.createElement('div');
      np.className = 'carousel-panel';
      np.dataset.year = y;
      np.dataset.month = m;
      np.style.cssText = 'width:33.333%; flex-shrink:0; display:flex; flex-direction:column;';
      np.innerHTML = html;
      track.style.visibility = 'hidden';
      track.insertBefore(np, track.firstChild);
      track.style.transform = 'translateX(' + BASE_OFFSET + '%)';
      track.offsetHeight;
      track.style.visibility = '';
    });
  }

  function snapBack() {
    track.classList.add('animating');
    track.style.transform = 'translateX(' + BASE_OFFSET + '%)';
    setTimeout(function() { track.classList.remove('animating'); }, 350);
  }

  viewport.addEventListener('touchstart', function(e) {
    if (isAnimating) return;
    if (e.target.closest('.schedule-chip')) return;

    swipeStartX = e.touches[0].clientX;
    swipeStartY = e.touches[0].clientY;
    isSwiping = true;
    hasMoved = false;
    track.classList.remove('animating');
  }, { passive: true });

  viewport.addEventListener('touchmove', function(e) {
    if (!isSwiping || isAnimating) return;

    var dx = e.touches[0].clientX - swipeStartX;
    var dy = e.touches[0].clientY - swipeStartY;

    if (!hasMoved) {
      if (Math.abs(dx) > 5 || Math.abs(dy) > 5) {
        if (Math.abs(dy) > Math.abs(dx)) {
          isSwiping = false;
          return;
        } else {
          hasMoved = true;
        }
      } else {
        return;
      }
    }

    if (hasMoved) {
      if (e.cancelable) e.preventDefault();
      var vpWidth = viewport.offsetWidth;
      var pxToPct = (dx / vpWidth) * 100;
      var shiftPct = pxToPct / 3;
      track.style.transform = 'translateX(' + (BASE_OFFSET + shiftPct) + '%)';
    }
  }, { passive: false });

  viewport.addEventListener('touchend', function(e) {
    if (!isSwiping || isAnimating) return;
    isSwiping = false;

    var dx = e.changedTouches[0].clientX - swipeStartX;

    if (dx < -60) {
      slideToNext();
    } else if (dx > 60) {
      slideToPrev();
    } else {
      snapBack();
    }
  });
})();
</script>
