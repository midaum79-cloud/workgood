<% content_for :title, "새 영수증 등록" %>
<script>
  // 이 페이지에서 Turbo 캐시 비활성화 (카메라/갤러리 복귀 시 페이지 리셋 방지)
  if (window.Turbo) {
    Turbo.cache.exemptPageFromCache();
  }
</script>


<div class="top-header" style="background:white; padding:18px 20px 14px 20px; border-bottom:1px solid #ececec; position:sticky; top:0; z-index:30;">
  <div style="display:flex; justify-content:space-between; align-items:center;">
    <div style="display:flex; align-items:center; gap:8px;">
      <a href="javascript:history.back()" style="color:#1f2937; text-decoration:none;">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
      </a>
      <div style="font-size:20px; font-weight:900; color:#111827;">새 영수증 등록</div>
    </div>
  </div>
</div>

<div style="padding:20px; padding-bottom:80px;">
  <% if @receipt.errors.any? %>
    <div style="background:#fef2f2; border:1px solid #f87171; color:#ef4444; padding:12px; border-radius:8px; margin-bottom:16px;">
      <ul style="margin:0; padding-left:20px; font-size:14px;">
        <% @receipt.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <form action="<%= receipts_path %>" method="post" enctype="multipart/form-data" id="receiptForm" data-turbo="false">
    <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
    <input type="hidden" name="receipt[receipt_date]" id="receipt_date_field" value="<%= @selected_date || Date.current.to_s %>">

    <!-- 안내 + 버튼 영역 -->
    <div id="instructionArea" style="text-align:center; padding:40px 20px;">
      <div style="font-size:48px; margin-bottom:16px;">📸</div>
      <h3 style="font-size:18px; font-weight:800; color:#111827; margin-bottom:8px;">영수증을 촬영해주세요</h3>
      <p style="font-size:14px; color:#6b7280; line-height:1.5;">촬영된 이미지는 스마트기기 환경에 맞춰<br>자동으로 용량이 데이터 최적화 됩니다.</p>
      
      <div style="display:flex; gap:12px; margin-top:24px;">
        <label for="galleryInput" style="flex:1; background:#f3f4f6; color:#374151; border:none; padding:16px 0; font-size:16px; font-weight:700; border-radius:12px; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:8px; cursor:pointer; box-sizing:border-box;">
          <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          사진 선택
        </label>

        <label for="cameraInput" style="flex:1; background:#111827; color:white; border:none; padding:16px 0; font-size:16px; font-weight:700; border-radius:12px; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:8px; cursor:pointer; box-sizing:border-box;">
          <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          직접 촬영
        </label>
      </div>
    </div>

    <!-- 갤러리용 (capture 없음) — 폼 안에 위치 -->
    <input type="file" id="galleryInput" name="receipt[image]" accept="image/*" style="position:absolute; left:-9999px; opacity:0; width:1px; height:1px;">
    <!-- 카메라용 (capture 있음) — 폼 안에 위치 -->
    <input type="file" id="cameraInput" accept="image/*" capture="environment" style="position:absolute; left:-9999px; opacity:0; width:1px; height:1px;">

    <!-- 미리보기 + 저장 영역 -->
    <div id="formDetails" style="display:none;">
      <div style="background:#f9fafb; border-radius:12px; padding:16px; margin-bottom:16px; text-align:center;">
        <img id="imagePreview" src="" style="max-width:100%; max-height:200px; border-radius:8px; object-fit:contain; display:none; margin:0 auto; box-shadow:0 4px 6px -1px rgba(0,0,0,0.1);">
      </div>

      <div style="margin-bottom:24px;">
        <label style="display:block; font-size:14px; font-weight:700; color:#374151; margin-bottom:8px;">결제 날짜</label>
        <input type="date" id="receipt_date_visible" value="<%= @selected_date || Date.current.to_s %>" style="width:100%; padding:14px; border:1px solid #d1d5db; border-radius:10px; font-size:16px; box-sizing:border-box;">
      </div>

      <button type="submit" id="submitBtn" style="width:100%; background:#111827; color:white; border:none; padding:18px; font-size:18px; font-weight:800; border-radius:12px; cursor:pointer; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);">
        영수증 저장하기
      </button>
    </div>
  </form>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var galleryInput = document.getElementById('galleryInput');
  var cameraInput = document.getElementById('cameraInput');
  var form = document.getElementById('receiptForm');
  var instructionArea = document.getElementById('instructionArea');
  var formDetails = document.getElementById('formDetails');
  var imagePreview = document.getElementById('imagePreview');
  var submitBtn = document.getElementById('submitBtn');
  var dateField = document.getElementById('receipt_date_field');
  var dateVisible = document.getElementById('receipt_date_visible');

  if (!form) return;

  // 날짜 동기화
  if (dateVisible) {
    dateVisible.addEventListener('change', function() {
      dateField.value = this.value;
    });
  }

  // 카메라로 찍은 파일 → galleryInput(폼의 name 필드)로 복사
  function copyFileToGalleryInput(sourceInput) {
    if (!sourceInput.files || sourceInput.files.length === 0) return;
    try {
      var dt = new DataTransfer();
      dt.items.add(sourceInput.files[0]);
      galleryInput.files = dt.files;
    } catch(e) {
      // DataTransfer 미지원 시 - 폼 제출 전에 직접 처리
    }
  }

  function handleFile(inputEl) {
    if (!inputEl.files || inputEl.files.length === 0) return;
    
    var file = inputEl.files[0];
    
    // 미리보기 표시
    var reader = new FileReader();
    reader.onload = function(e) {
      imagePreview.src = e.target.result;
      imagePreview.style.display = 'block';
    };
    reader.readAsDataURL(file);

    // UI 전환
    instructionArea.style.display = 'none';
    formDetails.style.display = 'block';
  }

  // 갤러리 선택 (이미 name="receipt[image]"이므로 바로 사용 가능)
  galleryInput.addEventListener('change', function() {
    handleFile(this);
  });

  // 카메라 촬영 → galleryInput으로 파일 복사 후 처리
  cameraInput.addEventListener('change', function() {
    if (!this.files || this.files.length === 0) return;
    copyFileToGalleryInput(this);
    handleFile(galleryInput);
  });

  // 폼 제출
  form.addEventListener('submit', function(e) {
    // 파일 확인
    if (!galleryInput.files || galleryInput.files.length === 0) {
      e.preventDefault();
      alert('영수증 사진을 선택해주세요.');
      return;
    }

    // 날짜 동기화
    if (dateVisible) {
      dateField.value = dateVisible.value;
    }

    submitBtn.innerText = '저장하는 중...';
    submitBtn.style.opacity = '0.7';
    submitBtn.style.pointerEvents = 'none';
  });
});
</script>
