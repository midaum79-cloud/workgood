<% content_for :title, "새 영수증 등록" %>

<div class="top-header" style="background:white; padding:18px 20px 14px 20px; border-bottom:1px solid #ececec; position:sticky; top:0; z-index:30;">
  <div style="display:flex; justify-content:space-between; align-items:center;">
    <div style="display:flex; align-items:center; gap:8px;">
      <a href="javascript:history.back()" style="color:#1f2937; text-decoration:none;">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
      </a>
      <div style="font-size:20px; font-weight:900; color:#111827;">새 영수증 등록</div>
    </div>
  </div>
</div>

<div style="padding:20px; padding-bottom:80px;">
  <!-- 안내 영역 -->
  <div id="instructionArea" style="text-align:center; padding:40px 20px;">
    <div style="font-size:48px; margin-bottom:16px;">📸</div>
    <h3 style="font-size:18px; font-weight:800; color:#111827; margin-bottom:8px;">영수증을 촬영해주세요</h3>
    <p style="font-size:14px; color:#6b7280; line-height:1.5;">촬영된 이미지는 스마트기기 환경에 맞춰<br>자동으로 용량이 데이터 최적화 됩니다.</p>
    
    <button onclick="document.getElementById('receipt_image_file').click()" style="margin-top:24px; background:#4f46e5; color:white; border:none; padding:16px 24px; font-size:16px; font-weight:700; border-radius:12px; width:100%; display:flex; align-items:center; justify-content:center; gap:8px; cursor:pointer;">
      <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      사진 선택 / 촬영하기
    </button>
  </div>

  <!-- 입력 폼 영역 -->
  <div id="formArea" style="display:none;">
    <%= form_with model: @receipt, local: true, html: { multipart: true, id: "receiptForm" } do |f| %>
      <input type="file" id="receipt_image_file" name="receipt[image]" accept="image/*" capture="environment" style="display:none;" required>
      
      <div style="background:#f9fafb; border-radius:12px; padding:16px; margin-bottom:24px; text-align:center;">
        <img id="imagePreview" src="" style="max-width:100%; max-height:200px; border-radius:8px; object-fit:contain; display:none; margin:0 auto; box-shadow:0 4px 6px -1px rgba(0,0,0,0.1);">
      </div>

      <div class="form-group" style="margin-bottom:32px;">
        <label style="display:block; font-size:14px; font-weight:700; color:#374151; margin-bottom:8px;">결제 날짜</label>
        <%= f.date_field :receipt_date, value: @selected_date, class: "form-input", style: "width:100%; padding:14px; border:1px solid #d1d5db; border-radius:10px; font-size:16px;", required: true %>
      </div>

      <button type="submit" id="submitBtn" style="width:100%; background:#111827; color:white; border:none; padding:18px; font-size:18px; font-weight:800; border-radius:12px; cursor:pointer; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);">
        영수증 저장하기
      </button>
    <% end %>
  </div>
</div>

<script>
  let eventBound = false;

  document.addEventListener('turbo:load', function() {
    initCameraFeature();
  });

  function initCameraFeature() {
    const fileInput = document.getElementById('receipt_image_file');
    if (!fileInput || eventBound) return;
    
    eventBound = true;

    fileInput.addEventListener('change', function(e) {
      if (this.files && this.files[0]) {
        const file = this.files[0];
        
        const objectUrl = URL.createObjectURL(file);
        const imgPreview = document.getElementById('imagePreview');
        imgPreview.src = objectUrl;
        imgPreview.style.display = 'block';

        const btn = document.getElementById('submitBtn');
        btn.innerText = "이미지 최적화 중...";
        btn.style.opacity = "0.7";
        btn.style.pointerEvents = "none";

        // UI 상태 전환
        document.getElementById('instructionArea').style.display = 'none';
        document.getElementById('formArea').style.display = 'block';

        // 캔버스를 활용해 이미지 리사이징 (모바일 화면 최적화: 가로/세로 최대 800px)
        const img = new Image();
        img.src = objectUrl;
        img.onload = function() {
          const canvas = document.createElement('canvas');
          let width = img.width;
          let height = img.height;
          const MAX_SIZE = 800; // 용량 최적화 기준
          
          if (width > height) {
            if (width > MAX_SIZE) {
              height = Math.round((height * MAX_SIZE) / width);
              width = MAX_SIZE;
            }
          } else {
            if (height > MAX_SIZE) {
              width = Math.round((width * MAX_SIZE) / height);
              height = MAX_SIZE;
            }
          }
          
          canvas.width = width;
          canvas.height = height;
          const ctx = canvas.getContext('2d');
          ctx.drawImage(img, 0, 0, width, height);
          
          // 압축된 Blob 객체 생성 후 폼 파일 입력 대체 (DataTransfer)
          canvas.toBlob(function(blob) {
            const newFile = new File([blob], "receipt_optimized.png", {type: "image/png"});
            const dt = new DataTransfer();
            dt.items.add(newFile);
            fileInput.files = dt.files; // 기존 원본 대용량 파일 대신 PNG 최적화 파일 교체
            
            btn.innerText = "저장하기";
            btn.style.opacity = "1";
            btn.style.pointerEvents = "auto";
            
          }, 'image/png'); // 화질 저하 없이 서버 용량은 아끼기 위해 PNG 포맷 채택
        };
      }
    });

    // 폼 제출 방지 - 최적화 도중에는 제출 불가
    document.getElementById('receiptForm').addEventListener('submit', function(e) {
      const btn = document.getElementById('submitBtn');
      if (btn.innerText === "이미지 최적화 중...") {
        e.preventDefault();
      } else {
        btn.innerText = "저장하는 중...";
        btn.style.opacity = "0.7";
        btn.style.pointerEvents = "none";
      }
    });
  }
</script>
