<div style="max-width:430px; margin:0 auto; min-height:100vh; background:#0f172a;">

  <%# Header %>
  <div style="background:#0f172a; padding:18px 20px 14px 20px; border-bottom:1px solid #1e293b; position:sticky; top:0; z-index:30; margin-bottom:0;">
    <div style="display:flex; justify-content:space-between; align-items:center;">
      <div style="font-size:24px; color:white; font-weight:900; cursor:pointer;" onclick="openDrawer()">☰</div>
      <div style="font-size:20px; font-weight:900; color:white;">위젯 설정</div>
      <div style="width:40px;"></div>
    </div>
  </div>

  <%# Hero area %>
  <div style="padding:32px 20px 24px; text-align:center; background:linear-gradient(180deg, #0f172a 0%, #1e1b4b 100%);">
    <div style="font-size:13px; font-weight:800; color:#818cf8; letter-spacing:1px; margin-bottom:12px;">LOCK SCREEN WIDGET</div>
    <div style="font-size:26px; font-weight:900; color:white; margin-bottom:8px; line-height:1.3;">
      잠금화면에서 바로<br>오늘 공정을 확인하세요
    </div>
    <div style="font-size:14px; color:#94a3b8; font-weight:600; line-height:1.6;">
      프리미엄 구독 시 iOS/Android<br>잠금화면 위젯을 이용할 수 있습니다
    </div>
  </div>

  <%# Widget Preview — Lock Screen %>
  <div style="padding:0 20px 28px; background:linear-gradient(180deg, #1e1b4b 0%, #0f172a 100%);">
    <div style="font-size:12px; font-weight:800; color:#64748b; letter-spacing:1px; margin-bottom:14px; text-align:center;">미리보기</div>

    <%# Simulated Lock Screen %>
    <div style="background:linear-gradient(135deg, #1e3a5f 0%, #0c2340 100%); border-radius:28px; padding:24px 18px 20px; box-shadow:0 20px 60px rgba(0,0,0,0.6);">

      <%# Lock screen time %>
      <div style="text-align:center; margin-bottom:18px;">
        <div style="font-size:52px; font-weight:200; color:white; line-height:1;">09:41</div>
        <div style="font-size:14px; color:rgba(255,255,255,0.7); font-weight:500; margin-top:4px;">
          <%= Date.today.strftime("%Y년 %-m월 %-d일 %A").gsub("Monday","월요일").gsub("Tuesday","화요일").gsub("Wednesday","수요일").gsub("Thursday","목요일").gsub("Friday","금요일").gsub("Saturday","토요일").gsub("Sunday","일요일") %>
        </div>
      </div>

      <%# Widget Box %>
      <div style="background:rgba(255,255,255,0.12); border-radius:20px; padding:14px 16px; backdrop-filter:blur(10px); border:1px solid rgba(255,255,255,0.15);">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
          <div style="font-size:12px; font-weight:800; color:rgba(255,255,255,0.7); letter-spacing:0.5px;">일머리 · 오늘 공정</div>
          <div style="font-size:11px; color:rgba(255,255,255,0.5);">3월 12일</div>
        </div>

        <%# Sample schedule items %>
        <div style="display:flex; flex-direction:column; gap:8px;">
          <div style="display:flex; align-items:center; gap:10px;">
            <div style="width:8px; height:8px; border-radius:50%; background:#4ade80; flex-shrink:0;"></div>
            <div style="flex:1;">
              <div style="font-size:13px; font-weight:800; color:white;">목공 · 퇴계주공 604동</div>
              <div style="font-size:11px; color:rgba(255,255,255,0.5);">진행중</div>
            </div>
          </div>
          <div style="display:flex; align-items:center; gap:10px;">
            <div style="width:8px; height:8px; border-radius:50%; background:#facc15; flex-shrink:0;"></div>
            <div style="flex:1;">
              <div style="font-size:13px; font-weight:800; color:white;">타일 · 광명 센트레빌</div>
              <div style="font-size:11px; color:rgba(255,255,255,0.5);">예정</div>
            </div>
          </div>
          <div style="display:flex; align-items:center; gap:10px;">
            <div style="width:8px; height:8px; border-radius:50%; background:#60a5fa; flex-shrink:0;"></div>
            <div style="flex:1;">
              <div style="font-size:13px; font-weight:800; color:white;">전기 · 광명 센트레빌</div>
              <div style="font-size:11px; color:rgba(255,255,255,0.5);">예정</div>
            </div>
          </div>
        </div>
      </div>

      <%# Lock icon %>
      <div style="text-align:center; margin-top:20px; font-size:22px; opacity:0.5;">🔒</div>
    </div>
  </div>

  <%# Subscription Plans %>
  <div style="background:#f8fafc; padding:28px 20px 30px;">
    <div style="font-size:18px; font-weight:900; color:#111827; margin-bottom:6px; text-align:center;">구독 플랜</div>
    <div style="font-size:13px; color:#9ca3af; font-weight:600; text-align:center; margin-bottom:22px;">지금 가입하면 첫 달 무료</div>

    <div style="display:flex; flex-direction:column; gap:14px;">

      <%# Free plan %>
      <div style="background:white; border-radius:20px; padding:20px; border:2px solid #e5e7eb;">
        <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:10px;">
          <div>
            <div style="font-size:16px; font-weight:900; color:#374151;">무료</div>
            <div style="font-size:12px; color:#9ca3af; font-weight:600; margin-top:2px;">Free</div>
          </div>
          <div style="text-align:right;">
            <div style="font-size:22px; font-weight:900; color:#111827;">₩0</div>
            <div style="font-size:11px; color:#9ca3af;">/월</div>
          </div>
        </div>
        <div style="display:flex; flex-direction:column; gap:7px;">
          <div style="font-size:13px; color:#6b7280; font-weight:600;">✓ 프로젝트 1개</div>
          <div style="font-size:13px; color:#6b7280; font-weight:600;">✓ 공정 일정 관리</div>
          <div style="font-size:13px; color:#6b7280; font-weight:600;">✓ 캘린더 보기</div>
          <div style="font-size:13px; color:#6b7280; font-weight:600;">✓ 현장 공정 진행 상태 확인</div>
          <div style="font-size:13px; color:#d1d5db; font-weight:600;">✗ 잠금화면 위젯</div>
          <div style="font-size:13px; color:#d1d5db; font-weight:600;">✗ 알림 자동화</div>
        </div>
        <div style="margin-top:14px; padding:12px; background:#f9fafb; border-radius:12px; text-align:center; font-size:14px; font-weight:800; color:#9ca3af;">
          현재 플랜
        </div>
      </div>

      <%# Standard plan %>
      <div style="background:white; border-radius:20px; padding:20px; border:2px solid #3b82f6; position:relative; overflow:hidden;">
        <div style="position:absolute; top:14px; right:14px; background:#3b82f6; color:white; font-size:11px; font-weight:900; padding:4px 10px; border-radius:999px;">인기</div>
        <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:10px;">
          <div>
            <div style="font-size:16px; font-weight:900; color:#1d4ed8;">스탠다드</div>
            <div style="font-size:12px; color:#93c5fd; font-weight:600; margin-top:2px;">Standard</div>
          </div>
          <div style="text-align:right;">
            <div style="font-size:22px; font-weight:900; color:#111827;">₩4,900</div>
            <div style="font-size:11px; color:#9ca3af;">/월</div>
          </div>
        </div>
        <div style="display:flex; flex-direction:column; gap:7px;">
          <div style="font-size:13px; color:#374151; font-weight:700;">✓ 프로젝트 최대 3개</div>
          <div style="font-size:13px; color:#374151; font-weight:700;">✓ 공정 일정 관리</div>
          <div style="font-size:13px; color:#374151; font-weight:700;">✓ 캘린더</div>
          <div style="font-size:13px; color:#374151; font-weight:700;">✓ 공정 템플릿 사용</div>
          <div style="font-size:13px; color:#374151; font-weight:700;">✓ 업체 관리</div>
          <div style="font-size:13px; color:#374151; font-weight:700;">✓ 기본 알림</div>
          <div style="font-size:13px; color:#d1d5db; font-weight:600;">✗ 잠금화면 위젯</div>
        </div>
        <button style="width:100%; margin-top:14px; padding:13px; background:#3b82f6; color:white; border:none; border-radius:12px; font-size:15px; font-weight:900; cursor:pointer; font-family:inherit;" onclick="alert('구독 기능은 곧 오픈됩니다! 🎉')">
          시작하기 →
        </button>
      </div>

      <%# Premium plan %>
      <div style="background:linear-gradient(135deg, #1e1b4b 0%, #312e81 100%); border-radius:20px; padding:20px; border:2px solid #6366f1; position:relative; overflow:hidden;">
        <div style="position:absolute; top:14px; right:14px; background:linear-gradient(90deg,#f59e0b,#fbbf24); color:white; font-size:11px; font-weight:900; padding:4px 10px; border-radius:999px;">⭐ 위젯</div>
        <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:10px;">
          <div>
            <div style="font-size:16px; font-weight:900; color:white;">프리미엄</div>
            <div style="font-size:12px; color:#a5b4fc; font-weight:600; margin-top:2px;">Premium</div>
          </div>
          <div style="text-align:right;">
            <div style="font-size:22px; font-weight:900; color:white;">₩9,900</div>
            <div style="font-size:11px; color:#a5b4fc;">/월</div>
          </div>
        </div>
        <div style="display:flex; flex-direction:column; gap:7px;">
          <div style="font-size:13px; color:rgba(255,255,255,0.9); font-weight:700;">✓ 스탠다드 전체 포함</div>
          <div style="font-size:13px; color:rgba(255,255,255,0.9); font-weight:700;">✓ 프로젝트 무제한</div>
          <div style="font-size:13px; color:#fde68a; font-weight:800;">⭐ 캘린더 위젯</div>
          <div style="font-size:13px; color:#fde68a; font-weight:800;">⭐ 잠금화면 위젯 (iOS/AOS)</div>
          <div style="font-size:13px; color:#fde68a; font-weight:800;">⭐ 시간 알림 설정</div>
          <div style="font-size:13px; color:#fde68a; font-weight:800;">⭐ 팀 관리</div>
          <div style="font-size:13px; color:#fde68a; font-weight:800;">⭐ 고급 알림</div>
        </div>
        <button style="width:100%; margin-top:14px; padding:13px; background:linear-gradient(90deg, #6366f1, #818cf8); color:white; border:none; border-radius:12px; font-size:15px; font-weight:900; cursor:pointer; font-family:inherit;" onclick="alert('프리미엄 구독 기능은 곧 오픈됩니다! 🎉')">
          프리미엄 시작하기 →
        </button>
      </div>

    </div>

    <%# Notice about native widget %>
    <div style="margin-top:20px; background:#fef3c7; border-radius:14px; padding:14px 16px;">
      <div style="font-size:13px; font-weight:900; color:#92400e; margin-bottom:4px;">📱 위젯 사용 안내</div>
      <div style="font-size:12px; font-weight:600; color:#78350f; line-height:1.6;">
        잠금화면 위젯은 iOS 16 이상 / Android 12 이상에서 지원됩니다.
        프리미엄 구독 후 App Store / Google Play에서 일머리 앱을 설치하면 위젯을 사용할 수 있습니다.
        (네이티브 앱 — 출시 준비중 🚀)
      </div>
    </div>

  </div>

</div>
