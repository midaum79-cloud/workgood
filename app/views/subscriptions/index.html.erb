<script>
  async function requestPayment(plan, amount) {
    if (!window.Capacitor || !window.Capacitor.isNativePlatform()) {
      alert("해당 요금제 결제는 '일잘러' 모바일 앱에서만 가능합니다. 앱을 통해서 진행해주세요!");
      return;
    }

    try {
      const Purchases = window.Capacitor.Plugins.Purchases;
      if (!Purchases) {
        alert("앱 결제 모듈을 불러오지 못했습니다. 앱을 업데이트하거나 다시 실행해주세요.");
        return;
      }

      // RevenueCat API 키 (서버 환경 변수에서 주입)
      const RC_API_KEY = "<%= ENV['REVENUECAT_APPLE_API_KEY'] || 'appl_YOUR_KEY_HERE' %>";
      await Purchases.configure({ apiKey: RC_API_KEY, appUserID: "<%= current_user.id %>" });

      const productIdentifier = `com.workgood.app.${plan}`; // ex: com.workgood.app.standard

      // 결제 요청
      const { customerInfo } = await Purchases.purchaseProduct({
        productIdentifier: productIdentifier
      });

      // RevenueCat에서 활성화된 Entitlement가 있는지 확인 (plan 이름과 매칭)
      if (customerInfo.entitlements.active[plan] !== undefined) {
        // 결제 후 서버 검증 시작
        window.location.href = `/subscription/verify_apple?plan=${plan}`;
      } else {
        // Fallback
        window.location.href = `/subscription/verify_apple?plan=${plan}`;
      }

    } catch (e) {
      if (!e.userCancelled) {
        alert('앱 결제 중 오류가 발생했습니다: ' + e.message);
      }
    }
  }
</script>
