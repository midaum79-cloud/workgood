<div style="max-width:430px; margin:0 auto; min-height:100vh; background:#f5f5f5;">

  <%# Header %>
  <div style="background:white; padding:18px 20px 14px 20px; border-bottom:1px solid #ececec; position:sticky; top:0; z-index:30; margin-bottom:16px;">
    <div style="display:flex; justify-content:space-between; align-items:center;">
      <div style="font-size:24px; color:#111827; font-weight:900; cursor:pointer;" onclick="openDrawer()">☰</div>
      <div style="font-size:20px; font-weight:900;">구독 관리</div>
      <div style="width:40px;"></div>
    </div>
  </div>

  <div style="padding:0 16px 100px 16px;">

    <% if notice %>
      <div style="background:#dcfce7; color:#166534; border-radius:14px; padding:12px 16px; margin-bottom:16px; font-size:14px; font-weight:700;"><%= notice %></div>
    <% end %>
    <% if alert %>
      <div style="background:#fef2f2; color:#991b1b; border-radius:14px; padding:12px 16px; margin-bottom:16px; font-size:14px; font-weight:700;"><%= alert %></div>
    <% end %>

    <%# Current Plan Card %>
    <div style="background:linear-gradient(135deg, #111827 0%, #1e3a5f 100%); border-radius:20px; padding:22px; margin-bottom:20px; color:white;">
      <div style="font-size:12px; font-weight:700; color:rgba(255,255,255,0.6); margin-bottom:6px;">현재 요금제</div>
      <div style="font-size:26px; font-weight:900; margin-bottom:6px;"><%= current_user.plan_label %> 플랜</div>
      <div style="font-size:14px; color:rgba(255,255,255,0.7);">
        프로젝트 <%= @project_count %>개 사용 중 /
        <%= @plan_limit == Float::INFINITY ? "무제한" : "최대 #{@plan_limit}개" %>
      </div>

      <%# Usage bar %>
      <div style="margin-top:16px;">
        <div style="width:100%; height:6px; background:rgba(255,255,255,0.2); border-radius:999px; overflow:hidden;">
          <% usage_pct = @plan_limit == Float::INFINITY ? 0 : [(@project_count.to_f / @plan_limit * 100).round, 100].min %>
          <div style="width:<%= usage_pct %>%; height:100%; background:<%= usage_pct >= 100 ? '#ef4444' : '#4ade80' %>; border-radius:999px;"></div>
        </div>
        <div style="font-size:11px; color:rgba(255,255,255,0.5); margin-top:5px; text-align:right;">
          <%= usage_pct %>% 사용
        </div>
      </div>

      <% if @current_plan != "free" && @last_payment %>
        <div style="margin-top:14px; padding-top:14px; border-top:1px solid rgba(255,255,255,0.15); display:flex; justify-content:space-between; font-size:12px; color:rgba(255,255,255,0.6);">
          <span>결제일: <%= @last_payment.paid_at&.strftime("%Y-%m-%d") %></span>
          <span>만료일: <%= @last_payment.expires_at&.strftime("%Y-%m-%d") %></span>
        </div>
      <% end %>
    </div>

    <%# Plans %>
    <div style="font-size:16px; font-weight:900; color:#111827; margin-bottom:14px;">요금제 변경</div>

    <div style="display:flex; flex-direction:column; gap:12px;">

      <%# FREE %>
      <% is_current = @current_plan == "free" %>
      <div style="background:white; border-radius:18px; padding:18px; border:2px solid <%= is_current ? '#111827' : '#e5e7eb' %>;">
        <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:12px;">
          <div>
            <div style="font-size:16px; font-weight:900; color:#374151;">무료 플랜</div>
            <div style="font-size:12px; color:#9ca3af; font-weight:600; margin-top:2px;">프로젝트 1개</div>
          </div>
          <div style="font-size:20px; font-weight:900; color:#111827;">₩0</div>
        </div>
        <div style="font-size:13px; color:#6b7280; margin-bottom:14px; line-height:1.8;">
          ✓ 프로젝트 1개<br>
          ✓ 공정 일정 관리<br>
          ✓ 캘린더 보기<br>
          ✓ 현장 공정 진행 상태 확인
        </div>
        <% if is_current %>
          <div style="text-align:center; padding:11px; background:#f9fafb; border-radius:12px; font-size:14px; font-weight:800; color:#9ca3af;">현재 플랜</div>
        <% else %>
          <%= button_to "무료로 전환", subscription_path, method: :patch, params: { plan: "free" },
              style: "width:100%; padding:12px; background:#f3f4f6; color:#374151; border:none; border-radius:12px; font-size:14px; font-weight:800; cursor:pointer; font-family:inherit;" %>
        <% end %>
      </div>

      <%# STANDARD %>
      <% is_current = @current_plan == "standard" %>
      <div style="background:white; border-radius:18px; padding:18px; border:2px solid <%= is_current ? '#2563eb' : '#e5e7eb' %>;">
        <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:12px;">
          <div>
            <div style="font-size:16px; font-weight:900; color:#1d4ed8;">스탠다드 플랜</div>
            <div style="font-size:12px; color:#93c5fd; font-weight:600; margin-top:2px;">프로젝트 3개</div>
          </div>
          <div>
            <div style="font-size:20px; font-weight:900; color:#111827;">₩4,900</div>
            <div style="font-size:11px; color:#9ca3af; text-align:right;">/월</div>
          </div>
        </div>
        <div style="font-size:13px; color:#374151; margin-bottom:14px; line-height:1.8;">
          ✓ 프로젝트 최대 3개<br>
          ✓ 공정 일정 관리<br>
          ✓ 캘린더<br>
          ✓ 공정 템플릿 사용<br>
          ✓ 업체 관리<br>
          ✓ 기본 알림<br>
          ✓ AI 일정표 캐처 등록 · 월 5회
        </div>
        <% if is_current %>
          <div style="text-align:center; padding:11px; background:#dbeafe; border-radius:12px; font-size:14px; font-weight:800; color:#2563eb;">현재 플랜</div>
        <% else %>
          <button onclick="requestPayment('standard', 4900)" style="width:100%; padding:12px; background:#2563eb; color:white; border:none; border-radius:12px; font-size:14px; font-weight:900; cursor:pointer; font-family:inherit;">
            스탠다드 시작 · ₩4,900/월
          </button>
        <% end %>
      </div>

      <%# PREMIUM %>
      <% is_current = @current_plan == "premium" %>
      <div style="background:linear-gradient(135deg, #1e1b4b 0%, #312e81 100%); border-radius:18px; padding:18px; border:2px solid <%= is_current ? '#818cf8' : 'transparent' %>;">
        <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:12px;">
          <div>
            <div style="font-size:16px; font-weight:900; color:white;">프리미엄 플랜</div>
            <div style="font-size:12px; color:#a5b4fc; font-weight:600; margin-top:2px;">공사등록 무제한</div>
          </div>
          <div>
            <div style="font-size:20px; font-weight:900; color:white;">₩9,900</div>
            <div style="font-size:11px; color:#a5b4fc; text-align:right;">/월</div>
          </div>
        </div>
        <div style="font-size:13px; color:rgba(255,255,255,0.85); margin-bottom:14px; line-height:1.8;">
          ✓ 스탠다드 전체 포함<br>
          ✓ 공사등록 무제한<br>
          <span style="color:#fde68a;">⭐ AI 일정표 캐처 등록 · 무제한</span><br>
          <span style="color:#fde68a;">⭐ 캘린더 위젯</span><br>
          <span style="color:#fde68a;">⭐ 잠금화면 위젯</span><br>
          <span style="color:#fde68a;">⭐ 시간 알림 설정</span><br>
          <span style="color:#fde68a;">⭐ 고급 알림</span>
        </div>
        <% if is_current %>
          <div style="text-align:center; padding:11px; background:rgba(255,255,255,0.15); border-radius:12px; font-size:14px; font-weight:800; color:white;">현재 플랜</div>
        <% else %>
          <button onclick="requestPayment('premium', 9900)" style="width:100%; padding:12px; background:linear-gradient(90deg, #6366f1, #818cf8); color:white; border:none; border-radius:12px; font-size:14px; font-weight:900; cursor:pointer; font-family:inherit;">
            프리미엄 시작 · ₩9,900/월
          </button>
        <% end %>
      </div>

    </div>

    <%# Cancel Subscription %>
    <% if @current_plan != "free" %>
      <div style="margin-top:20px; text-align:center;">
        <%= button_to "구독 해지", cancel_subscription_path, method: :delete,
            data: { turbo_confirm: "정말 구독을 해지하시겠습니까? 무료 플랜으로 전환됩니다." },
            style: "background:none; border:none; color:#ef4444; font-size:14px; font-weight:700; cursor:pointer; font-family:inherit; padding:12px;" %>
      </div>
    <% end %>

    <%# Info Box %>
    <div style="margin-top:16px; background:#f0f9ff; border-radius:14px; padding:14px 16px;">
      <div style="font-size:13px; font-weight:700; color:#0c4a6e; line-height:1.7;">
        💳 <strong>안전한 결제</strong><br>
        카드 정보는 PortOne(포트원)을 통해 안전하게 처리됩니다.<br>
        매월 자동 결제되며, 언제든 해지 가능합니다.
      </div>
    </div>

  </div>
</div>

<%# PortOne JS SDK %>
<script src="https://cdn.portone.io/v2/browser-sdk.js"></script>
<script>
  const STORE_ID = "<%= ENV['PORTONE_STORE_ID'] || '' %>";
  const CHANNEL_KEY = "<%= ENV['PORTONE_CHANNEL_KEY'] || '' %>";

  async function requestPayment(plan, amount) {
    if (!STORE_ID || !CHANNEL_KEY) {
      alert("결제 시스템이 아직 설정되지 않았습니다. 관리자에게 문의해주세요.");
      return;
    }

    const planLabels = { standard: "스탠다드", premium: "프리미엄" };
    const paymentId = `ilmeori_${plan}_<%= current_user.id %>_${Date.now()}`;

    try {
      const response = await PortOne.requestPayment({
        storeId: STORE_ID,
        channelKey: CHANNEL_KEY,
        paymentId: paymentId,
        orderName: `일머리 ${planLabels[plan]} 플랜 (월간)`,
        totalAmount: amount,
        currency: "KRW",
        payMethod: "CARD",
        customer: {
          customerId: "customer_<%= current_user.id %>",
          email: "<%= current_user.email %>",
          fullName: "<%= current_user.name %>"
        }
      });

      if (response.code) {
        // 사용자가 결제를 취소하거나 오류 발생
        if (response.code !== "FAILURE_TYPE_PG" || !response.message.includes("cancel")) {
          alert("결제 실패: " + response.message);
        }
        return;
      }

      // 서버에서 결제 검증
      const verifyRes = await fetch("/subscription/verify", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "X-CSRF-Token": document.querySelector('meta[name="csrf-token"]').content
        },
        body: JSON.stringify({
          paymentId: response.paymentId,
          plan: plan
        })
      });

      const result = await verifyRes.json();
      if (result.success) {
        alert(result.message);
        window.location.reload();
      } else {
        alert(result.message || "결제 검증 실패");
      }
    } catch (error) {
      console.error("Payment error:", error);
      alert("결제 처리 중 오류가 발생했습니다.");
    }
  }
</script>
