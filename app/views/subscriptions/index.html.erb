<script>
  // RevenueCat 초기화 (페이지 로드시 한 번만)
  let purchasesReady = false;

  async function initPurchases() {
    if (!window.Capacitor || !window.Capacitor.isNativePlatform()) return;
    try {
      const Purchases = window.Capacitor.Plugins.Purchases;
      if (!Purchases || purchasesReady) return;

      const RC_API_KEY = "<%= ENV['REVENUECAT_APPLE_API_KEY'] || 'appl_YOUR_KEY_HERE' %>";
      await Purchases.configure({
        apiKey: RC_API_KEY,
        appUserID: "<%= current_user.id %>"
      });
      purchasesReady = true;
    } catch (e) {
      console.warn('RevenueCat init failed:', e);
    }
  }

  async function requestPayment(plan, amount) {
    if (!window.Capacitor || !window.Capacitor.isNativePlatform()) {
      alert("해당 요금제 결제는 '일잘러' 모바일 앱에서만 가능합니다.\n앱을 통해서 진행해주세요!");
      return;
    }

    try {
      const Purchases = window.Capacitor.Plugins.Purchases;
      if (!Purchases) {
        alert("앱 결제 모듈을 불러오지 못했습니다.\n앱을 최신 버전으로 업데이트 후 다시 시도해주세요.");
        return;
      }

      await initPurchases();

      // 상품 식별자: App Store Connect에 등록된 정확한 Product ID 사용
      const productIdentifier = `com.workgood.app.${plan}`;

      // 상품 목록 조회
      const { products } = await Purchases.getProducts({
        productIdentifiers: [productIdentifier]
      });

      if (!products || products.length === 0) {
        alert("결제 상품을 불러오지 못했습니다.\n잠시 후 다시 시도해주세요.");
        return;
      }

      // 구매 진행
      const { customerInfo } = await Purchases.purchaseStoreProduct({
        product: products[0]
      });

      // 구매 성공 — 서버에 검증 요청
      const hasEntitlement =
        customerInfo.entitlements &&
        customerInfo.entitlements.active &&
        customerInfo.entitlements.active[plan];

      if (hasEntitlement) {
        window.location.href = `/subscription/verify_apple?plan=${plan}`;
      } else {
        // 엔타이틀먼트가 없어도 verify 요청 (RevenueCat Webhook으로 처리될 수 있음)
        window.location.href = `/subscription/verify_apple?plan=${plan}`;
      }

    } catch (e) {
      if (e.code === 'PURCHASE_CANCELLED') return; // 사용자가 취소
      console.error('Purchase error:', e);
      alert('결제 중 오류가 발생했습니다.\n고객센터: midaum79@gmail.com\n오류: ' + (e.message || e.code || '알 수 없는 오류'));
    }
  }

  async function restorePurchases() {
    if (!window.Capacitor || !window.Capacitor.isNativePlatform()) {
      alert("구매 내역 복원은 모바일 앱에서만 가능합니다.");
      return;
    }

    try {
      const Purchases = window.Capacitor.Plugins.Purchases;
      if (!Purchases) {
        alert("결제 모듈을 불러오지 못했습니다. 앱을 재시작 후 다시 시도해주세요.");
        return;
      }

      await initPurchases();

      const { customerInfo } = await Purchases.restorePurchases();

      const activePlans = Object.keys(customerInfo.entitlements?.active || {});

      if (activePlans.length > 0) {
        const restoredPlan = activePlans.includes('premium') ? 'premium' : 'standard';
        window.location.href = `/subscription/verify_apple?plan=${restoredPlan}`;
      } else {
        alert("복원할 구매 내역이 없습니다.\n이전에 구독하신 내역이 없거나 만료되었습니다.");
      }
    } catch (e) {
      console.error('Restore error:', e);
      alert('구매 복원 중 오류가 발생했습니다: ' + (e.message || '알 수 없는 오류'));
    }
  }

  // 페이지 로드 시 RevenueCat 초기화
  document.addEventListener('DOMContentLoaded', initPurchases);
  document.addEventListener('capacitorReady', initPurchases);
</script>
