<%# Shared partial for new/edit vendor %>
<div style="max-width:430px; margin:0 auto; min-height:100vh; background:#f5f5f5;">

  <%# Header %>
  <div style="background:white; padding:18px 20px 14px 20px; border-bottom:1px solid #ececec; position:sticky; top:0; z-index:30; margin-bottom:16px;">
    <div style="display:flex; justify-content:space-between; align-items:center;">
      <%= link_to "←", vendors_path, style: "font-size:24px; color:#111; text-decoration:none; font-weight:800;" %>
      <div style="font-size:20px; font-weight:900;"><%= vendor.new_record? ? "거래처 등록" : "거래처 수정" %></div>
      <div style="width:40px;"></div>
    </div>
  </div>

  <div style="padding:0 16px 100px 16px;">
    <% if vendor.errors.any? %>
      <div style="background:#fee2e2; color:#dc2626; border-radius:14px; padding:12px 16px; margin-bottom:16px; font-size:14px; font-weight:700;">
        <%= vendor.errors.full_messages.first %>
      </div>
    <% end %>

    <%= form_with model: vendor, local: true do |f| %>
      <div style="background:white; border-radius:16px; padding:18px; box-shadow:0 2px 8px rgba(0,0,0,0.04); display:flex; flex-direction:column; gap:16px;">

        <%# 거래처 구분 %>
        <div>
          <label style="font-size:13px; font-weight:800; color:#374151; display:block; margin-bottom:6px;">구분 *</label>
          <div style="display:flex; gap:12px;" id="vendor_type_container">
            <label style="flex:1; display:flex; align-items:center; justify-content:center; padding:12px; border:1px solid #dcdfe4; border-radius:12px; cursor:pointer; background:<%= vendor.vendor_type == 'individual' ? 'white' : '#eff6ff' %>; border-color:<%= vendor.vendor_type == 'individual' ? '#dcdfe4' : '#2563eb' %>;">
              <%= f.radio_button :vendor_type, "company", checked: (vendor.vendor_type != "individual"), style: "display:none;" %>
              <span style="font-size:14px; font-weight:800; color:<%= vendor.vendor_type == 'individual' ? '#6b7280' : '#1d4ed8' %>;">🏢 업체</span>
            </label>
            <label style="flex:1; display:flex; align-items:center; justify-content:center; padding:12px; border:1px solid #dcdfe4; border-radius:12px; cursor:pointer; background:<%= vendor.vendor_type == 'individual' ? '#fff7ed' : 'white' %>; border-color:<%= vendor.vendor_type == 'individual' ? '#ea580c' : '#dcdfe4' %>;">
              <%= f.radio_button :vendor_type, "individual", checked: (vendor.vendor_type == "individual"), style: "display:none;" %>
              <span style="font-size:14px; font-weight:800; color:<%= vendor.vendor_type == 'individual' ? '#c2410c' : '#6b7280' %>;">👤 개인</span>
            </label>
          </div>
          <script>
            document.querySelectorAll('input[name="vendor[vendor_type]"]').forEach(function(radio) {
              radio.addEventListener('change', function() {
                var isCompany = (this.value === 'company');
                var companyLabel = document.getElementById('vendor_type_container').children[0];
                var individualLabel = document.getElementById('vendor_type_container').children[1];
                
                companyLabel.style.background = isCompany ? '#eff6ff' : 'white';
                companyLabel.style.borderColor = isCompany ? '#2563eb' : '#dcdfe4';
                companyLabel.querySelector('span').style.color = isCompany ? '#1d4ed8' : '#6b7280';
                
                individualLabel.style.background = !isCompany ? '#fff7ed' : 'white';
                individualLabel.style.borderColor = !isCompany ? '#ea580c' : '#dcdfe4';
                individualLabel.querySelector('span').style.color = !isCompany ? '#c2410c' : '#6b7280';
              });
            });
          </script>
        </div>

        <%# 업체명 %>
        <div>
          <label style="font-size:13px; font-weight:800; color:#374151; display:block; margin-bottom:6px;"><span id="vendor-name-label"><%= vendor.vendor_type == 'individual' ? '고객명' : '업체명' %></span> *</label>
          <%= f.text_field :name, placeholder: "업체명 또는 고객명을 등록해 주세요",
              style: "width:100%; height:48px; border:1.5px solid #e5e7eb; border-radius:12px; padding:0 14px; font-size:15px; font-weight:700; font-family:inherit; box-sizing:border-box;" %>
        </div>

        <%# 사업자등록번호 %>
        <div>
          <label style="font-size:13px; font-weight:800; color:#374151; display:block; margin-bottom:6px;">사업자등록번호</label>
          <%= f.text_field :business_number, placeholder: "000-00-00000",
              style: "width:100%; height:48px; border:1.5px solid #e5e7eb; border-radius:12px; padding:0 14px; font-size:15px; font-weight:700; font-family:inherit; box-sizing:border-box;" %>
        </div>

        <%# 사업장주소 %>
        <div>
          <label style="font-size:13px; font-weight:800; color:#374151; display:block; margin-bottom:6px;">사업장주소</label>
          <%= f.hidden_field :address, id: "vendor_address" %>
          
          <button type="button"
                  id="vendor_address_search_button"
                  style="width:100%; height:48px; border:1.5px solid #e5e7eb; border-radius:12px; background:white; color:#374151; font-size:15px; font-weight:700; text-align:left; padding:0 14px; display:flex; justify-content:space-between; align-items:center;">
            <span id="vendor_address_display_text" style="color:<%= vendor.address.present? ? '#111827' : '#9ca3af' %>; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
              <%= vendor.address.presence || "주소 검색 (클릭)" %>
            </span>
            <span style="font-size:16px;">🔍</span>
          </button>

          <% detail_addr = vendor.address.to_s.split(" ").last(2).join(" ") rescue "" %>
          <input type="text"
                 id="vendor_detail_address"
                 name="detail_address"
                 placeholder="상세주소 입력"
                 style="margin-top:8px; width:100%; height:48px; border:1.5px solid #e5e7eb; border-radius:12px; padding:0 14px; font-size:15px; font-weight:700; font-family:inherit; box-sizing:border-box;">
        </div>

        <script>
          // 라디오 버튼 선택 시 라벨 동기화
          document.querySelectorAll('input[name="vendor[vendor_type]"]').forEach(function(radio) {
            radio.addEventListener('change', function() {
              var isCompany = (this.value === 'company');
              document.getElementById('vendor-name-label').textContent = isCompany ? '업체명' : '고객명';
            });
          });
        </script>

        <%# 담당자명 %>
        <div>
          <label style="font-size:13px; font-weight:800; color:#374151; display:block; margin-bottom:6px;">담당자명</label>
          <%= f.text_field :contact_name, placeholder: "담당자 이름 (예: 김부장)",
              style: "width:100%; height:48px; border:1.5px solid #e5e7eb; border-radius:12px; padding:0 14px; font-size:15px; font-weight:700; font-family:inherit; box-sizing:border-box;" %>
        </div>

        <%# 전화번호 %>
        <div>
          <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;">
            <label style="font-size:13px; font-weight:800; color:#374151;">전화번호</label>
            <button type="button" id="import_contact_btn" style="background:none; border:none; color:#2563eb; font-size:13px; font-weight:800; padding:0; cursor:pointer; display:none;">
              📞 연락처 불러오기
            </button>
          </div>
          <%= f.telephone_field :phone, placeholder: "010-0000-0000", id: "vendor_phone_input",
              style: "width:100%; height:48px; border:1.5px solid #e5e7eb; border-radius:12px; padding:0 14px; font-size:15px; font-weight:700; font-family:inherit; box-sizing:border-box;" %>
        </div>

        <script>
          function formatPhoneNumber(value) {
            if (!value) return value;
            value = value.replace(/[^0-9]/g, '');
            if (!value) return '';
            
            if (value.startsWith('02')) {
              if (value.length <= 2) return value;
              if (value.length <= 5) return value.replace(/(\d{2})(\d{1,3})/, '$1-$2');
              if (value.length <= 9) return value.replace(/(\d{2})(\d{3})(\d{1,4})/, '$1-$2-$3');
              return value.replace(/(\d{2})(\d{4})(\d{1,4})/, '$1-$2-$3');
            } else if (value.startsWith('15') || value.startsWith('16') || value.startsWith('18')) {
              if (value.length <= 4) return value;
              return value.replace(/(\d{4})(\d{1,4})/, '$1-$2');
            } else {
              if (value.length <= 3) return value;
              if (value.length <= 7) return value.replace(/(\d{3})(\d{1,3})/, '$1-$2');
              return value.replace(/(\d{3})(\d{4})(\d{1,4})/, '$1-$2-$3');
            }
          }

          document.addEventListener('DOMContentLoaded', function() {
            var phoneInput = document.getElementById('vendor_phone_input');
            if (phoneInput) {
              phoneInput.value = formatPhoneNumber(phoneInput.value);
              phoneInput.addEventListener('input', function(e) {
                e.target.value = formatPhoneNumber(e.target.value);
              });
            }

            var importBtn = document.getElementById('import_contact_btn');
            var isCapacitor = !!(window.Capacitor && window.Capacitor.isNativePlatform && window.Capacitor.isNativePlatform());

            if (isCapacitor || ('contacts' in navigator && 'ContactsManager' in window)) {
              importBtn.style.display = 'block';
              importBtn.addEventListener('click', async function() {
                if (isCapacitor && window.Capacitor.nativePromise) {
                  try {
                    const permission = await window.Capacitor.nativePromise('Contacts', 'requestPermissions', {});
                    if (permission.contacts === 'granted') {
                      const result = await window.Capacitor.nativePromise('Contacts', 'pickContact', { projection: { name: true, phones: true } });
                      if (result && result.contact) {
                        const contact = result.contact;
                        if (contact.phones && contact.phones.length > 0) {
                          phoneInput.value = formatPhoneNumber(contact.phones[0].number);
                        }
                        const nameInput = document.getElementById('vendor_name');
                        if (nameInput && !nameInput.value && contact.name && contact.name.display) {
                          nameInput.value = contact.name.display;
                        }
                      }
                    } else {
                      alert('연락처 접근 권한이 거부되어 있습니다.\n\n스마트폰의 [설정] 앱을 열고 [일잘러]를 찾아 연락처 접근 권한을 허용(켬)으로 변경한 뒤 다시 시도해 주세요.');
                    }
                  } catch (err) {
                    console.error('Capacitor 연락처 에러:', err);
                  }
                } else {
                  // 브라우저 Web API
                  try {
                    const contacts = await navigator.contacts.select(['name', 'tel'], { multiple: false });
                    if (contacts.length > 0) {
                      const contact = contacts[0];
                      if (contact.tel && contact.tel.length > 0) {
                        phoneInput.value = formatPhoneNumber(contact.tel[0]);
                      }
                      const nameInput = document.getElementById('vendor_name');
                      if (nameInput && !nameInput.value && contact.name && contact.name.length > 0) {
                        nameInput.value = contact.name[0];
                      }
                    }
                  } catch (ex) {
                    console.error('연락처 불러오기 실패:', ex);
                  }
                }
              });
            }
          });
        </script>

        <%# 메모 %>
        <div>
          <label style="font-size:13px; font-weight:800; color:#374151; display:block; margin-bottom:6px;">메모</label>
          <%= f.text_area :memo, placeholder: "전문분야, 결제 조건, 특이사항 등",
              rows: 3,
              style: "width:100%; border:1.5px solid #e5e7eb; border-radius:12px; padding:12px 14px; font-size:14px; font-weight:600; font-family:inherit; box-sizing:border-box; resize:none; line-height:1.6;" %>
        </div>

      </div>

      <%# Action buttons - 수정 완료 버튼만 form 안에 %>
      <div style="display:flex; flex-direction:column; gap:10px; margin-top:20px;">
        <%= f.submit vendor.new_record? ? "거래처 등록하기" : "수정 완료",
            style: "display:block; width:100%; padding:16px; background:#111827; color:white; border:none; border-radius:14px; font-size:18px; font-weight:900; cursor:pointer; font-family:inherit; box-sizing:border-box;" %>
      </div>

    <% end %>
    <%# 삭제·취소 버튼은 form 바깥에 위치 (form 중첩 방지) %>
    <div style="display:flex; flex-direction:column; gap:10px; margin-top:10px;">
      <% unless vendor.new_record? %>
        <%= button_to "거래처 삭제", vendor_path(vendor), method: :delete,
            form: { onsubmit: "return confirm('\"#{vendor.name}\" 거래처를 삭제할까요?');" },
            style: "width:100%; padding:14px; background:#fee2e2; color:#dc2626; border:none; border-radius:14px; font-size:16px; font-weight:900; cursor:pointer; font-family:inherit;" %>
      <% end %>

      <%= link_to "취소", vendors_path,
          style: "display:block; width:100%; padding:14px; background:#e5e7eb; color:#374151; border-radius:14px; font-size:16px; font-weight:800; text-decoration:none; text-align:center; box-sizing:border-box;" %>
    </div>
    </div>
  </div>
</div>

<!-- iOS/Android compatible popup layer -->
<div id="daum_postcode_layer" style="display:none;position:fixed;overflow:hidden;z-index:9999;-webkit-overflow-scrolling:touch;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);">
  <div style="position:absolute;top:50%;left:50%;transform:translate(-50%, -50%);width:90%;max-width:500px;background:#fff;border-radius:12px;overflow:hidden;box-shadow:0 10px 25px rgba(0,0,0,0.2);">
    <div style="display:flex;justify-content:space-between;align-items:center;padding:14px 18px;background:#f9fafb;border-bottom:1px solid #e5e7eb;">
      <span style="font-weight:800; color:#111;">주소 검색</span>
      <button type="button" onclick="closeDaumPostcode()" style="background:none;border:none;font-size:26px;line-height:1;cursor:pointer;color:#6b7280;padding:0;margin:0;">&times;</button>
    </div>
    <div id="daum_postcode_wrap" style="width:100%;height:450px;max-height:70vh;"></div>
  </div>
</div>

<script src="//t1.kakaocdn.net/mapjsapi/bundle/postcode/prod/postcode.v2.js"></script>

<script>
  function closeDaumPostcode() {
    document.getElementById('daum_postcode_layer').style.display = 'none';
  }

  document.addEventListener("DOMContentLoaded", function () {
    const addressSearchButton = document.getElementById("vendor_address_search_button");
    const addressField = document.getElementById("vendor_address");
    const detailAddressField = document.getElementById("vendor_detail_address");

    if (addressSearchButton) {
      addressSearchButton.addEventListener("click", function () {
        var layer = document.getElementById('daum_postcode_layer');
        var wrap = document.getElementById('daum_postcode_wrap');
        layer.style.display = 'block';

        new daum.Postcode({
          oncomplete: function(data) {
            let addr = "";
            let extraAddr = "";

            if (data.userSelectedType === "R") {
              addr = data.roadAddress;
            } else {
              addr = data.jibunAddress;
            }

            if (data.userSelectedType === "R") {
              if (data.bname && /[동|로|가]$/g.test(data.bname)) {
                extraAddr += data.bname;
              }
              if (data.buildingName && data.apartment === "Y") {
                extraAddr += (extraAddr !== "" ? ", " + data.buildingName : data.buildingName);
              }
              if (extraAddr !== "") {
                extraAddr = " (" + extraAddr + ")";
              }
            }

            addressField.value = addr + extraAddr;
            document.getElementById("vendor_address_display_text").textContent = addr + extraAddr;
            document.getElementById("vendor_address_display_text").style.color = "#111827";
            detailAddressField.focus();
            closeDaumPostcode();
          },
          width: '100%',
          height: '100%',
          maxSuggestItems: 5
        }).embed(wrap);
      });
    }

    // 폼 제출 시 상세 주소 병합
    if (addressField) {
      const form = addressField.closest("form");
      if (form) {
        form.addEventListener("submit", function (e) {
          if (detailAddressField && detailAddressField.value.trim() !== "") {
            const detailValue = detailAddressField.value.trim();
            // 이미 주소에 포함되어 있지 않은 경우에만 병합
            if (!addressField.value.includes(detailValue)) {
              addressField.value = addressField.value.trim() + " " + detailValue;
            }
          }
        });
      }
    }
  });
</script>
