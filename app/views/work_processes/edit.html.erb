<%
  today = Date.today

  display_year =
    if params[:year].present?
      params[:year].to_i
    else
      today.year
    end

  display_month =
    if params[:month].present?
      params[:month].to_i
    else
      today.month
    end

  current_month_date = Date.new(display_year, display_month, 1)
  prev_month_date = current_month_date.prev_month
  next_month_date = current_month_date.next_month

  calendar_start = current_month_date.beginning_of_week(:sunday)
  calendar_end = current_month_date.end_of_month.end_of_week(:sunday)
  calendar_days = (calendar_start..calendar_end).to_a

  selected_dates = @work_process.work_days.map(&:work_date)
%>

<div style="max-width:430px; margin:0 auto; min-height:100vh; background:#f5f5f5; padding:16px;">

  <div style="background:white; padding:18px 20px 14px 20px; border-bottom:1px solid #ececec; position:sticky; top:0; z-index:20; margin:-16px -16px 16px -16px;">
    <div style="display:flex; justify-content:space-between; align-items:center;">
      <%= link_to "←", work_process_path(@work_process), style: "font-size:24px; color:#111; text-decoration:none; font-weight:800; padding-left:16px;" %>
      <div style="font-size:22px; font-weight:900;">공정 수정</div>
      <div style="width:40px;"></div>
    </div>
  </div>

  <%= render "form",
      work_process: @work_process,
      submit_label: "수정하기",
      cancel_label: "공정 상세로",
      cancel_path: work_process_path(@work_process) %>
</div>