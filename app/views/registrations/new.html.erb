<!DOCTYPE html>
<html lang="ko">
<head>
  <title>회원가입 · 일머리</title>
  <meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
  <link rel="stylesheet" as="style" crossorigin href="https://cdn.jsdelivr.net/npm/pretendard/dist/web/static/pretendard.css" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: "Pretendard", -apple-system, sans-serif; background: #0f172a; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .card { background: white; border-radius: 28px; padding: 32px 28px; width: 100%; max-width: 400px; margin: 20px; }
    .logo { text-align: center; margin-bottom: 24px; }
    .logo-title { font-size: 26px; font-weight: 900; color: #111827; }
    .logo-sub { font-size: 13px; color: #9ca3af; font-weight: 600; margin-top: 4px; }
    .input-group { margin-bottom: 13px; }
    label { font-size: 13px; font-weight: 800; color: #374151; display: block; margin-bottom: 6px; }
    input { width: 100%; height: 50px; border: 1.5px solid #e5e7eb; border-radius: 14px; padding: 0 16px; font-size: 15px; font-family: inherit; outline: none; transition: border-color 0.15s; }
    input:focus { border-color: #2563eb; }
    .free-badge { display: inline-block; padding: 4px 12px; background: #dcfce7; color: #166534; border-radius: 999px; font-size: 12px; font-weight: 800; margin-bottom: 16px; }
    .btn-primary { width: 100%; height: 52px; background: #111827; color: white; border: none; border-radius: 14px; font-size: 17px; font-weight: 900; cursor: pointer; font-family: inherit; margin-top: 8px; }
    .divider { text-align: center; font-size: 13px; color: #9ca3af; margin: 16px 0; }
    .btn-secondary { display: block; width: 100%; text-align: center; padding: 14px; background: #f3f4f6; color: #374151; border-radius: 14px; text-decoration: none; font-size: 15px; font-weight: 800; }
    .alert { background: #fee2e2; color: #dc2626; border-radius: 12px; padding: 12px 14px; margin-bottom: 14px; font-size: 13px; font-weight: 700; }
    .terms { font-size: 12px; color: #9ca3af; text-align: center; margin-top: 14px; }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo">
      <div class="logo-title">일머리 🏗️</div>
      <div class="logo-sub">인테리어 공정관리</div>
    </div>
    <div style="text-align:center; margin-bottom:18px;">
      <span class="free-badge">✓ 무료로 시작 · 신용카드 불필요</span>
    </div>

    <% if @user&.errors&.any? %>
      <div class="alert"><%= @user.errors.full_messages.first %></div>
    <% end %>

    <%= form_with model: @user, url: signup_path, local: true do |f| %>
      <div class="input-group">
        <label>이름</label>
        <%= f.text_field :name, placeholder: "홍길동", autocomplete: "name" %>
      </div>
      <div class="input-group">
        <label>이메일</label>
        <%= f.email_field :email, placeholder: "email@example.com", autocomplete: "email" %>
      </div>
      <div class="input-group">
        <label>전화번호 (선택)</label>
        <%= f.telephone_field :phone, placeholder: "010-0000-0000" %>
      </div>
      <div class="input-group">
        <label>비밀번호</label>
        <%= f.password_field :password, placeholder: "8자 이상", autocomplete: "new-password" %>
      </div>
      <div class="input-group">
        <label>비밀번호 확인</label>
        <%= f.password_field :password_confirmation, placeholder: "비밀번호 재입력", autocomplete: "new-password" %>
      </div>
      <%= f.submit "무료 가입하기", class: "btn-primary" %>
    <% end %>

    <div class="terms">가입 시 이용약관 및 개인정보처리방침에 동의합니다</div>

    <div class="divider">이미 계정이 있으신가요?</div>
    <%= link_to "로그인", login_path, class: "btn-secondary" %>
  </div>
</body>
</html>
