<!DOCTYPE html>
<html lang="ko">
<head>
  <title>로그인 · 일머리</title>
  <meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
  <link rel="stylesheet" as="style" crossorigin href="https://cdn.jsdelivr.net/npm/pretendard/dist/web/static/pretendard.css" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: "Pretendard", -apple-system, sans-serif; background: #0f172a; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .card { background: white; border-radius: 28px; padding: 32px 28px; width: 100%; max-width: 400px; margin: 20px; }
    .logo { text-align: center; margin-bottom: 28px; }
    .logo-title { font-size: 28px; font-weight: 900; color: #111827; }
    .logo-sub { font-size: 13px; color: #9ca3af; font-weight: 600; margin-top: 4px; }
    .input-group { margin-bottom: 14px; }
    label { font-size: 13px; font-weight: 800; color: #374151; display: block; margin-bottom: 6px; }
    input { width: 100%; height: 50px; border: 1.5px solid #e5e7eb; border-radius: 14px; padding: 0 16px; font-size: 15px; font-family: inherit; outline: none; transition: border-color 0.15s; }
    input:focus { border-color: #2563eb; }
    .btn-primary { width: 100%; height: 52px; background: #111827; color: white; border: none; border-radius: 14px; font-size: 17px; font-weight: 900; cursor: pointer; font-family: inherit; margin-top: 8px; }
    .divider { text-align: center; font-size: 13px; color: #9ca3af; margin: 18px 0; }
    .btn-secondary { display: block; width: 100%; text-align: center; padding: 14px; background: #f3f4f6; color: #374151; border-radius: 14px; text-decoration: none; font-size: 15px; font-weight: 800; }
    .alert { background: #fee2e2; color: #dc2626; border-radius: 12px; padding: 12px 14px; margin-bottom: 16px; font-size: 14px; font-weight: 700; }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo">
      <div class="logo-title">일머리 🏗️</div>
      <div class="logo-sub">인테리어 공정관리</div>
    </div>

    <% if alert %>
      <div class="alert"><%= alert %></div>
    <% end %>

    <%= form_with url: login_path, local: true do |f| %>
      <div class="input-group">
        <label>이메일</label>
        <%= f.email_field :email, placeholder: "email@example.com", autocomplete: "email", value: params[:email] %>
      </div>
      <div class="input-group">
        <label>비밀번호</label>
        <%= f.password_field :password, placeholder: "비밀번호 입력", autocomplete: "current-password" %>
      </div>
      <%= f.submit "로그인", class: "btn-primary" %>
    <% end %>

    <div class="divider">계정이 없으신가요?</div>
    <%= link_to "무료로 시작하기 →", signup_path, class: "btn-secondary" %>
  </div>
</body>
</html>
