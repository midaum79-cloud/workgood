<div style="max-width:430px; margin:0 auto; min-height:100vh; background:#0a0f1e; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:24px;">

  <div style="width:100%; max-width:380px; display:flex; flex-direction:column; align-items:center;">

    <%# Logo — 5회 탭하면 히든 이메일 로그인 표시 %>
    <div id="logo-tap-area" style="margin-bottom:12px; cursor:pointer; -webkit-tap-highlight-color:transparent; user-select:none;">
      <img src="/logo.png" alt="일잘러 로고" style="width:260px; height:auto; filter:drop-shadow(0 4px 24px rgba(37,99,235,0.3)); pointer-events:none;">
    </div>

    <div style="font-size:15px; font-weight:700; color:rgba(255,255,255,0.5); text-align:center; margin-bottom:40px; letter-spacing:0.3px;">시공 일정 관리 앱</div>

    <% if alert %>
      <div style="width:100%; background:rgba(239,68,68,0.15); border:1px solid rgba(239,68,68,0.3); color:#fca5a5; border-radius:14px; padding:12px 16px; margin-bottom:16px; font-size:14px; font-weight:700; text-align:center;"><%= alert %></div>
    <% end %>

    <%# 인앱 브라우저 안내 (기본 숨김, JS로 표시) %>
    <div id="inapp-notice" style="display:none; width:100%; margin-bottom:16px;">
      <div style="background:rgba(251,191,36,0.12); border:1px solid rgba(251,191,36,0.3); border-radius:14px; padding:16px; text-align:center;">
        <div style="font-size:14px; font-weight:700; color:#fbbf24; margin-bottom:8px;">⚠️ 인앱 브라우저 감지</div>
        <div style="font-size:13px; color:rgba(255,255,255,0.6); line-height:1.6; margin-bottom:14px;">
          현재 네이버/카카오 등의 앱 내 브라우저에서<br>접속 중입니다. Google 로그인은 보안 정책상<br>외부 브라우저에서만 이용 가능합니다.
        </div>
        <a id="open-external-btn" href="#" onclick="openInExternalBrowser(); return false;"
          style="display:inline-flex; align-items:center; justify-content:center; gap:8px; width:100%; height:48px; background:linear-gradient(90deg,#f59e0b,#f97316); color:white; border:none; border-radius:12px; font-size:14px; font-weight:800; cursor:pointer; text-decoration:none; box-shadow:0 4px 16px rgba(245,158,11,0.3);">
          🌐 외부 브라우저에서 열기
        </a>
        <div style="font-size:11px; color:rgba(255,255,255,0.3); margin-top:10px; line-height:1.5;">
          또는 아래 이메일 로그인을 이용해주세요
        </div>
      </div>
    </div>

    <%# ===== 소셜 로그인 (메인 노출) ===== %>

    <div style="width:100%; text-align:center; margin-bottom:20px;">
      <span style="font-size:16px; font-weight:800; color:rgba(255,255,255,0.85); letter-spacing:0.3px;">로그인이 필요합니다</span>
    </div>

    <%# Google Login Button (인앱 브라우저에서 숨겨짐) %>
    <a id="google-login-btn" href="#" data-turbo="false" data-oauth-url="/auth/google_oauth2" style="width:100%; display:flex; align-items:center; justify-content:center; gap:12px; height:54px; background:white; color:#3c4043; border:none; border-radius:14px; font-size:15px; font-weight:700; cursor:pointer; font-family:inherit; text-decoration:none; box-shadow:0 2px 12px rgba(0,0,0,0.15); transition:all 0.2s;" onmouseover="this.style.boxShadow='0 4px 20px rgba(0,0,0,0.25)'" onmouseout="this.style.boxShadow='0 2px 12px rgba(0,0,0,0.15)'">
      <svg width="20" height="20" viewBox="0 0 48 48"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/></svg>
      Google 계정으로 로그인
    </a>

    <%# Apple Login Button %>
    <a id="apple-login-btn" href="#" data-turbo="false" data-oauth-url="/apple_auth" style="width:100%; display:flex; align-items:center; justify-content:center; gap:10px; height:54px; background:#ffffff; color:#000000; border:1px solid #d1d5db; border-radius:14px; font-size:15px; font-weight:700; cursor:pointer; font-family:inherit; text-decoration:none; box-shadow:0 2px 12px rgba(0,0,0,0.08); transition:all 0.2s; margin-top:12px;" onmouseover="this.style.boxShadow='0 4px 20px rgba(0,0,0,0.15)'; this.style.background='#f5f5f5'" onmouseout="this.style.boxShadow='0 2px 12px rgba(0,0,0,0.08)'; this.style.background='#ffffff'">
      <svg width="20" height="20" viewBox="0 0 256 315"><path d="M213.803 167.03c.442 47.58 41.74 63.413 42.197 63.615-.35 1.116-6.599 22.563-21.757 44.716-13.104 19.153-26.705 38.235-48.13 38.63-21.05.388-27.82-12.483-51.888-12.483-24.061 0-31.582 12.088-51.51 12.871-20.68.783-36.428-20.71-49.64-39.793C7.228 234.11-10.834 174.716 15.896 134.495c13.303-20.003 37.072-32.67 62.87-33.003 20.303-.388 39.453 13.65 51.853 13.65 12.394 0 35.66-16.891 60.103-14.415 10.234.427 38.958 4.136 57.384 31.152-1.484.927-34.255 19.998-33.888 59.647l-.415.504zM174.24 50.199c10.98-13.29 18.368-31.786 16.342-50.199-15.804.642-34.928 10.527-46.28 23.816-10.16 11.761-19.043 30.582-16.65 48.63 17.621 1.371 35.608-8.956 46.588-22.247" fill="#000"/></svg>
      Apple로 로그인
    </a>

    <%# ===== 히든 이메일 로그인 섹션 (기본 숨김, 로고 5회 탭 시 표시) ===== %>
    <div id="hidden-email-section" style="width:100%; overflow:hidden; max-height:0; opacity:0; transition:max-height 0.5s cubic-bezier(0.4,0,0.2,1), opacity 0.4s ease;">

      <div style="width:100%; display:flex; align-items:center; gap:16px; margin:24px 0;">
        <div style="flex:1; height:1px; background:rgba(255,255,255,0.1);"></div>
        <span style="font-size:12px; color:rgba(255,255,255,0.3); font-weight:600;">이메일 로그인</span>
        <div style="flex:1; height:1px; background:rgba(255,255,255,0.1);"></div>
      </div>

      <%= form_with url: login_path, method: :post, local: true, style: "width:100%;" do |f| %>
        <div style="margin-bottom:14px;">
          <input type="text" name="email" inputmode="email" autocomplete="email" placeholder="이메일" value="decoplan79@gmail.com"
            style="width:100%; height:52px; background:rgba(255,255,255,0.08); border:1.5px solid rgba(255,255,255,0.15); border-radius:14px; padding:0 16px; font-size:15px; font-family:inherit; color:white; outline:none; box-sizing:border-box;"
            onfocus="this.style.borderColor='#2563eb'" onblur="this.style.borderColor='rgba(255,255,255,0.15)'">
        </div>
        <div style="margin-bottom:20px;">
          <input type="password" name="password" placeholder="비밀번호" value="Best1maren!"
            style="width:100%; height:52px; background:rgba(255,255,255,0.08); border:1.5px solid rgba(255,255,255,0.15); border-radius:14px; padding:0 16px; font-size:15px; font-family:inherit; color:white; outline:none; box-sizing:border-box;"
            onfocus="this.style.borderColor='#2563eb'" onblur="this.style.borderColor='rgba(255,255,255,0.15)'">
        </div>
        <button type="submit"
          style="width:100%; height:52px; background:linear-gradient(90deg,#2563eb,#3b82f6); color:white; border:none; border-radius:14px; font-size:16px; font-weight:900; cursor:pointer; font-family:inherit; box-shadow:0 4px 20px rgba(37,99,235,0.4);">
          이메일로 로그인
        </button>
      <% end %>

      <div style="margin-top:20px; text-align:center;">
        <%= link_to signup_path, style: "display:inline-flex; align-items:center; gap:8px; font-size:14px; color:rgba(255,255,255,0.5); text-decoration:none; font-weight:700; transition:color 0.2s;", onmouseover: "this.style.color='rgba(255,255,255,0.9)'", onmouseout: "this.style.color='rgba(255,255,255,0.5)'" do %>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
          회원가입
        <% end %>
        <span style="color:rgba(255,255,255,0.2); margin:0 8px;">·</span>
        <%= link_to "비밀번호 찾기", new_password_reset_path,
            style: "font-size:14px; color:rgba(255,255,255,0.5); text-decoration:none; font-weight:700;" %>
      </div>
    </div>

    <%# 히든 이메일 로그인용 스페이서 %>
    <div id="other-login-hint" style="margin-top:8px;"></div>

    <div style="font-size:12px; color:rgba(255,255,255,0.2); text-align:center; margin-top:24px; line-height:1.7;">
      일잘러 v1.0 · © 2026<br>
      <%= link_to "개인정보처리방침", privacy_path, style: "color:rgba(255,255,255,0.3); text-decoration:underline;" %> ·
      <%= link_to "이용약관", terms_path, style: "color:rgba(255,255,255,0.3); text-decoration:underline;" %>
    </div>
  </div>
</div>

<style>
  @keyframes spin { to { transform: rotate(360deg); } }
</style>

<script>
(function() {
  // ── 로고 5회 탭 → 히든 이메일 로그인 표시 ──
  var tapCount = 0;
  var tapTimer = null;
  var logoArea = document.getElementById('logo-tap-area');
  var hiddenSection = document.getElementById('hidden-email-section');
  var loginHint = document.getElementById('other-login-hint');

  if (logoArea && hiddenSection) {
    logoArea.addEventListener('click', function(e) {
      e.preventDefault();
      tapCount++;
      clearTimeout(tapTimer);
      tapTimer = setTimeout(function() { tapCount = 0; }, 3000);
      if (tapCount >= 5) {
        hiddenSection.style.maxHeight = '500px';
        hiddenSection.style.opacity = '1';
        if (loginHint) loginHint.style.display = 'none';
        tapCount = 0;
      }
    });
  }

  var ua = navigator.userAgent || navigator.vendor || '';
  var isCapacitor = !!(window.Capacitor && window.Capacitor.isNativePlatform && window.Capacitor.isNativePlatform());
  var isAndroidWebView = /wv/.test(ua) || (/Android/.test(ua) && /Version\//.test(ua));
  var isInApp = new RegExp(['NAVER','KAKAOTALK','KakaoTalk','Instagram','FBAN','FBAV','FB_IAB','Line','DaumApps','everytimeApp','SamsungBrowser.*CrossApp','whale'].join('|'), 'i').test(ua);
  var isStandalone = window.matchMedia('(display-mode: standalone)').matches || navigator.standalone;

  console.log('[일잘러] isCapacitor:', isCapacitor, 'isAndroidWebView:', isAndroidWebView, 'UA:', ua);

  // ── 외부 브라우저 폴백 함수 (workhead 동일) ──
  function fallbackToExternalBrowser(oauthPath) {
    var nonce = Math.random().toString(36).substr(2) + Date.now().toString(36);
    var oauthUrl = window.location.origin + oauthPath + '?origin=' + encodeURIComponent(window.location.origin + '?source=app&nonce=' + nonce);
    console.log('[일잘러] 외부 브라우저 폴백, url:', oauthUrl);

    try {
      if (window.Capacitor && window.Capacitor.Plugins && window.Capacitor.Plugins.Browser && window.Capacitor.Plugins.Browser.open) {
        window.Capacitor.Plugins.Browser.open({ url: oauthUrl });
      } else {
        window.location.href = oauthUrl;
        return;
      }
    } catch(err) {
      window.location.href = oauthUrl;
      return;
    }

    // 폴링 (폴백 시에만 사용)
    var pollCount = 0;
    var maxPoll = 60;
    var pollInterval = setInterval(function() {
      pollCount++;
      if (pollCount > maxPoll) { clearInterval(pollInterval); return; }
      fetch('/auth/check_login?nonce=' + nonce)
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.token) {
            clearInterval(pollInterval);
            try {
              if (window.Capacitor && window.Capacitor.Plugins && window.Capacitor.Plugins.Browser) {
                window.Capacitor.Plugins.Browser.close();
              }
            } catch(e) {}
            window.location.href = window.location.origin + '/auth/token_login?token=' + data.token;
          }
        })
        .catch(function(err) { console.log('[일잘러] Poll error:', err); });
    }, 2000);
  }

  // ── Capacitor 앱: 네이티브 소셜 로그인 ──
  if (isCapacitor || isAndroidWebView) {
    var isIOS = /iPhone|iPad|iPod/i.test(ua);

    // ── SocialLogin 플러그인 초기화 (Google Web Client ID 필수) ──
    var socialLoginReady = false;
    if (window.Capacitor && window.Capacitor.Plugins && window.Capacitor.Plugins.SocialLogin) {
      try {
        window.Capacitor.Plugins.SocialLogin.initialize({
          google: {
            webClientId: '<%= ENV["GOOGLE_CLIENT_ID"] || "" %>'
          }
        }).then(function() {
          console.log('[일잘러] SocialLogin initialized successfully');
          socialLoginReady = true;
        }).catch(function(err) {
          console.warn('[일잘러] SocialLogin init warning:', err);
          socialLoginReady = true; // 실패해도 시도는 해봄
        });
      } catch(e) {
        console.warn('[일잘러] SocialLogin init error:', e);
      }
    }

    // ── Google: 네이티브 Google Sign-In SDK ──
    var googleBtn = document.getElementById('google-login-btn');
    if (googleBtn) {
      googleBtn.addEventListener('click', function(e) {
        e.preventDefault();

        // 버튼 로딩 상태
        var originalText = googleBtn.innerHTML;
        googleBtn.innerHTML = '<div style="width:20px;height:20px;border:2px solid #ccc;border-top:2px solid #333;border-radius:50%;animation:spin 0.8s linear infinite;"></div> 로그인 중...';
        googleBtn.style.pointerEvents = 'none';
        googleBtn.style.opacity = '0.7';

        function resetBtn() {
          googleBtn.innerHTML = originalText;
          googleBtn.style.pointerEvents = '';
          googleBtn.style.opacity = '';
        }

        console.log('[일잘러] Native Google Sign-In 시도... ready:', socialLoginReady);

        // SocialLogin 플러그인 확인
        if (window.Capacitor && window.Capacitor.Plugins && window.Capacitor.Plugins.SocialLogin) {
          var SocialLogin = window.Capacitor.Plugins.SocialLogin;

          // initialize가 완료될 때까지 짧게 대기
          var waitCount = 0;
          function tryLogin() {
            if (!socialLoginReady && waitCount < 10) {
              waitCount++;
              setTimeout(tryLogin, 300);
              return;
            }

            // iOS: 기존 Google 세션 초기화 (계정 선택 화면 강제 표시)
            if (isIOS) { try { SocialLogin.logout({ provider: 'google' }); } catch(e) {} }

            SocialLogin.login({
              provider: 'google',
              options: {}
            }).then(function(res) {
              console.log('[일잘러] Google native login success:', JSON.stringify(res));

              // ID Token 추출 (다양한 플러그인 버전 대응)
              var idToken = null;
              if (res && res.result && res.result.idToken) {
                idToken = res.result.idToken;
              } else if (res && res.result && res.result.credential && res.result.credential.idToken) {
                idToken = res.result.credential.idToken;
              } else if (res && res.idToken) {
                idToken = res.idToken;
              }

              if (!idToken) {
                console.error('[일잘러] ID Token 없음. 응답:', JSON.stringify(res));
                resetBtn();
                alert('Google 로그인 응답에서 인증 토큰을 찾을 수 없습니다.');
                return;
              }

              // 서버에 ID Token 전송
              var csrfToken = document.querySelector('meta[name="csrf-token"]') ? document.querySelector('meta[name="csrf-token"]').getAttribute('content') : '';
              fetch('/auth/native_google', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
                body: JSON.stringify({ idToken: idToken })
              })
              .then(function(r) { return r.json(); })
              .then(function(data) {
                if (data.token) {
                  window.location.href = window.location.origin + '/auth/token_login?token=' + data.token;
                } else {
                  resetBtn();
                  alert('Google 로그인 검증 실패: ' + (data.error || JSON.stringify(data)));
                }
              })
              .catch(function(err) {
                resetBtn();
                console.error('[일잘러] Google auth fetch error:', err);
                alert('서버 연결 오류. 네트워크를 확인해주세요.');
              });

            }).catch(function(err) {
              var errStr = JSON.stringify(err) || '';
              var errMsg = (err && err.message) || errStr;
              console.log('[일잘러] Google native login error:', errMsg);

              // 사용자가 직접 취소한 경우만 무시
              if (err && err.code === 'SIGN_IN_CANCELED') { resetBtn(); return; }
              if (errMsg === 'The user canceled the sign-in flow.') { resetBtn(); return; }

              // 네이티브 실패 → 외부 브라우저로 자동 전환
              console.log('[일잘러] 네이티브 실패, 외부 브라우저 폴백:', errMsg);
              googleBtn.innerHTML = '<div style="width:20px;height:20px;border:2px solid #ccc;border-top:2px solid #333;border-radius:50%;animation:spin 0.8s linear infinite;"></div> 브라우저로 로그인 중...';
              fallbackToExternalBrowser('/auth/google_oauth2');
            });
          }
          tryLogin();
        } else {
          // SocialLogin 플러그인 없음 → 외부 브라우저 폴백
          console.log('[일잘러] SocialLogin 플러그인 없음, 외부 브라우저 폴백');
          resetBtn();
          fallbackToExternalBrowser('/auth/google_oauth2');
        }
      });
    }

    // ── Apple: 네이티브 Apple Sign-In (workhead 동일) ──
    var btnApple = document.getElementById('apple-login-btn');
    if (isCapacitor && isIOS && btnApple) {
      btnApple.addEventListener('click', function(e) {
        e.preventDefault();
        try {
          if (window.Capacitor && window.Capacitor.Plugins && window.Capacitor.Plugins.AppleSignIn) {
            window.Capacitor.Plugins.AppleSignIn.signIn({
              scopes: ['EMAIL', 'FULL_NAME']
            }).then(function(res) {
              console.log('[일잘러] Apple Sign-In 성공');
              var idToken = res.idToken;
              var givenName = (res.name && res.name.givenName) || (res.givenName || '');
              var familyName = (res.name && res.name.familyName) || (res.familyName || '');
              var fullName = [familyName, givenName].filter(function(n) { return n; }).join(' ');

              if (!idToken) {
                alert('Apple 인증 정보를 받지 못했습니다.');
                return;
              }

              var csrfToken = document.querySelector('meta[name="csrf-token"]') ? document.querySelector('meta[name="csrf-token"]').getAttribute('content') : '';
              fetch('/auth/native_apple', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
                body: JSON.stringify({ id_token: idToken, name: fullName || null })
              })
              .then(function(r) { return r.json(); })
              .then(function(data) {
                if (data.token) {
                  window.location.href = window.location.origin + '/auth/token_login?token=' + data.token;
                } else {
                  alert('Apple 로그인 검증 실패: ' + (data.error || JSON.stringify(data)));
                }
              })
              .catch(function(err) {
                console.log('[일잘러] Apple API Error:', err);
                alert('Apple 로그인 처리 중 오류가 발생했습니다.');
              });
            }).catch(function(err) {
              console.log('[일잘러] Apple native error:', err);
            });
          } else {
            fallbackToExternalBrowser('/apple_auth');
          }
        } catch(err) {
          console.log('[일잘러] Apple login catch:', err);
          fallbackToExternalBrowser('/apple_auth');
        }
      });
    } else if (btnApple) {
      btnApple.addEventListener('click', function(e) {
        e.preventDefault();
        fallbackToExternalBrowser('/apple_auth');
      });
    }

    // 딥링크 수신 리스너는 application.html.erb의 글로벌 리스너로 통합되었습니다.
  }

  // ── 일반 인앱 브라우저(네이버, 카카오 등) ──
  if (isInApp && !isCapacitor && !isAndroidWebView) {
    var googleBtn2 = document.getElementById('google-login-btn');
    if (googleBtn2) googleBtn2.style.display = 'none';
    var appleBtn2 = document.getElementById('apple-login-btn');
    if (appleBtn2) appleBtn2.style.display = 'none';

    var notice = document.getElementById('inapp-notice');
    if (notice) notice.style.display = 'block';

    setTimeout(function() { openInExternalBrowser(); }, 800);
  } else if (!isCapacitor && !isAndroidWebView && !isStandalone) {
    // ── 일반 웹 브라우저 ──
    var webGoogleBtn = document.getElementById('google-login-btn');
    if (webGoogleBtn) {
      webGoogleBtn.addEventListener('click', function(e) {
        e.preventDefault();
        window.location.href = webGoogleBtn.getAttribute('data-oauth-url') || '/auth/google_oauth2';
      });
    }
    var webAppleBtn = document.getElementById('apple-login-btn');
    if (webAppleBtn) {
      webAppleBtn.addEventListener('click', function(e) {
        e.preventDefault();
        window.location.href = webAppleBtn.getAttribute('data-oauth-url') || '/apple_auth';
      });
    }
  }
})();

function openInExternalBrowser() {
  var currentUrl = window.location.href;
  var host = window.location.host;
  var path = window.location.pathname + window.location.search;
  var intentUrl = 'intent://' + host + path + '#Intent;scheme=https;package=com.android.chrome;end';

  if (/NAVER/i.test(navigator.userAgent)) {
    window.location.href = 'naversearchapp://inappbrowser?url=' + encodeURIComponent(currentUrl) + '&target=browser';
    setTimeout(function() { window.location.href = intentUrl; }, 500);
    return;
  }
  if (/KAKAOTALK|KakaoTalk/i.test(navigator.userAgent)) {
    window.location.href = 'kakaotalk://web/openExternal?url=' + encodeURIComponent(currentUrl);
    setTimeout(function() { window.location.href = intentUrl; }, 500);
    return;
  }
  window.location.href = intentUrl;
}
</script>

